---
// src/pages/services/index.astro

import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';
import SectionBanner from '../../components/ui/SectionBanner.astro';
import ServicesTabs from '../../components/services/ServicesTabs';

const allServices = await getCollection('services', ({ data }) => data.published);
allServices.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const serviceItems = allServices.map(s => ({
  slug:        s.slug,
  title:       s.data.title,
  tagline:     s.data.tagline ?? undefined,
  description: s.data.description ?? '',
}));
---

<Page
  title="Services"
  description="Architectural visualization, product visualization, large-scale projects, AI-enhanced workflows, 3ds Max scripting, workflow optimization, custom rendering. Working globally since 1996."
  fullBleed
>

  <SectionBanner
    image="/_img/banners/banner-services.jpg"
    label="Visuals & Solutions"
    title="Show It, Scale It, Build It."
    size="page"
    headingLevel="h1"
  />

  <div class="services-page">

    <div class="services-intro section-sm">
      <div class="container">
        <p class="services-sub">
          From single architectural renders to airport-scale animation sequences.
          From photorealistic product shots to custom MAXScript tools, pipeline audits, and AI-enhanced workflows.
          Seven services — scoped and priced to your actual project, not a package tier.
        </p>
      </div>
    </div>

    <section class="services-tabs-section section-sm">
      <div class="container">
        <ServicesTabs services={serviceItems} client:load />
      </div>
    </section>

    <hr class="page-rule" />

    <!-- Pricing teaser -->
    <section class="section">
      <div class="container pricing-teaser">
        <div>
          <p class="section-label">Pricing</p>
          <h2 class="display-md pricing-heading">Transparent from the Start</h2>
          <p class="pricing-body">
            Essential from €5,000 · Professional from €15,000 · Enterprise custom.
            We quote based on actual scope, not package tiers.
          </p>
          <div class="pricing-ctas">
            <a href="/pricing/" class="btn btn-secondary">See Pricing</a>
            <a href="/contact/" class="btn btn-primary">Get a Quote</a>
          </div>
        </div>
        <div class="pricing-note">
          <p>"Not sure which fits?<br />30-minute consultation, no charge."</p>
        </div>
      </div>
    </section>

  </div>
</Page>

<style>
  .services-page { width: 100%; }

  .services-intro {
    padding-block: clamp(1.5rem, 3vw, 2rem);
  }

  .services-sub {
    font-size: var(--fs-body);
    color: var(--color-text-muted);
    max-width: 52ch;
    line-height: 1.7;
    margin: 0;
  }

  .services-tabs-section {
    padding-block: clamp(1rem, 2vw, 2rem) clamp(2rem, 4vw, 3.5rem);
  }

  .page-rule {
    border-color: var(--color-border);
    margin-inline: auto;
    max-width: 1320px;
  }

  /* Pricing teaser */
  .pricing-teaser {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
  }

  .pricing-heading { margin: var(--space-3) 0 var(--space-4); }

  .pricing-body {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    max-width: 52ch;
    line-height: 1.7;
    margin-bottom: var(--space-6);
  }

  .pricing-ctas { display: flex; gap: var(--space-3); flex-wrap: wrap; }

  .pricing-note {
    border: 1px solid var(--color-border);
    padding: 2rem;
    border-radius: var(--radius-sm);
    background: var(--color-surface);
  }

  .pricing-note p {
    font-family: var(--font-display);
    font-size: var(--fs-body);
    font-weight: 300;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
    max-width: none;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .pricing-teaser { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
