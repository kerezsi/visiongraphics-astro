---
// src/pages/services/index.astro

import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';
import SectionBanner from '../../components/ui/SectionBanner.astro';

const allServices = await getCollection('services', ({ data }) => data.published);
allServices.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Page
  title="Services"
  description="Architectural visualization, AI-enhanced workflows, 3ds Max scripting, custom rendering. Budapest-based, working globally since 1996."
  fullBleed
>

  <SectionBanner
    image="/_img/banners/banner-services.jpg"
    label="Visuals & Solutions"
    title="Show It, Scale It, Build It."
    size="page"
    headingLevel="h1"
  />
  <div class="services-page">

    <div class="services-intro section-sm">
      <div class="container">
        <p class="services-sub">
          From single architectural renders to airport-scale animations.
          From custom MAXScript tools to AI-enhanced image pipelines.
        </p>
      </div>
    </div>

    <hr class="page-rule" />

    <!-- Services list -->
    <section class="services-list section">
      <div class="container">
        {allServices.map((service, i) => (
          <article class="service-row">
            <div class="service-row-header">
              <span class="service-n">{String(i + 1).padStart(2, '0')}</span>
              <div class="service-heading">
                <h2 class="service-title">{service.data.title}</h2>
                {service.data.tagline && (
                  <p class="service-tagline">{service.data.tagline}</p>
                )}
              </div>
              <a href={`/services/${service.slug}/`} class="btn btn-secondary service-link">Learn more</a>
            </div>
            <div class="service-row-body">
              <p class="service-body">{service.data.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <hr class="page-rule" />

    <!-- Pricing teaser -->
    <section class="section">
      <div class="container pricing-teaser">
        <div>
          <p class="section-label">Pricing</p>
          <h2 class="display-md pricing-heading">Transparent from the Start</h2>
          <p class="pricing-body">
            Essential from €5,000 · Professional from €15,000 · Enterprise custom.
            We quote based on actual scope, not package tiers.
          </p>
          <div class="pricing-ctas">
            <a href="/pricing/" class="btn btn-secondary">See Pricing</a>
            <a href="/contact/" class="btn btn-primary">Get a Quote</a>
          </div>
        </div>
        <div class="pricing-note">
          <p>"Not sure which fits?<br />30-minute consultation, no charge."</p>
        </div>
      </div>
    </section>

  </div>
</Page>

<style>
  .services-page { width: 100%; }

  .services-intro {
    padding-block: clamp(1.5rem, 3vw, 2rem);
  }

  .services-sub {
    font-size: var(--fs-body);
    color: var(--color-text-muted);
    max-width: 52ch;
    line-height: 1.7;
    margin: 0;
  }

  .page-rule {
    border-color: var(--color-border);
    margin-inline: auto;
    max-width: 1320px;
  }

  /* Service rows */
  .services-list {
    display: flex;
    flex-direction: column;
  }

  .service-row {
    padding-block: 2.5rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .service-row:last-child { border-bottom: 1px solid var(--color-border); }

  .service-row-header {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
  }

  .service-n {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    flex-shrink: 0;
    padding-top: 0.2rem;
  }

  .service-heading { flex: 1; }

  .service-title {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 0.3rem;
  }

  .service-tagline {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    color: var(--color-accent);
    font-style: italic;
    margin: 0;
  }

  .service-link { flex-shrink: 0; }

  .service-row-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    padding-left: calc(1.25rem + 2rem); /* align with heading */
  }

  .service-body {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 58ch;
    margin: 0;
  }

  /* Pricing teaser */
  .pricing-teaser {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
  }

  .pricing-heading { margin: 0.75rem 0 1rem; }

  .pricing-body {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    max-width: 52ch;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .pricing-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .pricing-note {
    border: 1px solid var(--color-border);
    padding: 2rem;
    border-radius: var(--radius-sm);
    background: var(--color-surface);
  }

  .pricing-note p {
    font-family: var(--font-display);
    font-size: var(--fs-body);
    font-weight: 300;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
    max-width: none;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .pricing-teaser { grid-template-columns: 1fr; gap: 2rem; }
  }

  @media (max-width: 768px) {
    .service-row-header { flex-wrap: wrap; }
    .service-link { width: 100%; }
    .service-row-body { grid-template-columns: 1fr; padding-left: 0; }
  }
</style>
