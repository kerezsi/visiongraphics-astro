---
import Page from '../../layouts/Page.astro';
import PageHero from '../../components/ui/PageHero.astro';
---

<Page
  title="Workflow Optimization"
  description="Visualization pipeline audits, batch automation, MAXScript utilities, AI-assisted QC. Vision Graphics Kft. — Budapest."
>

  <PageHero
    image="/_img/banners/banner-workflow.jpg"
    label="Your Pipeline Can Be Faster"
    title="Workflow Optimization"
    variant="section"
  />
  <div class="service-page">

    <div class="service-breadcrumb">
      <a href="/services/">Services</a>
      <span>→</span>
      <span>Workflow Optimization</span>
    </div>

    <p class="section-label">Service</p>
    <h2 class="display-lg service-h1">Workflow Optimization</h2>
    <p class="service-tagline-large">Your pipeline is probably slower than it needs to be.</p>

    <p class="service-lead">
      We audit visualization workflows and build fixes: automated batch processes,
      tool integrations, MAXScript utilities, AI-assisted QC. We've been
      optimizing our own pipeline for 30 years — we know where the time goes.
    </p>

    <hr class="service-rule" />

    <div class="service-body-grid">
      <div class="service-main">

        <h2 class="service-section-h2">What we fix</h2>
        <div class="deliverable-grid">
          {[
            {
              title: 'Pipeline Audit',
              desc: 'We map your current workflow, identify bottlenecks, and produce a prioritized list of improvements with estimated time savings.',
            },
            {
              title: 'Batch Automation',
              desc: 'Automate repetitive tasks: render submission, file naming, format conversion, delivery packaging. Hours of manual work reduced to minutes.',
            },
            {
              title: 'Tool Integration',
              desc: 'Connect your tools — 3ds Max, V-Ray, project management, file storage — so data flows without manual copy-paste steps.',
            },
            {
              title: 'AI-Assisted QC',
              desc: 'Automated quality checks on large render batches. Catch render errors, missing elements, and colour drift before delivery.',
            },
            {
              title: 'Team Process Design',
              desc: 'For studios with multiple artists: review and file handoff protocols that prevent version confusion and lost work.',
            },
            {
              title: 'Custom Scripts',
              desc: 'MAXScript and Python tools built for your specific production problems. Tools you\'ll actually use, not generic plugins.',
            },
          ].map(d => (
            <div class="deliverable-card">
              <h3 class="deliverable-title">{d.title}</h3>
              <p class="deliverable-desc">{d.desc}</p>
            </div>
          ))}
        </div>

        <h2 class="service-section-h2">Who this is for</h2>
        <ul class="results-list">
          <li>Visualization studios spending too much time on admin and file management</li>
          <li>Architects and developers who run visualization in-house</li>
          <li>Marketing teams managing large image libraries</li>
          <li>Studios scaling up who need reproducible processes</li>
        </ul>

        <h2 class="service-section-h2">How it works</h2>
        <p class="body-text">
          We start with a 1-hour discovery call, then either a remote audit of your current workflow
          or a site visit. Within one week we deliver a written report with specific recommendations
          and time-saving estimates. You can implement yourself or engage us to build the fixes.
        </p>

      </div>

      <aside class="service-sidebar">
        <div class="sidebar-block">
          <h3 class="sidebar-label">Starting point</h3>
          <p class="sidebar-price">from €1,500</p>
          <p class="sidebar-note">Pipeline audit + written report. Implementation quoted separately.</p>
        </div>

        <div class="sidebar-cta">
          <a href="/contact/" class="btn btn-primary sidebar-btn">Book an Audit</a>
          <a href="/services/3ds-max-tools/" class="btn btn-ghost">3ds Max scripting</a>
        </div>
      </aside>
    </div>

  </div>
</Page>

<style>
  .service-page { max-width: 1060px; }
  .service-breadcrumb { display: flex; align-items: center; gap: 0.5rem; font-family: var(--font-body); font-size: 0.72rem; color: var(--color-text-faint); margin-bottom: 2rem; }
  .service-breadcrumb a { color: var(--color-text-muted); text-decoration: none; transition: color 200ms; }
  .service-breadcrumb a:hover { color: var(--color-accent); }
  .service-h1 { margin: 0.5rem 0 0.75rem; }
  .service-tagline-large { font-family: var(--font-display); font-size: 1.2rem; font-style: italic; color: var(--color-accent); margin-bottom: 1.5rem; }
  .service-lead { font-size: 0.98rem; color: var(--color-text-muted); max-width: 65ch; line-height: 1.75; margin: 0 0 2rem; }
  .service-rule { border-color: var(--color-border); margin-bottom: 2.5rem; }
  .service-body-grid { display: grid; grid-template-columns: 1fr 240px; gap: 4rem; align-items: start; }
  .service-main { display: flex; flex-direction: column; gap: 2.5rem; }
  .service-section-h2 { font-family: var(--font-body); font-size: 0.65rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-text-faint); margin-bottom: 1rem; }
  .deliverable-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); }
  .deliverable-card { background: var(--color-surface); padding: 1.5rem; transition: background 200ms; }
  .deliverable-card:hover { background: var(--color-surface-2); }
  .deliverable-title { font-family: var(--font-body); font-size: 0.875rem; font-weight: 500; color: var(--color-text); margin-bottom: 0.4rem; }
  .deliverable-desc { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.6; margin: 0; max-width: none; }
  .results-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .results-list li { font-size: 0.88rem; color: var(--color-text-muted); padding-left: 1.25rem; position: relative; line-height: 1.5; }
  .results-list li::before { content: '→'; position: absolute; left: 0; color: var(--color-accent); font-size: 0.7rem; }
  .body-text { font-size: 0.9rem; color: var(--color-text-muted); max-width: 65ch; line-height: 1.75; margin: 0; }
  .service-sidebar { display: flex; flex-direction: column; gap: 2rem; position: sticky; top: 5rem; }
  .sidebar-block { display: flex; flex-direction: column; gap: 0.6rem; }
  .sidebar-label { font-family: var(--font-body); font-size: 0.62rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-text-faint); }
  .sidebar-price { font-family: var(--font-display); font-size: 1.5rem; font-weight: 300; color: var(--color-text); margin: 0; }
  .sidebar-note { font-size: 0.75rem; color: var(--color-text-faint); line-height: 1.5; margin: 0; max-width: none; }
  .sidebar-cta { display: flex; flex-direction: column; gap: 0.75rem; }
  .sidebar-btn { width: 100%; justify-content: center; }
  @media (max-width: 900px) { .service-body-grid { grid-template-columns: 1fr; } .service-sidebar { position: static; } .deliverable-grid { grid-template-columns: 1fr; } }
</style>
