---
import Page from '../../layouts/Page.astro';
import PageHero from '../../components/ui/PageHero.astro';
---

<Page
  title="Architectural Visualization"
  description="Expert architectural visualization — stills, animations, 360° tours, VR walkthroughs. Budapest-based, working globally since 1996."
>

  <PageHero
    image="/_img/banners/banner-arch-viz.jpg"
    label="See It Before You Build"
    title="Architectural Visualization"
  />
  <div class="service-page">

    <div class="service-breadcrumb">
      <a href="/services/">Services</a>
      <span>→</span>
      <span>Architectural Visualization</span>
    </div>

    <p class="section-label">Service</p>
    <h1 class="display-lg service-h1">Architectural Visualization</h1>
    <p class="service-tagline-large">Turn plans into decisions.</p>

    <p class="service-lead">
      We convert technical drawings into clear 3D views that get projects approved,
      properties sold, and stakeholders aligned. 30 years of doing this —
      for budgets ranging from a single apartment block to an airport terminal.
    </p>

    <hr class="service-rule" />

    <div class="service-body-grid">
      <div class="service-main">

        <h2 class="service-section-h2">What we deliver</h2>
        <div class="deliverable-grid">
          {[
            {
              title: 'Architectural Stills',
              desc: 'High-resolution renders for planning, marketing, and presentations. Interior and exterior. Daylight, dusk, and night variants.',
            },
            {
              title: '3D Animation',
              desc: 'Walkthroughs, flyovers, phasing sequences. Up to 4K. For marketing campaigns, planning submissions, and stakeholder presentations.',
            },
            {
              title: '360° Interactive Tours',
              desc: 'Pano2VR-based panoramas, embeddable on any website. Click-to-explore rooms and spaces. Works on mobile and desktop.',
            },
            {
              title: 'VR Walkthroughs',
              desc: 'Real-time Unreal Engine experiences for headset or browser. Pre-sell properties before a brick is laid.',
            },
            {
              title: 'Photo Integration',
              desc: 'CGI blended with site photography. For before/after comparisons, planning applications, and contextual renders.',
            },
            {
              title: 'AI-Enhanced Variations',
              desc: 'Fast concept iterations using AI-assisted pipelines. Explore material options, lighting moods, and design alternatives without full re-renders.',
            },
          ].map(d => (
            <div class="deliverable-card">
              <h3 class="deliverable-title">{d.title}</h3>
              <p class="deliverable-desc">{d.desc}</p>
            </div>
          ))}
        </div>

        <h2 class="service-section-h2">Results clients get</h2>
        <ul class="results-list">
          <li>Pre-sell properties before construction begins — with visuals that feel real</li>
          <li>Catch design conflicts before they reach the site — 30 years of pattern recognition</li>
          <li>Get planning approval with visuals that explain, not just impress</li>
          <li>Reduce revision cycles with clear iterative drafts</li>
          <li>Reach international buyers with high-quality marketing materials</li>
        </ul>

        <h2 class="service-section-h2">Typical timeline</h2>
        <div class="timeline-table">
          {[
            { scope: 'Single exterior still', time: '5–7 working days' },
            { scope: 'Interior still set (3–5 views)', time: '1–2 weeks' },
            { scope: 'Full marketing package (10–15 views)', time: '2–3 weeks' },
            { scope: 'Short animation (60–90 sec)', time: '3–5 weeks' },
            { scope: '360° tour (3–5 panoramas)', time: '2–3 weeks' },
          ].map(r => (
            <div class="timeline-row">
              <span class="timeline-scope">{r.scope}</span>
              <span class="timeline-time">{r.time}</span>
            </div>
          ))}
        </div>

      </div>

      <aside class="service-sidebar">
        <div class="sidebar-block">
          <h3 class="sidebar-label">What you need to start</h3>
          <ul class="sidebar-list">
            <li>Plans (CAD, PDF, or sketch)</li>
            <li>Style references you like</li>
            <li>Your deadline</li>
          </ul>
          <p class="sidebar-note">Nothing polished required. We guide the rest.</p>
        </div>

        <div class="sidebar-block">
          <h3 class="sidebar-label">Pricing</h3>
          <p class="sidebar-price">from €5,000</p>
          <p class="sidebar-note">Final price based on scope.<br />Quote within one business day.</p>
        </div>

        <div class="sidebar-cta">
          <a href="/contact/" class="btn btn-primary sidebar-btn">Get a Quote</a>
          <a href="/portfolio/?cat=architectural-visualization" class="btn btn-ghost">See portfolio</a>
        </div>
      </aside>
    </div>

  </div>
</Page>

<style>
  .service-page { max-width: 1060px; }

  .service-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    color: var(--color-text-faint);
    margin-bottom: 2rem;
  }

  .service-breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 200ms;
  }

  .service-breadcrumb a:hover { color: var(--color-accent); }

  .service-h1 { margin: 0.5rem 0 0.75rem; }

  .service-tagline-large {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-style: italic;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .service-lead {
    font-size: 0.98rem;
    color: var(--color-text-muted);
    max-width: 65ch;
    line-height: 1.75;
    margin: 0 0 2rem;
  }

  .service-rule { border-color: var(--color-border); margin-bottom: 2.5rem; }

  .service-body-grid {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 4rem;
    align-items: start;
  }

  .service-main { display: flex; flex-direction: column; gap: 2.5rem; }

  .service-section-h2 {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin-bottom: 1rem;
  }

  .deliverable-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .deliverable-card {
    background: var(--color-surface);
    padding: 1.5rem;
    transition: background 200ms;
  }

  .deliverable-card:hover { background: var(--color-surface-2); }

  .deliverable-title {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.4rem;
  }

  .deliverable-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
    max-width: none;
  }

  .results-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .results-list li {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }

  .results-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.7rem;
  }

  .timeline-table {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
  }

  .timeline-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--color-border);
    gap: 1rem;
  }

  .timeline-row:last-child { border-bottom: none; }

  .timeline-scope {
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  .timeline-time {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-accent);
    white-space: nowrap;
  }

  /* Sidebar */
  .service-sidebar {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    top: 5rem;
  }

  .sidebar-block { display: flex; flex-direction: column; gap: 0.6rem; }

  .sidebar-label {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .sidebar-list li {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    padding-left: 0.9rem;
    position: relative;
  }

  .sidebar-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-border);
    font-size: 0.7rem;
  }

  .sidebar-price {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--color-text);
    margin: 0;
  }

  .sidebar-note {
    font-size: 0.75rem;
    color: var(--color-text-faint);
    line-height: 1.5;
    margin: 0;
    max-width: none;
  }

  .sidebar-cta { display: flex; flex-direction: column; gap: 0.75rem; }
  .sidebar-btn { width: 100%; justify-content: center; }

  @media (max-width: 900px) {
    .service-body-grid { grid-template-columns: 1fr; }
    .service-sidebar { position: static; }
    .deliverable-grid { grid-template-columns: 1fr; }
  }
</style>
