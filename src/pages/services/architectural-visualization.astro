---
import Page from '../../layouts/Page.astro';
import SectionBanner from '../../components/ui/SectionBanner.astro';
import ImageCompare from '../../components/ui/ImageCompare';
---

<Page
  title="Architectural Visualization"
  description="Expert architectural visualization — stills, animations, 360° tours, VR walkthroughs. Budapest-based, working globally since 1996."
>

  <SectionBanner
    image="/_img/banners/banner-arch-viz.jpg"
    label="See It Before You Build"
    title="Architectural Visualization"
    size="page"
    headingLevel="h1"
  />
  <div class="service-page">

    <div class="service-breadcrumb">
      <a href="/services/">Services</a>
      <span>→</span>
      <span>Architectural Visualization</span>
    </div>

    <p class="section-label">Service</p>
    <h2 class="display-lg service-h1">Architectural Visualization</h2>
    <p class="service-tagline-large">Turn plans into decisions.</p>

    <div class="service-body-grid">
      <div class="service-main">

        <p class="service-lead">
          Buildings are expensive to get wrong. We help you see exactly what you're getting
          before construction starts. We turn architectural plans into images and animations
          that show what your building will look like when it's finished.
        </p>

        <h2 class="service-section-h2">What we do</h2>
        <ul class="results-list">
          <li>Spot design issues early when they're cheap to fix</li>
          <li>Show clients and investors what they're getting</li>
          <li>Get faster approvals from planning committees</li>
          <li>Help your team understand the details</li>
          <li>Market properties before they're built</li>
        </ul>

        <p class="body-text">
          We offer three main types of visualization: still images, animations, and interactive tools.
          Each has its strengths, and many clients use a mix of all three. Still images work great
          for marketing and planning applications. Animations help people understand how spaces flow
          together. And interactive tools let users explore at their own pace.
        </p>
        <p class="body-text">
          AI is changing how we work. It helps us try out different design options faster and add
          more detail to our visuals. But we always keep control of the creative process —
          AI is just another tool in our toolkit.
        </p>

      </div>

      <aside class="service-sidebar">
        <div class="sidebar-block">
          <h3 class="sidebar-label">What you need to start</h3>
          <ul class="sidebar-list">
            <li>Plans (CAD, PDF, or sketch)</li>
            <li>Style references you like</li>
            <li>Your deadline</li>
          </ul>
          <p class="sidebar-note">Nothing polished required. We guide the rest.</p>
        </div>

        <div class="sidebar-block">
          <h3 class="sidebar-label">Pricing</h3>
          <p class="sidebar-price">from €5,000</p>
          <p class="sidebar-note">Final price based on scope.<br />Quote within one business day.</p>
        </div>

        <div class="sidebar-cta">
          <a href="/contact/" class="btn btn-primary sidebar-btn">Get a Quote</a>
          <a href="/portfolio/?cat=architectural-visualization" class="btn btn-ghost">See portfolio</a>
        </div>
      </aside>
    </div>

    <!-- Before / After comparison -->
    <div class="service-compare-block">
      <p class="section-label">Photo Integration</p>
      <h3 class="service-compare-heading">Site Photo vs. CGI Render</h3>
      <p class="service-compare-sub">
        Drag the handle to compare an existing site photograph with the finished CGI render placed on the same scene.
      </p>
      <ImageCompare
        client:load
        before={{
          src: '/_img/banners/banner-arch-viz.jpg',
          alt: 'Existing site — before visualization',
          label: 'Before',
        }}
        after={{
          src: '/_img/banners/banner-arch-viz.jpg',
          alt: 'Architectural CGI render',
          label: 'After',
        }}
        initialPosition={50}
        aspectRatio="16 / 7"
      />
    </div>

  </div>

  <SectionBanner
    image="/_img/banners/banner-arch-viz.jpg"
    label="Still Images"
    title="Stills That Inform Decisions"
    headingLevel="h2"
  />
  <div class="service-section container">
    <div class="deliverable-grid">
      {[
        {
          title: 'Exterior Views',
          desc: 'Using V-Ray with 3ds Max, we create photorealistic images showing how your building fits into its surroundings. Typical timeline: 1–2 weeks. Perfect for planning applications, marketing materials, client presentations, and public consultations.',
        },
        {
          title: 'Interior Views',
          desc: 'We pay special attention to materials, lighting, and atmosphere to create spaces that feel real. Each interior takes 1–2 weeks. Helps with layout checks, client presentations, material testing, tenant marketing, and furniture planning.',
        },
        {
          title: 'Aerial Views',
          desc: 'Combining drone photography with 3D modelling to show accurate context. 1–2 weeks. Useful for understanding neighbourhood fit, showing site layout, and marketing larger developments.',
        },
      ].map(d => (
        <div class="deliverable-card">
          <h3 class="deliverable-title">{d.title}</h3>
          <p class="deliverable-desc">{d.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <SectionBanner
    image="/_img/banners/banner-general.jpg"
    label="Animations"
    title="Motion That Explains"
    headingLevel="h2"
  />
  <div class="service-section container">
    <div class="deliverable-grid">
      {[
        {
          title: 'Building Walkthroughs',
          desc: 'Take a virtual walk through your building before it exists. These 3–4 week productions show how spaces connect, the flow between areas, views from different spots, light changes through the day, and what it feels like to be there.',
        },
        {
          title: 'Exterior Flyby',
          desc: 'See your building from every angle. These animations give everyone a clear picture of how the building sits in its surroundings. Perfect for showing the overall design, highlighting key features, and marketing.',
        },
        {
          title: 'Construction Sequences',
          desc: 'Understanding how your building comes together is crucial. Over 2–3 weeks, we create sequences that help with planning construction stages, spotting potential problems, coordinating contractors, and training site teams.',
        },
      ].map(d => (
        <div class="deliverable-card">
          <h3 class="deliverable-title">{d.title}</h3>
          <p class="deliverable-desc">{d.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <SectionBanner
    image="/_img/banners/banner-tech.jpg"
    label="Interactive Tools"
    title="Experiences People Remember"
    headingLevel="h2"
  />
  <div class="service-section container">
    <div class="deliverable-grid">
      {[
        {
          title: '360° Tours',
          desc: 'Web-based tours that work on any device. 2–3 weeks to create. Great for virtual property viewings, design reviews, training staff, marketing to clients, and public consultations.',
        },
        {
          title: 'Virtual Reality',
          desc: 'Using Unreal Engine, we create fully interactive environments where users can walk around freely. These 4–6 week projects help with understanding spaces properly, testing if layouts work, and showing clients the real scale.',
        },
        {
          title: 'Interactive Presentations',
          desc: 'Custom applications for desktop and AR viewing. 3–4 weeks. Desktop: real-time exploration, material switching, view comparison, measurement tools. AR: on-site visualisation, scale model viewing, context integration, multi-user sessions.',
        },
      ].map(d => (
        <div class="deliverable-card">
          <h3 class="deliverable-title">{d.title}</h3>
          <p class="deliverable-desc">{d.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <SectionBanner
    image="/_img/banners/banner-workflow.jpg"
    label="When You Need It"
    title="Support Through Every Phase"
    headingLevel="h2"
  />
  <div class="service-section container">
    <div class="timeline-table">
      {[
        { scope: 'Concept Design (2–4 weeks)', time: 'Quick concept visualizations · Mass studies and volume analysis · Basic material options · Early-stage pricing support' },
        { scope: 'Permit Design (3–5 weeks)', time: 'Context studies · Environmental impact views · Planning documentation · Public consultation materials' },
        { scope: 'Detailed Design (3–6 weeks)', time: 'Detailed exterior & interior renderings · Material and finish studies · Lighting analysis · Construction detail visualization' },
      ].map(r => (
        <div class="timeline-row">
          <span class="timeline-scope">{r.scope}</span>
          <span class="timeline-time">{r.time}</span>
        </div>
      ))}
    </div>
  </div>

</Page>

<style>
  .service-page {
    max-width: 1060px;
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  .service-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    margin-bottom: 2rem;
  }

  .service-breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 200ms;
  }

  .service-breadcrumb a:hover { color: var(--color-accent); }

  .service-h1 { margin: 0.5rem 0 0.75rem; }

  .service-tagline-large {
    font-family: var(--font-display);
    font-size: var(--fs-h6);
    font-style: italic;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .service-lead {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    max-width: 65ch;
    line-height: 1.75;
    margin: 0 0 1.5rem;
  }

  .service-body-grid {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 4rem;
    align-items: start;
    margin-bottom: var(--space-10);
  }

  .service-main { display: flex; flex-direction: column; gap: 1.5rem; }

  .service-section-h2 {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin-bottom: 0.5rem;
  }

  .service-compare-block { margin-top: var(--space-8); }

  .service-compare-heading {
    font-size: var(--fs-h5);
    font-weight: 600;
    color: var(--color-text);
    margin: var(--space-2) 0 var(--space-3);
  }

  .service-compare-sub {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    max-width: 60ch;
    margin-bottom: var(--space-6);
  }

  /* Sub-sections */
  .service-section {
    padding-block: clamp(2rem, 4vw, 3rem);
  }

  .deliverable-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .deliverable-card {
    background: var(--color-surface);
    padding: 1.5rem;
    transition: background 200ms;
  }

  .deliverable-card:hover { background: var(--color-surface-2); }

  .deliverable-title {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.4rem;
  }

  .deliverable-desc {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
    max-width: none;
  }

  .results-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .results-list li {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }

  .results-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: var(--fs-xs);
  }

  .body-text {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    max-width: 65ch;
    line-height: 1.75;
    margin: 0;
  }

  .timeline-table {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
  }

  .timeline-row {
    display: grid;
    grid-template-columns: 220px 1fr;
    align-items: baseline;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--color-border);
    gap: 1.5rem;
  }

  .timeline-row:last-child { border-bottom: none; }

  .timeline-scope {
    font-size: var(--fs-xs);
    color: var(--color-text);
    font-weight: 500;
  }

  .timeline-time {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Sidebar */
  .service-sidebar {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    top: 5rem;
  }

  .sidebar-block { display: flex; flex-direction: column; gap: 0.6rem; }

  .sidebar-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .sidebar-list li {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    padding-left: 0.9rem;
    position: relative;
  }

  .sidebar-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-border);
    font-size: var(--fs-xs);
  }

  .sidebar-price {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: 300;
    color: var(--color-text);
    margin: 0;
  }

  .sidebar-note {
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    line-height: 1.5;
    margin: 0;
    max-width: none;
  }

  .sidebar-cta { display: flex; flex-direction: column; gap: 0.75rem; }
  .sidebar-btn { width: 100%; justify-content: center; }

  @media (max-width: 900px) {
    .service-body-grid { grid-template-columns: 1fr; }
    .service-sidebar { position: static; }
    .deliverable-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .timeline-row { grid-template-columns: 1fr; }
  }
</style>
