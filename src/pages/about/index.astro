---
// src/pages/about/index.astro

import Page          from '../../layouts/Page.astro';
import SectionBanner from '../../components/ui/SectionBanner.astro';
import timeline      from '../../data/about-timeline.json';

const specialists = [
  { role: '3D Scanning Specialist',      desc: 'Detailed digital copies of buildings and objects using scanning equipment.' },
  { role: 'Architecture Photographer',   desc: 'High-quality site photography matched to real-world detail in 3D work.' },
  { role: 'Character Animator',          desc: 'Natural movement for digital people that make spaces feel lived-in.' },
  { role: 'Character Artist',            desc: 'Digital people — from casual passersby to office workers.' },
  { role: 'Environment Artist',          desc: 'Rich digital worlds: parks, gardens, cityscapes at any scale.' },
  { role: 'UI/UX Designer',              desc: 'Interaction design for interactive projects and VR experiences.' },
  { role: 'Graphic Designer',            desc: '2D elements that complement 3D: logos, layouts, infographics.' },
  { role: 'Interior Designer',           desc: 'Furniture, materials and spatial feel for interior projects.' },
  { role: 'Web Developer',               desc: 'Websites and platforms for presenting embedded 3D work online.' },
  { role: 'Photogrammetry Expert',       desc: 'Site photos turned into accurate 3D models — the digital twin approach.' },
  { role: '3D Generalist',               desc: 'All-round modelling, texturing and rendering across any brief.' },
  { role: 'Unreal Engine Developer',     desc: 'Real-time 3D experiences: VR walkthroughs, interactive kiosks.' },
  { role: 'Drone Pilot',                 desc: 'Aerial photography and video showing how projects fit surroundings.' },
  { role: 'BIM Specialist',              desc: 'Visual accuracy cross-checked against technical building data.' },
  { role: 'Crowd Simulator',             desc: 'Realistic crowd behaviour for large public spaces and transit hubs.' },
];
---

<Page
  title="About"
  description="Vision Graphics Kft. — Budapest-based architectural visualization studio founded 1996 by László Kerezsi. 30 years, 500+ projects across four continents."
  fullBleed
  >
  <div class="about-page">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- PAGE HEADER / SECTION 1 — ABOUT THE STUDIO            -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <SectionBanner
      image="/_img/banners/banner-large-scale.jpg"
      label="Vision Graphics"
      title="About the Studio"
      headingLevel="h1"
      size="page"
    />

    <section class="about-studio section">
      <div class="container two-col">

        <div class="col-left">
          <p class="body-lead">
            We've been bringing architectural ideas to life through 3D visualization
            for over 30 years. What started as a small Budapest studio has grown
            into a globally active practice — airport terminals, urban masterplans,
            VR experiences, and retail rollouts across four continents.
          </p>
        </div>

        <div class="col-right">
          <div class="diff-block">
            <p class="diff-label">What makes us different</p>
            <p class="body-text">
              We solve communication problems, not just render problems.
              Whether you need to win investor approval, succeed in a design
              competition, or show a neighbourhood what's coming — we build
              the visual argument that makes it happen.
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- SECTION 2 — MEET THE EXPERT                            -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <SectionBanner
      image="/_img/banners/banner-general.jpg"
      label="Founder"
      title="Meet the Expert"
    />

    <section class="founder-section section">
      <div class="container founder-inner">

        <!-- Text column -->
        <div class="founder-text">
          <p class="founder-name-label">László Kerezsi</p>
          <p class="founder-role">Visualization Director</p>

          <p class="body-text">
            László started Vision Graphics in 1996. Before AI was a buzzword,
            he was writing custom MAXScript tools to solve production problems.
            Before VR was mainstream, he was building walkthrough experiences
            for real estate clients.
          </p>
          <p class="body-text">
            He works directly on every client project — from initial brief through
            final delivery. No layers of project managers between you and the
            person making decisions about your visuals.
          </p>
          <p class="body-text">
            Currently: integrating AI tools into production workflows,
            building custom desktop utilities for visualization pipelines,
            and preparing a presentation on AI-driven disruption in
            architectural visualization for the Ybl Conference 2026.
          </p>

          <div class="founder-contact">
            <a href="tel:+36309454179" class="contact-link">
              <span class="contact-link-label">Phone</span>
              <span class="contact-link-value">+36 30 945 4179</span>
            </a>
            <a href="mailto:info@visiongraphics.eu" class="contact-link">
              <span class="contact-link-label">Email</span>
              <span class="contact-link-value">info@visiongraphics.eu</span>
            </a>
          </div>
        </div>

        <!-- Photo + stats column -->
        <div class="founder-aside">
          <div class="founder-photo-wrap">
            <img
              src="/laszlo.jpg"
              alt="László Kerezsi — Founder, Vision Graphics"
              class="founder-photo"
              width="400"
              height="520"
              loading="lazy"
            />
          </div>
          <div class="founder-stats">
            {[
              { n: '30+',  l: 'Years in 3ds Max' },
              { n: '15+',  l: 'Years with V-Ray' },
              { n: '500+', l: 'Projects delivered' },
              { n: '4',    l: 'Continents' },
            ].map(s => (
              <div class="stat-block">
                <span class="stat-n">{s.n}</span>
                <span class="stat-l">{s.l}</span>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- SECTION 3 — HOW WE WORK                                -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <SectionBanner
      image="/_img/banners/banner-workflow.jpg"
      label="Structure"
      title="How We Work"
    />

    <section class="how-section section">
      <div class="container">

        <div class="two-col how-intro">
          <div class="col-left">
            <h3 class="section-sub-heading">Small Team, Big Results</h3>
            <p class="body-lead">
              Think of us as the conductors of an orchestra — we bring in the
              right experts at the right time to make your project work.
            </p>
          </div>
          <div class="col-right">
            <p class="body-text">
              We're a small core team that can tackle large-scale commissions
              through our network of tested specialists. You always work with
              László directly. The team scales around the project, not around overhead.
            </p>
            <p class="inhouse-label">We keep the most critical parts in-house:</p>
            <ul class="how-list">
              <li>Project management — one point of contact, start to finish</li>
              <li>Render farm operation and quality control before every delivery</li>
              <li>Core 3D work requiring 30 years of judgement to get right</li>
              <li>Final output in the formats your team can actually use</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Start a Conversation</a>
          </div>
        </div>

        <!-- Specialist network -->
        <div class="specialists-block">
          <div class="specialists-header">
            <p class="block-label">Our Network of Experts</p>
            <p class="body-text specialists-intro">
              When your project needs something special, we bring in the right expert.
              Every specialist below has been tested on real commissions.
            </p>
          </div>
          <div class="specialists-grid">
            {specialists.map(s => (
              <div class="specialist-card">
                <p class="specialist-role">{s.role}</p>
                <p class="specialist-desc">{s.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Why it works -->
        <div class="benefits-block">
          <p class="block-label">Why This Works So Well</p>
          <div class="benefits-grid">
            {[
              { t: 'Move quickly',        b: 'Small core means fast decisions. No committee approvals for scope changes.' },
              { t: 'Right talent',         b: 'The right specialists brought in when needed — not carried as overhead.' },
              { t: 'Quality stays high',   b: 'László reviews everything before it leaves the studio. No exceptions.' },
              { t: 'Precise scope',        b: 'You get exactly what your project needs, not a one-size-fits-all solution.' },
            ].map(b => (
              <div class="benefit-item">
                <h4 class="benefit-title">{b.t}</h4>
                <p class="benefit-body">{b.b}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- SECTION 4 — TIMELINE                                   -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <SectionBanner
      image="/_img/banners/banner-arch-viz.jpg"
      label="History"
      title="Our Story"
    />

    <section class="timeline-section section">
      <div class="container">

        <p class="body-text timeline-intro">
          30 years. 10 eras. A record of how the studio grew, adapted, and kept delivering.
        </p>

        <div class="tl-timeline" id="about-timeline">
          <div class="tl-line" id="tl-line"></div>
          {timeline.map((era, i) => (
            <div class="tl-item" data-index={i} style={`transition-delay: ${i * 80}ms`}>
              <span class="tl-years">{era.years}</span>
              <div class="tl-content">
                <h3 class="tl-title">{era.title}</h3>
                <p class="tl-text">{era.summary}</p>
                <ul class="tl-projects">
                  {era.projects.map(p => <li>{p}</li>)}
                </ul>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- CTA                                                    -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <section class="about-cta">
      <div class="container about-cta-inner">
        <div>
          <h2 class="cta-heading">Ready to Work Together?</h2>
          <p class="cta-sub">30-minute consultation. No charge. No obligation.</p>
        </div>
        <a href="/contact/" class="btn btn-primary">Get in Touch</a>
      </div>
    </section>

  </div>
</Page>

<script>
  // Scroll-animated vertical timeline
  const section = document.querySelector<HTMLElement>('.timeline-section');
  const line    = document.getElementById('tl-line');
  const items   = document.querySelectorAll<HTMLElement>('.tl-item');

  // Reveal line when section enters viewport
  if (section && line) {
    const lineObserver = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        line.classList.add('revealed');
        lineObserver.disconnect();
      }
    }, { threshold: 0.05 });
    lineObserver.observe(section);
  }

  // Pop-in each item and advance the red portion of the line
  const total = items.length;
  let visibleCount = 0;

  const itemObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        visibleCount++;
        if (line) {
          const pct = Math.round((visibleCount / total) * 100);
          line.style.setProperty('--tl-red', `${pct}%`);
        }
        itemObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  items.forEach(item => itemObserver.observe(item));
</script>

<style>
  .about-page { width: 100%; }

  /* ── Shared typography ───────────────────────────────────── */
  .body-lead {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin: 0;
  }

  .body-text {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin: 0;
    max-width: 60ch;
  }

  .block-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 1.25rem;
  }

  .section-sub-heading {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 1.25rem;
  }

  /* ── Two-column layout (shared) ──────────────────────────── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  /* ── Section 1: About the studio ────────────────────────── */
  .about-studio {
    padding-block: clamp(3rem, 5vw, 5rem);
  }

  .diff-block {
    padding: 2rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .diff-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.75rem;
  }

  /* ── Section 2: Founder ──────────────────────────────────── */
  .founder-section {
    padding-block: clamp(3rem, 5vw, 5rem);
  }

  .founder-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  .founder-name-label {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0 0 0.4rem;
  }

  .founder-role {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 2rem;
  }

  .founder-text .body-text { margin-bottom: 1rem; max-width: 58ch; }
  .founder-text .body-text:last-of-type { margin-bottom: 2rem; }

  .founder-contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    padding: 0.4rem 0;
    cursor: pointer;
    transition: color 200ms;
  }

  .contact-link-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    min-width: 3.5rem;
  }

  .contact-link-value {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    transition: color 200ms;
  }

  .contact-link:hover .contact-link-value { color: var(--color-text); }

  /* Photo — portrait rectangle, squared corners */
  .founder-aside {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
  }

  .founder-photo-wrap {
    width: 320px;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .founder-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 600ms ease;
  }

  .founder-photo-wrap:hover .founder-photo { transform: scale(1.03); }

  /* Stat blocks */
  .founder-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    width: 100%;
  }

  .stat-block {
    background: var(--color-surface);
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    transition: background 200ms;
  }

  .stat-block:hover { background: var(--color-surface-2); }

  .stat-n {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 300;
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .stat-l {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 400;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  /* ── Section 3: How We Work ──────────────────────────────── */
  .how-section { padding-block: clamp(3rem, 5vw, 5rem); }

  .how-intro { margin-bottom: 4rem; }

  .inhouse-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin: 1.5rem 0 0.75rem;
  }

  .how-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin-bottom: 2rem;
  }

  .how-list li {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    padding-left: 1.2rem;
    position: relative;
    line-height: 1.6;
  }

  .how-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: var(--fs-xs);
    top: 0.18em;
  }

  /* Specialist grid */
  .specialists-block {
    border-top: 1px solid var(--color-border);
    padding-top: 3rem;
    margin-bottom: 3rem;
  }

  .specialists-header {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(3rem, 6vw, 7rem);
    margin-bottom: 2rem;
    align-items: start;
  }

  .specialists-intro { max-width: 56ch; }

  .specialists-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .specialist-card {
    background: var(--color-surface);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    transition: background 200ms;
  }

  .specialist-card:hover { background: var(--color-surface-2); }

  .specialist-role {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .specialist-desc {
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    line-height: 1.55;
    margin: 0;
  }

  /* Benefits */
  .benefits-block {
    border-top: 1px solid var(--color-border);
    padding-top: 3rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-top: 1.5rem;
  }

  .benefit-item { display: flex; flex-direction: column; gap: 0.5rem; }

  .benefit-title {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: 400;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin: 0;
    line-height: 1.1;
  }

  .benefit-body {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Section 4: Scroll-animated Timeline ────────────────── */
  .timeline-section { padding-block: clamp(3rem, 5vw, 5rem); }

  .timeline-intro {
    max-width: 68ch;
    margin-bottom: 2.5rem;
    color: var(--color-text-faint);
    font-size: var(--fs-small);
  }

  /* Timeline container */
  .tl-timeline {
    position: relative;
    padding-left: 9rem;
  }

  /* Vertical line */
  .tl-line {
    position: absolute;
    left: 7rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 1px;
    background: linear-gradient(
      to bottom,
      var(--color-accent) 0%,
      var(--color-accent) var(--tl-red, 0%),
      var(--color-border) var(--tl-red, 0%),
      var(--color-border) 100%
    );
    transform-origin: top;
    transform: scaleY(0);
    transition: transform 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .tl-line.revealed { transform: scaleY(1); }

  /* Each era row */
  .tl-item {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    padding-bottom: 2.5rem;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .tl-item.visible { opacity: 1; transform: translateY(0); }

  /* Dot on the line */
  .tl-item::before {
    content: '';
    position: absolute;
    left: calc(-9rem + 7rem - 5px); /* line offset - half dot */
    top: 0.35rem;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    background: var(--color-bg);
    z-index: 1;
    transition: border-color 400ms, background 400ms, box-shadow 400ms;
    transition-delay: inherit;
  }
  .tl-item.visible::before {
    border-color: var(--color-accent);
    background: var(--color-accent);
    box-shadow: 0 0 10px color-mix(in srgb, var(--color-accent) 35%, transparent);
  }

  .tl-years {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-accent);
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
    display: block;
  }

  .tl-title {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .tl-text {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    line-height: 1.75;
    max-width: 65ch;
    margin-bottom: 1rem;
  }

  .tl-projects {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.5rem;
    margin: 0;
  }

  .tl-projects li {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    letter-spacing: 0.04em;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 1px;
    transition: color 200ms ease, border-color 200ms ease;
  }

  .tl-projects li:hover {
    color: var(--color-text-muted);
    border-color: rgba(255, 255, 255, 0.22);
  }

  /* ── CTA ─────────────────────────────────────────────────── */
  .about-cta {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding-block: 5rem;
  }

  .about-cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-heading {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 300;
    color: var(--color-text);
