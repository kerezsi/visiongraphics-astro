---
// src/pages/about/index.astro

import Page from '../../layouts/Page.astro';
import PageHero from '../../components/ui/PageHero.astro';
import timeline from '../../data/about-timeline.json';
---

<Page
  title="About"
  description="Vision Graphics Kft. — Budapest-based architectural visualization studio founded 1996 by László Kerezsi. 30 years, 500+ projects across four continents."
  fullBleed
>
  <div class="about-page">

    <PageHero
      image="/_img/banners/banner-general.jpg"
      label="30 Years"
      title="Making Complex Ideas Visible"
    />

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- LÁSZLÓ SECTION                                         -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="laszlo-section section">
      <div class="container laszlo-inner">

        <div class="laszlo-text">
          <p class="section-label">Founder</p>
          <h2 class="display-md">László Kerezsi</h2>
          <p class="laszlo-tagline">Visualization Director</p>

          <p class="laszlo-body">
            László started Vision Graphics in 1996. Before AI was a buzzword,
            he was writing custom MAXScript tools to solve production problems.
            Before VR was mainstream, he was building walkthrough experiences
            for real estate clients.
          </p>
          <p class="laszlo-body">
            He works directly on client projects — from initial brief through
            final delivery. No layers of project managers between you and the
            person making decisions about your visuals.
          </p>
          <p class="laszlo-body">
            Currently: integrating AI tools into production workflows,
            building custom desktop utilities for visualization pipelines,
            and preparing a presentation on AI-driven disruption in
            architectural visualization for the Ybl Conference 2026.
          </p>

          <div class="laszlo-contact">
            <a href="tel:+36309454179" class="contact-link">
              <span class="contact-link-label">Phone</span>
              <span>+36 30 945 4179</span>
            </a>
            <a href="mailto:info@visiongraphics.eu" class="contact-link">
              <span class="contact-link-label">Email</span>
              <span>info@visiongraphics.eu</span>
            </a>
          </div>
        </div>

        <div class="laszlo-photo-col">
          <div class="laszlo-photo-wrap">
            <img
              src="/laszlo.jpg"
              alt="László Kerezsi — Founder, Vision Graphics"
              class="laszlo-photo"
              width="280"
              height="280"
              loading="lazy"
            />
          </div>
          <div class="laszlo-stats">
          {[
            { n: '30+',  l: 'Years in 3ds Max' },
            { n: '15+',  l: 'Years with V-Ray' },
            { n: '500+', l: 'Projects delivered' },
            { n: '4',    l: 'Continents' },
          ].map(s => (
            <div class="stat-block">
              <span class="stat-block-n">{s.n}</span>
              <span class="stat-block-l">{s.l}</span>
            </div>
          ))}
          </div>
        </div>

      </div>
    </section>

    <hr class="page-rule" />

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- HOW WE WORK                                            -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="how-section section">
      <div class="container how-inner">
        <div class="how-header">
          <p class="section-label">Structure</p>
          <h2 class="display-md">Small Core.<br />Right Specialists When You Need Them.</h2>
        </div>
        <div class="how-body">
          <p>
            We keep the critical parts in-house: project management, quality
            control, render farm operation, and the 3D work that requires
            30 years of experience to get right.
          </p>
          <p>
            When a project calls for it, we bring in tested specialists:
            character animators, BIM experts, drone pilots, Unreal Engine
            developers, photogrammetry specialists, 3D scanning specialists,
            architectural photographers, character artists, environment artists,
            graphic designers, interior designers, crowd simulation experts,
            web developers, and more.
          </p>
          <p>
            You always work with László directly. The team scales around
            the project, not around overhead.
          </p>
          <a href="/contact/" class="btn btn-primary how-cta">Start a Conversation</a>
        </div>
      </div>
    </section>

    <hr class="page-rule" />

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- TIMELINE                                               -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="timeline-section section">
      <div class="container">
        <p class="section-label">History</p>
        <h2 class="display-md timeline-heading">28 Years of Work</h2>
      </div>
      <div class="timeline container">
        {timeline.map((era, i) => (
          <div class="timeline-era">
            <div class="era-left">
              <span class="era-years">{era.years}</span>
              <div class="era-line" aria-hidden="true"></div>
            </div>
            <div class="era-right">
              <h3 class="era-title">{era.title}</h3>
              <p class="era-summary">{era.summary}</p>
              <ul class="era-projects">
                {era.projects.map(p => (
                  <li>{p}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- CTA                                                    -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="about-cta">
      <div class="container about-cta-inner">
        <div>
          <h2 class="cta-heading">Ready to Work Together?</h2>
          <p class="cta-sub">30-minute consultation. No charge. No obligation.</p>
        </div>
        <a href="/contact/" class="btn btn-primary">Get in Touch</a>
      </div>
    </section>

  </div>
</Page>

<style>
  .about-page { width: 100%; }

  .page-rule {
    border-color: var(--color-border);
    margin-inline: auto;
    max-width: 1320px;
  }

  /* ── László founder section ──────────────────────────────── */
  .laszlo-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  .laszlo-photo-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  /* Larger photo for presence at 1280–1440px */
  .laszlo-photo-wrap {
    width: 240px;
    height: 240px;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid var(--color-border);
    flex-shrink: 0;
    /* Reserve space so layout doesn't jump */
    aspect-ratio: 1;
  }

  .laszlo-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: filter 400ms ease;
  }

  .laszlo-photo-wrap:hover .laszlo-photo { filter: brightness(1.05); }

  .laszlo-tagline {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0.4rem 0 1.75rem;
  }

  .laszlo-body {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    max-width: 58ch;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .laszlo-body:last-of-type { margin-bottom: 2rem; }

  .laszlo-contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.88rem;
    color: var(--color-text-muted);
    text-decoration: none;
    cursor: pointer;
    transition: color 200ms ease;
    padding: 0.35rem 0;
  }

  .contact-link:hover { color: var(--color-text); }

  .contact-link-label {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    min-width: 3.5rem;
  }

  /* ── Stat blocks — 2×2 grid ──────────────────────────────── */
  .laszlo-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    align-self: start;
    min-width: 260px;
  }

  .stat-block {
    background: var(--color-surface);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  /* Cormorant Garamond for large numerals — editorial weight */
  .stat-block-n {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .stat-block-l {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    line-height: 1.4;
  }

  /* ── How We Work section ─────────────────────────────────── */
  .how-inner {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  .how-header h2 { margin: 0.75rem 0 0; }

  .how-body {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .how-body p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    max-width: 58ch;
    line-height: 1.8;
  }

  .how-cta { margin-top: 0.5rem; align-self: flex-start; }

  /* ── Timeline ────────────────────────────────────────────── */
  .timeline-heading { margin: 0.75rem 0 2.5rem; }

  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline-era {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 3rem;
    padding-block: 2.75rem;
    border-top: 1px solid var(--color-border);
  }

  .timeline-era:last-child { border-bottom: 1px solid var(--color-border); }

  .era-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding-top: 0.25rem;
  }

  .era-years {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .era-line {
    width: 1px;
    flex: 1;
    min-height: 2rem;
    background: linear-gradient(to bottom, var(--color-border), transparent);
    margin-left: 0.3rem;
  }

  .era-right {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  /* Larger, more editorial era titles */
  .era-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .era-summary {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    max-width: 65ch;
    margin-top: 0.1rem;
  }

  /* Project name pills */
  .era-projects {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.5rem;
    margin-top: 0.5rem;
  }

  .era-projects li {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 400;
    color: var(--color-text-faint);
    letter-spacing: 0.04em;
    padding: 0.18rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 1px;
    transition: color 200ms ease, border-color 200ms ease;
    cursor: default;
  }

  .era-projects li:hover {
    color: var(--color-text-muted);
    border-color: rgba(255, 255, 255, 0.22);
  }

  /* ── CTA ─────────────────────────────────────────────────── */
  .about-cta {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding-block: 5rem;
  }

  .about-cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-heading {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .cta-sub {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .laszlo-inner { grid-template-columns: 1fr; gap: 3rem; }
    .laszlo-photo-col { flex-direction: row; align-items: flex-start; gap: 2rem; }
    .laszlo-stats { grid-template-columns: repeat(4, 1fr); min-width: unset; width: 100%; }
    .how-inner { grid-template-columns: 1fr; gap: 2rem; }
  }

  @media (max-width: 768px) {
    .laszlo-photo-col { flex-direction: column; align-items: flex-start; }
    .laszlo-photo-wrap { width: 180px; height: 180px; }
    .laszlo-stats { grid-template-columns: repeat(2, 1fr); }
    .timeline-era { grid-template-columns: 1fr; gap: 0.5rem; }
    .era-line { display: none; }
    .about-cta-inner { flex-direction: column; align-items: flex-start; }
    .about-cta { padding-block: 3.5rem; }
  }

  @media (max-width: 480px) {
    .laszlo-stats { grid-template-columns: 1fr 1fr; }
    .timeline-era { padding-block: 2rem; }
  }
</style>
