---
// src/pages/about/index.astro

import Page from '../../layouts/Page.astro';
import PageHero from '../../components/ui/PageHero.astro';
import timeline from '../../data/about-timeline.json';

const specialists = [
  { role: '3D Scanning Specialist',      desc: 'Detailed digital copies of buildings and objects using scanning equipment.' },
  { role: 'Architecture Photographer',   desc: 'High-quality site photography to match real-world detail in 3D work.' },
  { role: 'Character Animator',          desc: 'Natural-movement digital people that make spaces feel lived-in and active.' },
  { role: 'Character Artist',            desc: 'Digital people — from casual passersby to office workers.' },
  { role: 'Environment Artist',          desc: 'Rich digital worlds: parks, gardens, cityscapes.' },
  { role: 'UI/UX Designer',              desc: 'Interaction design for interactive projects and VR experiences.' },
  { role: 'Graphic Designer',            desc: '2D elements that complement 3D work: logos, layouts, infographics.' },
  { role: 'Interior Designer',           desc: 'Furniture, materials, and space feel for interior projects.' },
  { role: 'Web Developer',               desc: 'Websites and platforms where work is presented and embedded.' },
  { role: 'Photogrammetry Expert',       desc: 'Turns site photos into accurate 3D models — the digital twin approach.' },
  { role: '3D Generalist',               desc: 'All-around 3D modelling, texturing, and rendering across any brief.' },
  { role: 'Unreal Engine Developer',     desc: 'Real-time 3D experiences: walkthrough VR, interactive kiosks.' },
  { role: 'Drone Pilot',                 desc: 'Aerial photography and video showing how projects fit their surroundings.' },
  { role: 'BIM Specialist',              desc: 'Visual accuracy cross-checked against technical building data.' },
  { role: 'Crowd Simulator',             desc: 'Realistic crowd behaviour for large public spaces and transport hubs.' },
];
---

<Page
  title="About"
  description="Vision Graphics Kft. — Budapest-based architectural visualization studio founded 1996 by László Kerezsi. 30 years, 500+ projects across four continents."
  fullBleed
>
  <div class="about-page">

    <PageHero
      image="/_img/banners/banner-general.jpg"
      label="30 Years"
      title="Making Complex Ideas Visible"
    />

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- COMPANY OVERVIEW                                       -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="overview-section section">
      <div class="container overview-inner">

        <div class="overview-left">
          <p class="section-label">Vision Graphics</p>
          <h2 class="display-md overview-h2">About<br />the Studio</h2>
        </div>

        <div class="overview-right">
          <p class="overview-body">
            We've been bringing architectural ideas to life through 3D visualization
            for over 30 years. What started as a small Budapest studio has grown into
            a globally active practice — airport terminals, urban masterplans, VR
            experiences, and retail rollouts across four continents.
          </p>
          <div class="overview-diff">
            <p class="overview-diff-label">What makes us different</p>
            <p class="overview-body">
              We solve communication problems, not just render problems. Whether you need
              to win investor approval, succeed in a design competition, or show a
              neighbourhood what's coming — we build the visual argument that makes it happen.
            </p>
          </div>
        </div>

      </div>
    </section>

    <hr class="page-rule" />

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- LÁSZLÓ SECTION                                         -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="laszlo-section section">
      <div class="container laszlo-inner">

        <div class="laszlo-text">
          <p class="section-label">Founder</p>
          <h2 class="display-md">László Kerezsi</h2>
          <p class="laszlo-tagline">Visualization Director</p>

          <p class="laszlo-body">
            László started Vision Graphics in 1996. Before AI was a buzzword,
            he was writing custom MAXScript tools to solve production problems.
            Before VR was mainstream, he was building walkthrough experiences
            for real estate clients.
          </p>
          <p class="laszlo-body">
            He works directly on client projects — from initial brief through
            final delivery. No layers of project managers between you and the
            person making decisions about your visuals.
          </p>
          <p class="laszlo-body">
            Currently: integrating AI tools into production workflows,
            building custom desktop utilities for visualization pipelines,
            and preparing a presentation on AI-driven disruption in
            architectural visualization for the Ybl Conference 2026.
          </p>

          <div class="laszlo-contact">
            <a href="tel:+36309454179" class="contact-link">
              <span class="contact-link-label">Phone</span>
              <span>+36 30 945 4179</span>
            </a>
            <a href="mailto:info@visiongraphics.eu" class="contact-link">
              <span class="contact-link-label">Email</span>
              <span>info@visiongraphics.eu</span>
            </a>
          </div>
        </div>

        <div class="laszlo-photo-col">
          <div class="laszlo-photo-wrap">
            <img
              src="/laszlo.jpg"
              alt="László Kerezsi — Founder, Vision Graphics"
              class="laszlo-photo"
              width="240"
              height="240"
              loading="lazy"
            />
          </div>
          <div class="laszlo-stats">
          {[
            { n: '30+',  l: 'Years in 3ds Max' },
            { n: '15+',  l: 'Years with V-Ray' },
            { n: '500+', l: 'Projects delivered' },
            { n: '4',    l: 'Continents' },
          ].map(s => (
            <div class="stat-block">
              <span class="stat-block-n">{s.n}</span>
              <span class="stat-block-l">{s.l}</span>
            </div>
          ))}
          </div>
        </div>

      </div>
    </section>

    <hr class="page-rule" />

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- HOW WE WORK                                            -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="how-section section">
      <div class="container">

        <div class="how-inner">
          <div class="how-header">
            <p class="section-label">Structure</p>
            <h2 class="display-md">Small Team,<br />Big Results.</h2>
          </div>
          <div class="how-body">
            <p>
              Think of us as the conductors of an orchestra — we bring in the right
              experts at the right time to make your project work. We're a small
              core team that can tackle large-scale commissions through our network
              of tested specialists.
            </p>
            <p class="how-inhouse-label">We keep the most critical parts in-house:</p>
            <ul class="how-list">
              <li>Project management — one point of contact, start to finish</li>
              <li>Render farm operation and quality control before delivery</li>
              <li>Core 3D work requiring 30 years of judgement to get right</li>
              <li>Final output — formats your team can actually use</li>
            </ul>
            <a href="/contact/" class="btn btn-primary how-cta">Start a Conversation</a>
          </div>
        </div>

        <!-- Network of experts -->
        <div class="specialists-section">
          <div class="specialists-header">
            <p class="section-label">Our network of specialists</p>
            <p class="specialists-intro">
              When your project needs something special, we bring in the right expert.
              Every specialist below has been tested on real commissions.
            </p>
          </div>
          <div class="specialists-grid">
            {specialists.map(s => (
              <div class="specialist-card">
                <p class="specialist-role">{s.role}</p>
                <p class="specialist-desc">{s.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Why this works -->
        <div class="benefits-section">
          <p class="section-label">Why this works so well</p>
          <div class="benefits-grid">
            {[
              { t: 'Move quickly',       b: 'Small core means fast decisions. No committee approvals for scope changes.' },
              { t: 'Right talent',        b: 'Cutting-edge specialists brought in exactly when needed — not carried as overhead.' },
              { t: 'Quality stays high',  b: 'László reviews everything before it leaves the studio. No exceptions.' },
              { t: 'Precise scope',       b: 'You get exactly what your project needs. Not a one-size-fits-all solution.' },
            ].map(b => (
              <div class="benefit-item">
                <h3 class="benefit-title">{b.t}</h3>
                <p class="benefit-body">{b.b}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <hr class="page-rule" />

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- TIMELINE                                               -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="timeline-section section">
      <div class="container">
        <p class="section-label">History</p>
        <h2 class="display-md timeline-heading">History &amp; Milestones</h2>
      </div>
      <div class="timeline container">
        {timeline.map((era) => (
          <div class="timeline-era">
            <div class="era-left">
              <span class="era-years">{era.years}</span>
              <div class="era-line" aria-hidden="true"></div>
            </div>
            <div class="era-right">
              <h3 class="era-title">{era.title}</h3>
              <p class="era-summary">{era.summary}</p>
              <ul class="era-projects">
                {era.projects.map(p => (
                  <li>{p}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- CTA                                                    -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="about-cta">
      <div class="container about-cta-inner">
        <div>
          <h2 class="cta-heading">Ready to Work Together?</h2>
          <p class="cta-sub">30-minute consultation. No charge. No obligation.</p>
        </div>
        <a href="/contact/" class="btn btn-primary">Get in Touch</a>
      </div>
    </section>

  </div>
</Page>

<style>
  .about-page { width: 100%; }

  .page-rule {
    border-color: var(--color-border);
    margin-inline: auto;
    max-width: 1320px;
  }

  /* ── Company overview section ────────────────────────────── */
  .overview-inner {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  .overview-left { padding-top: 0.25rem; }

  .overview-h2 { margin: 0.75rem 0 0; }

  .overview-body {
    font-size: 0.97rem;
    color: var(--color-text-muted);
    max-width: 62ch;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .overview-diff {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .overview-diff-label {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  /* ── László founder section ──────────────────────────────── */
  .laszlo-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  .laszlo-photo-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .laszlo-photo-wrap {
    width: 240px;
    height: 240px;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid var(--color-border);
    flex-shrink: 0;
    aspect-ratio: 1;
  }

  .laszlo-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: filter 400ms ease;
  }

  .laszlo-photo-wrap:hover .laszlo-photo { filter: brightness(1.05); }

  .laszlo-tagline {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0.4rem 0 1.75rem;
  }

  .laszlo-body {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    max-width: 58ch;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .laszlo-body:last-of-type { margin-bottom: 2rem; }

  .laszlo-contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.88rem;
    color: var(--color-text-muted);
    text-decoration: none;
    cursor: pointer;
    transition: color 200ms ease;
    padding: 0.35rem 0;
  }

  .contact-link:hover { color: var(--color-text); }

  .contact-link-label {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    min-width: 3.5rem;
  }

  /* ── Stat blocks — 2×2 grid ──────────────────────────────── */
  .laszlo-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    align-self: start;
    min-width: 260px;
  }

  .stat-block {
    background: var(--color-surface);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .stat-block-n {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .stat-block-l {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    line-height: 1.4;
  }

  /* ── How We Work section ─────────────────────────────────── */
  .how-inner {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
    margin-bottom: 4rem;
  }

  .how-header h2 { margin: 0.75rem 0 0; }

  .how-body {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .how-body p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    max-width: 58ch;
    line-height: 1.8;
  }

  .how-inhouse-label {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin-bottom: 0 !important;
  }

  .how-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .how-list li {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    padding-left: 1.2rem;
    position: relative;
    line-height: 1.55;
  }

  .how-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.7rem;
    top: 0.12em;
  }

  .how-cta { align-self: flex-start; }

  /* ── Specialist network grid ─────────────────────────────── */
  .specialists-section {
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
    margin-bottom: 3.5rem;
  }

  .specialists-header {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: clamp(3rem, 6vw, 7rem);
    margin-bottom: 2.5rem;
    align-items: start;
  }

  .specialists-intro {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 56ch;
    margin: 0;
    padding-top: 0.1rem;
  }

  .specialists-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .specialist-card {
    background: var(--color-surface);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    transition: background 200ms ease;
  }

  .specialist-card:hover { background: var(--color-surface-2); }

  .specialist-role {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .specialist-desc {
    font-size: 0.75rem;
    color: var(--color-text-faint);
    line-height: 1.55;
    margin: 0;
    max-width: none;
  }

  /* ── Benefits grid ───────────────────────────────────────── */
  .benefits-section {
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
    margin-top: 1.75rem;
  }

  .benefit-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .benefit-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  .benefit-body {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
    max-width: none;
  }

  /* ── Timeline ────────────────────────────────────────────── */
  .timeline-heading { margin: 0.75rem 0 2.5rem; }

  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline-era {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 3rem;
    padding-block: 2.75rem;
    border-top: 1px solid var(--color-border);
  }

  .timeline-era:last-child { border-bottom: 1px solid var(--color-border); }

  .era-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding-top: 0.25rem;
  }

  .era-years {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .era-line {
    width: 1px;
    flex: 1;
    min-height: 2rem;
    background: linear-gradient(to bottom, var(--color-border), transparent);
    margin-left: 0.3rem;
  }

  .era-right {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .era-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .era-summary {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    max-width: 65ch;
    margin-top: 0.1rem;
  }

  .era-projects {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.5rem;
    margin-top: 0.5rem;
  }

  .era-projects li {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 400;
    color: var(--color-text-faint);
    letter-spacing: 0.04em;
    padding: 0.18rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 1px;
    transition: color 200ms ease, border-color 200ms ease;
    cursor: default;
  }

  .era-projects li:hover {
    color: var(--color-text-muted);
    border-color: rgba(255, 255, 255, 0.22);
  }

  /* ── CTA ─────────────────────────────────────────────────── */
  .about-cta {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding-block: 5rem;
  }

  .about-cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-heading {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .cta-sub {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 1200px) {
    .specialists-grid { grid-template-columns: repeat(3, 1fr); }
    .benefits-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 1100px) {
    .overview-inner { grid-template-columns: 1fr; gap: 2rem; }
    .laszlo-inner { grid-template-columns: 1fr; gap: 3rem; }
    .laszlo-photo-col { flex-direction: row; align-items: flex-start; gap: 2rem; }
    .laszlo-stats { grid-template-columns: repeat(4, 1fr); min-width: unset; width: 100%; }
    .how-inner { grid-template-columns: 1fr; gap: 2rem; }
    .specialists-header { grid-template-columns: 1fr; gap: 1rem; }
  }

  @media (max-width: 768px) {
    .laszlo-photo-col { flex-direction: column; align-items: flex-start; }
    .laszlo-photo-wrap { width: 180px; height: 180px; }
    .laszlo-stats { grid-template-columns: repeat(2, 1fr); }
    .specialists-grid { grid-template-columns: repeat(2, 1fr); }
    .benefits-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .timeline-era { grid-template-columns: 1fr; gap: 0.5rem; }
    .era-line { display: none; }
    .about-cta-inner { flex-direction: column; align-items: flex-start; }
    .about-cta { padding-block: 3.5rem; }
  }

  @media (max-width: 480px) {
    .laszlo-stats { grid-template-columns: 1fr 1fr; }
    .specialists-grid { grid-template-columns: 1fr; }
    .timeline-era { padding-block: 2rem; }
  }
</style>
