---
// src/pages/portfolio/[slug].astro

import Page from '../../../layouts/Page.astro';
import FilmEmbed from '../../../components/media/FilmEmbed.astro';
import Tour360 from '../../../components/media/Tour360.astro';
import YouTubeEmbed from '../../../components/media/YouTubeEmbed.astro';
import ImageLightbox from '../../../components/media/ImageLightbox';
import ImageGallery from '../../../components/mdx/ImageGallery.astro';
import ImageCompare from '../../../components/mdx/ImageCompare.astro';
import MdxSectionBanner from '../../../components/mdx/SectionBanner.astro';
import ProjectDescription from '../../../components/mdx/ProjectDescription.astro';
import ProjectStory from '../../../components/mdx/ProjectStory.astro';
import ProjectTasks from '../../../components/mdx/ProjectTasks.astro';
import ArticleGalleryMounter from '../../../components/media/ArticleGalleryMounter.tsx';
import ArticleImageCompareMounter from '../../../components/media/ArticleImageCompareMounter.tsx';
import ProcessFlow from '../../../components/mdx/ProcessFlow.astro';
import SpecTable from '../../../components/mdx/SpecTable.astro';
import CompareTable from '../../../components/mdx/CompareTable.astro';
import NotableGrid from '../../../components/mdx/NotableGrid.astro';
import DeliverableGrid from '../../../components/mdx/DeliverableGrid.astro';
import TimelineTable from '../../../components/mdx/TimelineTable.astro';
import PhaseMatrix from '../../../components/mdx/PhaseMatrix.astro';
import SingleImage from '../../../components/mdx/SingleImage.astro';
import Lang from '../../../components/i18n/Lang.astro';
import { getCollection, getEntry } from 'astro:content';
import { localizedPaths, localeUrl, t, tStr, type Locale } from '../../../lib/i18n';
import { ui } from '../../../i18n/strings';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => data.published);
  return localizedPaths(projects, project => ({ slug: project.slug }));
}

const { lang, slug } = Astro.params as { lang: Locale; [k: string]: string | undefined };
Astro.locals.lang = lang;
const L = ui(lang);
const allProjects = await getCollection('projects', ({ data }) => data.published);
const project = allProjects.find(p => p.slug === slug);
if (!project) return Astro.redirect(localeUrl('/portfolio/', lang));
const { data } = project;
const { Content } = await project.render();

// Resolve translated text fields. data.title / data.description may be a plain
// string (single-language file) or { en, hu, ... } (translated file). t() handles both.
const titleStr       = tStr(data.title, lang);
const displayTitle   = tStr(data.displayTitle, lang) || titleStr;
const descriptionStr = tStr(data.description, lang);

// Resolve category references — title is also localized
const resolvedCategories = await Promise.all(
  data.categories.map(async ref => {
    const entry = await getEntry('categories', ref.id);
    return { id: ref.id, title: tStr(entry?.data.title, lang) || ref.id };
  })
);

// Resolve optional client/designer/location references to display strings
const clientTitle   = data.client   ? tStr((await getEntry('clients',   data.client.id))?.data.title,   lang) || undefined : undefined;
const designerTitle = data.designer ? tStr((await getEntry('designers', data.designer.id))?.data.title, lang) || undefined : undefined;
const cityTitle     = data.city     ? tStr((await getEntry('cities',    data.city.id))?.data.title,     lang) || undefined : undefined;
const countryTitle  = data.country  ? tStr((await getEntry('countries', data.country.id))?.data.title,  lang) || undefined : undefined;
const locationStr   = [cityTitle, countryTitle].filter(Boolean).join(', ') || undefined;

// Adjacent projects for prev/next navigation
const sorted = allProjects.sort((a, b) => b.data.year - a.data.year);
const currentIndex = sorted.findIndex(p => p.slug === project.slug);
const prevProject = sorted[currentIndex + 1] ?? null;
const nextProject = sorted[currentIndex - 1] ?? null;

// Format a technique slug for display: "360-tour" → "360 TOUR"
function formatTech(slug: string): string {
  return slug.replace(/-/g, '\u00A0').toUpperCase();
}

// Resolve service slugs to titles for display
const allServices = data.services && data.services.length > 0
  ? await getCollection('services', s => s.data.published)
  : [];
const relatedServices = allServices.filter(s => (data.services ?? []).includes(s.slug));
---

<Page
  title={titleStr}
  description={descriptionStr || `${titleStr} — architectural visualization by Vision Graphics Kft.`}
  image={data.coverImage}
  fullBleed
>
  <!-- Hero image -->
  <div class="project-hero">
    <img
      src={data.coverImage}
      alt={titleStr}
      class="project-hero-img"
      loading="eager"
    />
    <div class="project-hero-overlay">
      <div class="container">
        <div class="project-hero-meta">
          <a href={localeUrl('/portfolio/', lang)} class="back-link">{L.cta.backToPortfolio}</a>
          <div class="project-cats">
            {resolvedCategories.map(cat => (
              <a href={localeUrl(`/portfolio/category/${cat.id}/`, lang)} class="project-cat-tag">
                {cat.title}
              </a>
            ))}
          </div>
        </div>
        <h1 class="project-title">{displayTitle}</h1>
        <div class="project-subtitle-row">
          <span class="project-year">{data.year}</span>
          {clientTitle  && <span class="project-client">{clientTitle}</span>}
          {locationStr  && <span class="project-location">{locationStr}</span>}
        </div>
      </div>
    </div>
  </div>

  <!-- Single-column content area -->
  <div class="project-content-area container">

    <!-- "The Project:" section -->
    <div class="project-intro">
      <h2 class="project-red-heading">{L.project.theProject}</h2>
      {descriptionStr && (
        <p class="project-description">{descriptionStr}</p>
      )}
      <div class="project-data-line">
        {resolvedCategories.length > 0 && (
          <span class="data-item">
            <span class="data-label">{L.project.field}</span>
            <span class="data-value">{resolvedCategories.map(c => c.title).join(' | ')}</span>
          </span>
        )}
        <span class="data-item">
          <span class="data-label">{L.project.date}</span>
          <span class="data-value">{data.year}</span>
        </span>
        {locationStr && (
          <span class="data-item">
            <span class="data-label">{L.project.location}</span>
            <span class="data-value">{locationStr}</span>
          </span>
        )}
        {clientTitle && (
          <span class="data-item">
            <span class="data-label">{L.project.client}</span>
            <span class="data-value">{clientTitle}</span>
          </span>
        )}
        {designerTitle && (
          <span class="data-item">
            <span class="data-label">{L.project.architectDesigner}</span>
            <span class="data-value">{designerTitle}</span>
          </span>
        )}
      </div>
    </div>

    <!-- "The Task:" section header + techniques + services -->
    <div class="project-task-header">
      <h2 class="project-red-heading">{L.project.theTask}</h2>
      {data.techniques && data.techniques.length > 0 && (
        <div class="techniques-bar">
          {data.techniques.map((tech: string, i: number) => (
            <>
              {i > 0 && <span class="tech-sep"> | </span>}
              <a href={localeUrl(`/vision-tech/${tech}/`, lang)} class="tech-item">{formatTech(tech)}</a>
            </>
          ))}
        </div>
      )}
      {relatedServices.length > 0 && (
        <div class="services-bar">
          <span class="services-bar-label">{L.project.services}</span>
          {relatedServices.map((svc, i) => (
            <>
              {i > 0 && <span class="tech-sep"> · </span>}
              <a href={localeUrl(`/services/${svc.slug}/`, lang)} class="service-item">{tStr(svc.data.title, lang)}</a>
            </>
          ))}
        </div>
      )}
    </div>

    <!-- MDX body: ProjectTasks text → media → ProjectStory -->
    <div class="project-content">
      <Content components={{ ImageGallery, ImageCompare, SingleImage, Tour360, FilmEmbed, YouTubeEmbed, YoutubeEmbed: YouTubeEmbed, SectionBanner: MdxSectionBanner, ProjectDescription, ProjectStory, ProjectTasks, ProcessFlow, SpecTable, CompareTable, NotableGrid, DeliverableGrid, TimelineTable, PhaseMatrix, Lang }} />
      <ArticleGalleryMounter client:load />
      <ArticleImageCompareMounter client:load />
    </div>

    <!-- CTA block -->
    <div class="project-cta">
      <p>{L.cta.similarProject}</p>
      <a href={localeUrl('/contact/', lang)} class="btn btn-primary">{L.cta.talkToUs}</a>
    </div>

    <!-- Project navigation -->
    <nav class="project-nav" aria-label="Project navigation">
      {prevProject && (
        <a href={localeUrl(`/portfolio/${prevProject.slug}/`, lang)} class="project-nav-link project-nav-link--prev">
          <span class="nav-dir">{L.cta.previous}</span>
          <span class="nav-title">{tStr(prevProject.data.title, lang)}</span>
        </a>
      )}
      <a href={localeUrl('/portfolio/', lang)} class="project-nav-link project-nav-link--all">{L.cta.allProjects}</a>
      {nextProject && (
        <a href={localeUrl(`/portfolio/${nextProject.slug}/`, lang)} class="project-nav-link project-nav-link--next">
          <span class="nav-dir">{L.cta.next}</span>
          <span class="nav-title">{tStr(nextProject.data.title, lang)}</span>
        </a>
      )}
    </nav>

  </div>
</Page>

<style>
  /* =====================
     Hero
     ===================== */
  .project-hero {
    position: relative;
    height: 70vh;
    min-height: 400px;
    overflow: hidden;
  }

  .project-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.92) 0%,
      rgba(0,0,0,0.80) 20%,
      rgba(0,0,0,0.30) 45%,
      transparent      65%
    );
    padding-bottom: 3rem;
  }
  :global([data-theme="light"]) .project-hero-overlay {
    background: linear-gradient(
      to top,
      rgba(247,245,242,0.95) 0%,
      rgba(247,245,242,0.82) 20%,
      rgba(247,245,242,0.35) 45%,
      transparent            65%
    );
  }

  .project-hero-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .back-link {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 200ms ease;
    letter-spacing: 0.05em;
  }
  .back-link:hover { color: var(--color-text); }

  .project-cats { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .project-cat-tag {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    border: 1px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
    padding: 0.2rem 0.5rem;
    border-radius: 1px;
    transition: all 200ms ease;
  }
  .project-cat-tag:hover {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    border-color: var(--color-accent);
  }

  .project-title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 0.75rem;
  }

  .project-subtitle-row {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
  }

  /* =====================
     Content area
     ===================== */
  .project-content-area {
    padding-block-end: var(--space-16);
  }

  /* =====================
     Red section headings
     ===================== */
  .project-red-heading {
    font-family: var(--font-display);
    font-size: var(--fs-h4);
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  /* =====================
     "The Project:" section
     ===================== */
  .project-intro {
    padding-top: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .project-description {
    font-size: var(--fs-body);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
    max-width: 68ch;
  }

  .project-data-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 2rem;
  }

  .data-item {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    display: flex;
    gap: 0.4em;
    align-items: baseline;
  }

  .data-label {
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-size: var(--fs-xs);
    white-space: nowrap;
  }

  .data-value {
    color: var(--color-text);
  }

  /* =====================
     "The Task:" section header
     ===================== */
  .project-task-header {
    margin-bottom: 1.5rem;
  }

  .techniques-bar {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .tech-item {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 150ms;
  }
  .tech-item:hover { color: var(--color-accent); }

  .tech-sep {
    color: var(--color-text-faint);
  }

  .services-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3em;
    margin-top: var(--space-3);
    font-size: var(--fs-xs);
  }
  .services-bar-label {
    color: var(--color-text-faint);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-right: 0.2em;
  }
  .service-item {
    color: var(--color-text-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: color 150ms ease;
  }
  .service-item:hover { color: var(--color-accent); }

  /* =====================
     MDX body content
     ===================== */
  .project-content {
    margin-bottom: 2rem;
  }

  /* SectionBanner inside MDX body: full viewport width */
  .project-content :global(.article-section-banner) {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin-inline: 0;
  }

  /* =====================
     CTA block
     ===================== */
  .project-cta {
    margin-block: 3rem;
    padding: 2rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    text-align: center;
  }

  .project-cta p {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    max-width: none;
  }

  /* =====================
     Project navigation
     ===================== */
  .project-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    gap: 1rem;
  }

  .project-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    transition: color 200ms;
    max-width: 35%;
  }

  .nav-dir {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    letter-spacing: 0.1em;
  }

  .nav-title {
    font-family: var(--font-display);
    font-size: var(--fs-body);
    color: var(--color-text-muted);
    transition: color 200ms;
  }

  .project-nav-link:hover .nav-title { color: var(--color-accent); }

  .project-nav-link--all {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    flex-direction: row;
    align-items: center;
    max-width: none;
  }
  .project-nav-link--all:hover { color: var(--color-text); }

  .project-nav-link--next {
    text-align: right;
    align-items: flex-end;
  }
</style>
