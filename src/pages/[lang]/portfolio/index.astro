---
// src/pages/portfolio/index.astro

import Page from '../../../layouts/Page.astro';
import PortfolioFilter from '../../../components/portfolio/PortfolioFilter';
import { getCollection, getEntry } from 'astro:content';
import type { ProjectMeta } from '../../../components/portfolio/PortfolioFilter';
import { staticLocalePaths, tStr, type Locale } from '../../../lib/i18n';
import { ui } from '../../../i18n/strings';

export const getStaticPaths = staticLocalePaths;


const { lang } = Astro.params as { lang: Locale };
Astro.locals.lang = lang;
const L = ui(lang);
const allProjects = await getCollection('projects', ({ data }) => data.published);
const allCategories = await getCollection('categories');
const catMap = new Map(allCategories.map(c => [c.id, tStr(c.data.title, lang)]));

// Resolve a reference field to its display title (locale-aware)
async function resolveTitle(ref: { id: string; collection: string } | undefined): Promise<string | undefined> {
  if (!ref) return undefined;
  const entry = await getEntry(ref.collection as any, ref.id);
  const v = tStr(entry?.data.title, lang);
  return v || undefined;
}

// Serialize to plain strings for the React island — Localized<T> objects
// must be flattened before crossing the server/client boundary, otherwise
// React tries to render `{en, hu}` as a child and throws.
const projectData: ProjectMeta[] = await Promise.all(allProjects.map(async p => {
  const cityTitle    = await resolveTitle(p.data.city);
  const countryTitle = await resolveTitle(p.data.country);
  return {
    slug:        p.slug,
    title:       tStr(p.data.title, lang),
    year:        p.data.year,
    client:      await resolveTitle(p.data.client),
    designer:    await resolveTitle(p.data.designer),
    city:        cityTitle,
    country:     countryTitle,
    description: tStr(p.data.description, lang) || undefined,
    categories:  p.data.categories.map(ref => ({ id: ref.id, title: catMap.get(ref.id) ?? ref.id })),
    features:    p.data.features,
    tags:        p.data.tags,
    coverImage:  p.data.coverImage,
    featured:    p.data.featured,
    has360:      p.data.has360 ?? false,
    hasFilm:     p.data.hasFilm ?? false,
  };
}));

const years = projectData.map(p => p.year);
const minYear = Math.min(...years);
const maxYear = Math.max(...years);
---

<Page
  title={L.nav.portfolio}
  description={lang === 'hu'
    ? '30 év építészeti látványtervezés. 500+ projekt repterek, lakó-, kereskedelmi, városi és VR területeken. Budapesti székhely, globális működés.'
    : '30 years of architectural visualization. 500+ projects across airports, residential, commercial, urban, and VR. Budapest-based, working globally.'}
  fullBleed
>

  <div class="portfolio-page">
    <div class="portfolio-header container">
      <p class="section-label">{lang === 'hu' ? 'Munkáink' : 'Our Work'}</p>
      <h2 class="display-lg">{lang === 'hu' ? 'Válogatott projektek' : 'Selected Projects'}</h2>
      <p class="portfolio-sub">
        {lang === 'hu'
          ? '30 év. 500+ projekt. Válogatás szektorok és léptékek szerint.'
          : '30 years. 500+ projects. A selection across sectors and scales.'}
      </p>
    </div>

    <div class="portfolio-body container">
      <PortfolioFilter
        projects={projectData}
        minYear={minYear}
        maxYear={maxYear}
        client:load
      />
    </div>
  </div>
</Page>

<style>
  .portfolio-page {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .portfolio-header {
    margin-bottom: var(--space-12);
  }

  .portfolio-header h1 {
    margin: var(--space-3) 0 var(--space-4);
  }

  .portfolio-sub {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    margin: 0;
    max-width: 52ch;
  }

  .portfolio-body {
    /* Full width grid with container padding */
  }
</style>
