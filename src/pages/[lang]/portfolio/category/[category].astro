---
// src/pages/portfolio/category/[category].astro
// Pre-built category pages for SEO

import Page from '../../../../layouts/Page.astro';
import SectionBanner from '../../../../components/ui/SectionBanner.astro';
import { getCollection, getEntry } from 'astro:content';
import { thumbUrl } from '../../../../lib/image-url';
import { localizedPaths, type Locale } from '../../../../lib/i18n';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects', ({ data }) => data.published);
  const categoryIds = [...new Set(allProjects.flatMap(p => p.data.categories.map(c => c.id)))];
  return localizedPaths(categoryIds, categoryId => ({ category: categoryId }));
}

const { lang, category } = Astro.params as { lang: Locale; [k: string]: string | undefined };
Astro.locals.lang = lang;
const allProjects = await getCollection('projects', ({ data }) => data.published);
const allCategories = await getCollection('categories');
const catMap = new Map(allCategories.map(c => [c.id, c.data.title]));
const label = catMap.get(category) ?? category;
const projects = allProjects
  .filter(p => p.data.categories.some(c => c.id === category))
  .sort((a, b) => b.data.year - a.data.year);
if (!projects.length) return Astro.redirect('/portfolio/');

// Resolve client names and locations for all projects
const projectMeta = await Promise.all(
  projects.map(async p => {
    const client  = p.data.client  ? (await getEntry('clients',   p.data.client.id))?.data.title  : undefined;
    const city    = p.data.city    ? (await getEntry('cities',    p.data.city.id))?.data.title    : undefined;
    const country = p.data.country ? (await getEntry('countries', p.data.country.id))?.data.title : undefined;
    const location = [city, country].filter(Boolean).join(', ') || undefined;
    return { client, location };
  })
);
---

<Page
  title={`${label} — Portfolio`}
  description={`${label} projects by Vision Graphics Kft. ${projects.length} projects. Budapest-based, working globally since 1996.`}
  fullBleed
>
  <SectionBanner
    image="/_img/banners/banner-arch-viz.jpg"
    label="Portfolio"
    title={label}
    size="page"
    headingLevel="h1"
  />
  <div class="category-page">

    <div class="category-header container">
      <div class="category-breadcrumb">
        <a href="/portfolio/">Portfolio</a>
        <span>→</span>
        <span>{label}</span>
      </div>
      <p class="section-label">Portfolio</p>
      <h2 class="display-lg category-h1">{label}</h2>
      <p class="category-sub">
        {projects.length} project{projects.length !== 1 ? 's' : ''} in this category.
        <a href="/portfolio/">Browse all →</a>
      </p>
    </div>

    <div class="category-grid container">
      {projects.map((project, i) => (
        <a href={`/portfolio/${project.slug}/`} class="cat-card">
          <div class="cat-card-image">
            <img
              src={thumbUrl(project.data.coverImage)}
              alt={project.data.title}
              loading={i < 4 ? 'eager' : 'lazy'}
              decoding="async"
              onerror={`this.onerror=null;this.src='${project.data.coverImage}'`}
            />
          </div>
          <div class="cat-card-body">
            <div class="cat-card-meta">
              <span class="cat-card-cat">{label}</span>
              <span class="cat-card-year">{project.data.year}</span>
            </div>
            <h2 class="cat-card-title">{project.data.title}</h2>
            {(projectMeta[i].client || projectMeta[i].location) && (
              <span class="cat-card-sub">{projectMeta[i].client || projectMeta[i].location}</span>
            )}
          </div>
        </a>
      ))}
    </div>

    <div class="category-cta container">
      <a href="/portfolio/" class="btn btn-secondary">← All Projects</a>
      <a href="/contact/" class="btn btn-primary">Start a Project</a>
    </div>

  </div>
</Page>

<style>
  .category-page { padding-block: clamp(3rem, 6vw, 5rem); }

  .category-header { margin-bottom: 3rem; }

  .category-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    margin-bottom: 1.5rem;
  }

  .category-breadcrumb a { color: var(--color-text-muted); text-decoration: none; transition: color 200ms; }
  .category-breadcrumb a:hover { color: var(--color-accent); }

  .category-h1 { margin: 0.5rem 0 1rem; }

  .category-sub {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    margin: 0;
  }

  .category-sub a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-left: 0.5rem;
  }

  /* Grid — matches vt-grid */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  /* Portfolio card — white border */
  .cat-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-sm);
    overflow: hidden;
    text-decoration: none;
    transition: border-color 250ms ease, transform 250ms ease;
  }

  .cat-card:hover { border-color: rgba(255, 255, 255, 0.35); transform: translateY(-2px); }

  .cat-card-image {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--color-surface-2);
  }

  .cat-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }

  .cat-card:hover .cat-card-image img { transform: scale(1.04); }

  .cat-card-body {
    padding: 1rem 1.1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    flex: 1;
  }

  .cat-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cat-card-cat {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .cat-card-year {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
  }

  .cat-card-title {
    font-family: var(--font-display);
    font-size: var(--fs-body);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
    margin: 0;
  }

  .cat-card-sub {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
  }

  /* CTA */
  .category-cta {
    display: flex;
    gap: 0.75rem;
  }
</style>
