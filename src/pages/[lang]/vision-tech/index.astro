---
// src/pages/vision-tech/index.astro
import { getCollection } from 'astro:content';
import Page from '../../../layouts/Page.astro';
import SectionBanner from '../../../components/ui/SectionBanner.astro';
import { thumbUrl } from '../../../lib/image-url';
import { staticLocalePaths, localeUrl, tStr, type Locale } from '../../../lib/i18n';

export const getStaticPaths = staticLocalePaths;


const { lang } = Astro.params as { lang: Locale };
Astro.locals.lang = lang;
const allTech = await getCollection('vision-tech', e => e.data.published !== false);
const techniques = allTech.sort((a, b) => tStr(a.data.title, lang).localeCompare(tStr(b.data.title, lang)));

const techniques_vals = [...new Set(techniques.map(t => t.data.technique).filter(Boolean))].sort();
const costs_vals      = ['€','€€','€€€','€€€€','€€€€€'];
const model3d_vals    = [...new Set(techniques.map(t => t.data.model3d))].sort();
const complexity_vals = ['1 - Basic','2 - Intermediate','3 - Advanced','4 - Expert','5 - Cutting-Edge'];
const reality_vals    = ['Pure Reality','Enhanced Reality','Hybrid Reality-Vision','Conceptual Reality','Pure Vision'];
const purpose_vals    = [...new Set(techniques.flatMap(t => t.data.purpose))].sort();

const COPY = {
  en: {
    metaTitle:        'Technologies | Vision Graphics',
    metaDescription:  '26 visualization techniques — photorealistic rendering, VR, 360° tours, AI workflows and more.',
    bannerLabel:      'See Your Ideas',
    bannerTitle:      'Tech Gets It Done',
    filtersBtn:       'Filters',
    showingAll:       (n: number) => `Showing all ${n} techniques`,
    showingSome:      (v: number, n: number) => `Showing ${v} of ${n} techniques`,
    reset:            'Reset filters',
    fTechnique:       'Technique',
    fCost:            'Cost',
    fModel3d:         '3D Model',
    fComplexity:      'Complexity',
    fReality:         'Reality spectrum',
    fPurpose:         'Purpose',
    emptyMsg:         'No techniques match those filters.',
    toolsLabel:       'Tools We Use',
    toolsHeading:     'Our Tech Stack',
    ctaText:          'Not sure which approach fits your project?',
    talkToUs:         'Talk to Us',
    toolNotes: {
      v1:           'Since version 1',
      years15:      '15+ years',
      vrRealtime:   'VR & real-time',
      secondaryMod: 'Secondary modelling',
      tours360:     '360° tours',
      aiWorkflows:  'AI workflows',
      automation:   'Automation',
      customTools:  'Custom tools',
      videoPost:    'Video post',
      hostingCDN:   'Hosting & CDN',
      thisSite:     'This site',
    },
  },
  hu: {
    metaTitle:        'Technológiák | Vision Graphics',
    metaDescription:  '26 látványterv-technika — fotórealisztikus renderelés, VR, 360°-os túrák, AI-munkafolyamatok és még sok más.',
    bannerLabel:      'Tegye láthatóvá az ötleteit',
    bannerTitle:      'A technológia elvégzi',
    filtersBtn:       'Szűrők',
    showingAll:       (n: number) => `Mind a ${n} technika látható`,
    showingSome:      (v: number, n: number) => `${v} / ${n} technika látható`,
    reset:            'Szűrők törlése',
    fTechnique:       'Technika',
    fCost:            'Költség',
    fModel3d:         '3D-modell',
    fComplexity:      'Összetettség',
    fReality:         'Valóság-spektrum',
    fPurpose:         'Cél',
    emptyMsg:         'Nincs olyan technika, amely ezeknek a szűrőknek megfelel.',
    toolsLabel:       'Eszközeink',
    toolsHeading:     'A technológiai paletta',
    ctaText:          'Nem biztos benne, melyik megközelítés illik a projektjéhez?',
    talkToUs:         'Beszéljünk',
    toolNotes: {
      v1:           'Az 1-es verzió óta',
      years15:      '15+ év',
      vrRealtime:   'VR és valós idejű',
      secondaryMod: 'Másodlagos modellezés',
      tours360:     '360°-os túrák',
      aiWorkflows:  'AI-munkafolyamatok',
      automation:   'Automatizálás',
      customTools:  'Egyedi eszközök',
      videoPost:    'Videó-utómunka',
      hostingCDN:   'Hosting és CDN',
      thisSite:     'Ez az oldal',
    },
  },
} as const;
const c = COPY[lang];

const tools = [
  { name: '3ds Max',         note: c.toolNotes.v1 },
  { name: 'V-Ray',           note: c.toolNotes.years15 },
  { name: 'Unreal Engine',   note: c.toolNotes.vrRealtime },
  { name: 'Blender',         note: c.toolNotes.secondaryMod },
  { name: 'Pano2VR',         note: c.toolNotes.tours360 },
  { name: 'ComfyUI',         note: c.toolNotes.aiWorkflows },
  { name: 'SwarmUI',         note: c.toolNotes.aiWorkflows },
  { name: 'Python',          note: c.toolNotes.automation },
  { name: 'MAXScript',       note: c.toolNotes.customTools },
  { name: 'DaVinci Resolve', note: c.toolNotes.videoPost },
  { name: 'Cloudflare',      note: c.toolNotes.hostingCDN },
  { name: 'Astro',           note: c.toolNotes.thisSite },
];
---

<Page
  title={c.metaTitle}
  description={c.metaDescription}
  fullBleed
>

  <SectionBanner
    image="/_img/banners/banner-tech.jpg"
    label={c.bannerLabel}
    title={c.bannerTitle}
    size="page"
    headingLevel="h1"
  />

  <section class="vt-filter-section">
    <div class="container">
      <div class="vt-filters-bar">
        <button id="vt-filter-toggle" class="vt-filter-toggle" aria-expanded="false">
          {c.filtersBtn}
          <span id="vt-filter-dot" class="vt-filter-dot" hidden></span>
          <svg class="vt-toggle-chevron" viewBox="0 0 12 8" fill="none" aria-hidden="true">
            <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <span id="vt-count" class="vt-count-inline" data-tmpl-all={c.showingAll(techniques.length)} data-tmpl-some={lang === 'hu' ? '__V__ / __N__ technika látható' : 'Showing __V__ of __N__ techniques'}>{c.showingAll(techniques.length)}</span>
        <button class="vt-reset" id="vt-reset" hidden>{c.reset}</button>
      </div>

      <div class="vt-filters" id="vt-filters-body" hidden>

        <div class="vt-filter-group">
          <span class="vt-filter-label">{c.fTechnique}</span>
          <div class="vt-pills" data-filter="technique">
            {techniques_vals.map(v => <button class="vt-pill" data-val={v}>{v}</button>)}
          </div>
        </div>

        <div class="vt-filter-group">
          <span class="vt-filter-label">{c.fCost}</span>
          <div class="vt-pills" data-filter="cost">
            {costs_vals.map(v => <button class="vt-pill" data-val={v}>{v}</button>)}
          </div>
        </div>

        <div class="vt-filter-group">
          <span class="vt-filter-label">{c.fModel3d}</span>
          <div class="vt-pills" data-filter="model3d">
            {model3d_vals.map(v => <button class="vt-pill" data-val={v}>{v}</button>)}
          </div>
        </div>

        <div class="vt-filter-group">
          <span class="vt-filter-label">{c.fComplexity}</span>
          <div class="vt-pills" data-filter="complexity">
            {complexity_vals.map(v => <button class="vt-pill" data-val={v}>{v}</button>)}
          </div>
        </div>

        <div class="vt-filter-group">
          <span class="vt-filter-label">{c.fReality}</span>
          <div class="vt-pills" data-filter="reality">
            {reality_vals.map(v => <button class="vt-pill" data-val={v}>{v}</button>)}
          </div>
        </div>

        <div class="vt-filter-group">
          <span class="vt-filter-label">{c.fPurpose}</span>
          <div class="vt-pills" data-filter="purpose">
            {purpose_vals.map(v => <button class="vt-pill" data-val={v}>{v}</button>)}
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="section vt-grid-section">
    <div class="container">
      <div class="vt-grid" id="vt-grid">
        {techniques.map(t => {
          const titleStr = tStr(t.data.title, lang);
          const descStr  = tStr(t.data.description, lang);
          return (
            <a
              href={localeUrl(`/vision-tech/${t.slug}/`, lang)}
              class="vt-card"
              data-technique={t.data.technique}
              data-cost={t.data.cost}
              data-model3d={t.data.model3d}
              data-complexity={t.data.complexity}
              data-reality={t.data.reality}
              data-purpose={t.data.purpose.join('|')}
            >
              <div class="vt-card-img">
                <img src={thumbUrl(t.data.image)} alt={titleStr} loading="lazy" />
              </div>
              <div class="vt-card-body">
                <div class="vt-card-meta">
                  {t.data.technique && <span class="vt-badge">{t.data.technique}</span>}
                  <span class="vt-cost">{t.data.cost}</span>
                </div>
                <h3 class="vt-card-title">{titleStr}</h3>
                <p class="vt-card-desc">{descStr.substring(0, 100)}…</p>
                <div class="vt-card-tags">
                  <span class="vt-tag-small">{t.data.complexity}</span>
                  <span class="vt-tag-small">{t.data.reality}</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
      <div class="vt-empty" id="vt-empty" hidden>
        <p>{c.emptyMsg}</p>
        <button class="btn btn-secondary" id="vt-reset-2">{c.reset}</button>
      </div>
    </div>
  </section>

  <section class="section vt-tools-section">
    <div class="container">
      <p class="section-label">{c.toolsLabel}</p>
      <h2 class="display-md">{c.toolsHeading}</h2>
      <div class="vt-tools-grid">
        {tools.map(tool => (
          <div class="vt-tool">
            <span class="vt-tool-name">{tool.name}</span>
            <span class="vt-tool-note">{tool.note}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-sm vt-cta">
    <div class="container vt-cta-inner">
      <p class="vt-cta-text">{c.ctaText}</p>
      <a href={localeUrl('/contact/', lang)} class="btn btn-primary">{c.talkToUs}</a>
    </div>
  </section>

</Page>


<script>
  const grid       = document.getElementById('vt-grid')!;
  const empty      = document.getElementById('vt-empty')!;
  const countEl    = document.getElementById('vt-count')!;
  const dotEl      = document.getElementById('vt-filter-dot')!;
  const toggleBtn  = document.getElementById('vt-filter-toggle')!;
  const filtersBody = document.getElementById('vt-filters-body')!;
  const resetBtns  = [document.getElementById('vt-reset'), document.getElementById('vt-reset-2')];
  const total = grid.querySelectorAll('.vt-card').length;
  const active: Record<string,string> = {};

  // Toggle open/close
  toggleBtn.addEventListener('click', () => {
    const isOpen = !filtersBody.hidden;
    filtersBody.hidden = isOpen;
    toggleBtn.setAttribute('aria-expanded', String(!isOpen));
    toggleBtn.classList.toggle('open', !isOpen);
  });

  function applyFilters() {
    const cards = grid.querySelectorAll<HTMLElement>('.vt-card');
    let visible = 0;
    cards.forEach(card => {
      const show = Object.entries(active).every(([key, val]) => {
        if (key === 'purpose') return (card.dataset.purpose || '').split('|').includes(val);
        return (card.dataset as any)[key] === val;
      });
      card.hidden = !show;
      if (show) visible++;
    });
    const hasFilter = Object.keys(active).length > 0;
    // Templates are server-rendered into data attributes so this script stays
    // locale-agnostic. `__V__`/`__N__` are placeholders for visible/total counts.
    const allTmpl  = countEl.dataset.tmplAll  || `Showing all ${total} techniques`;
    const someTmpl = countEl.dataset.tmplSome || 'Showing __V__ of __N__ techniques';
    countEl.textContent = hasFilter
      ? someTmpl.replace('__V__', String(visible)).replace('__N__', String(total))
      : allTmpl;
    dotEl.hidden = !hasFilter;
    empty.hidden = visible > 0;
    resetBtns.forEach(b => { if (b) b.hidden = !hasFilter; });
  }

  document.querySelectorAll('.vt-pills').forEach(group => {
    const filterKey = (group as HTMLElement).dataset.filter!;
    group.querySelectorAll('.vt-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        const val = (pill as HTMLElement).dataset.val!;
        if (active[filterKey] === val) {
          delete active[filterKey];
          pill.classList.remove('active');
        } else {
          group.querySelectorAll('.vt-pill').forEach(p => p.classList.remove('active'));
          active[filterKey] = val;
          pill.classList.add('active');
        }
        applyFilters();
      });
    });
  });

  function reset() {
    Object.keys(active).forEach(k => delete active[k]);
    document.querySelectorAll('.vt-pill').forEach(p => p.classList.remove('active'));
    applyFilters();
  }
  resetBtns.forEach(b => b?.addEventListener('click', reset));
</script>

<style>
  .vt-hero { padding-block: clamp(3rem,6vw,5rem) clamp(2rem,4vw,3rem); border-bottom: 1px solid var(--color-border); }
  .vt-hero-sub { max-width: 60ch; margin-top: 1rem; font-size: var(--fs-body); color: var(--color-text-muted); }

  .vt-filter-section { padding-block: 0.75rem; background: var(--color-surface); border-bottom: 1px solid var(--color-border); }
  .vt-filters-bar { display: flex; align-items: center; gap: 1rem; }
  .vt-filter-toggle { display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-body); font-size: var(--fs-xs); font-weight: 500; color: var(--color-text-muted); background: transparent; border: 1px solid var(--color-border); border-radius: var(--radius-sm); padding: 0.4rem 0.75rem; cursor: pointer; transition: all 180ms ease; white-space: nowrap; }
  .vt-filter-toggle:hover { border-color: var(--color-text-muted); color: var(--color-text); }
  .vt-filter-toggle.open { border-color: var(--color-accent); color: var(--color-text); }
  .vt-toggle-chevron { width: 0.6rem; height: 0.4rem; transition: transform 200ms; }
  .vt-filter-toggle.open .vt-toggle-chevron { transform: rotate(180deg); }
  .vt-filter-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; }
  .vt-filter-dot[hidden] { display: none; }
  .vt-count-inline { font-size: var(--fs-xs); color: var(--color-text-faint); margin-left: auto; }
  .vt-filters { display: flex; flex-direction: column; gap: 0.6rem; padding-top: 0.75rem; }
  .vt-filters[hidden] { display: none; }
  .vt-filter-group { display: flex; align-items: flex-start; gap: 1rem; }
  .vt-filter-label { font-size: var(--fs-xs); font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text-faint); white-space: nowrap; padding-top: 0.35rem; min-width: 9rem; }
  .vt-pills { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .vt-pill { font-family: var(--font-body); font-size: var(--fs-xs); font-weight: 500; padding: 0.25rem 0.65rem; border: 1px solid var(--color-border); border-radius: var(--radius-sm); background: transparent; color: var(--color-text-muted); cursor: pointer; transition: all 180ms ease; white-space: nowrap; }
  .vt-pill:hover { border-color: var(--color-text-muted); color: var(--color-text); }
  .vt-pill.active { border-color: var(--color-accent); color: var(--color-accent); background: color-mix(in srgb, var(--color-accent) 8%, transparent); }
  #vt-count { font-size: var(--fs-xs); color: var(--color-text-faint); }
  .vt-reset { font-size: var(--fs-xs); color: var(--color-accent); background: none; border: none; cursor: pointer; padding: 0; font-family: var(--font-body); }

  .vt-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(max(280px, 22%), 1fr)); gap: 1.5rem; }
  /* Tech items — red border */
  .vt-card { display: flex; flex-direction: column; background: var(--color-surface); border: 1px solid var(--color-accent); border-radius: var(--radius-sm); overflow: hidden; text-decoration: none; transition: border-color 250ms ease, transform 250ms ease; }
  .vt-card:hover { border-color: var(--color-accent); transform: translateY(-2px); }
  .vt-card[hidden] { display: none; }
  .vt-card-img { aspect-ratio: 16/9; overflow: hidden; background: var(--color-surface-2); }
  .vt-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 400ms ease; }
  .vt-card:hover .vt-card-img img { transform: scale(1.04); }
  .vt-card-body { padding: 1rem 1.1rem 1.2rem; display: flex; flex-direction: column; gap: 0.45rem; flex: 1; }
  .vt-card-meta { display: flex; align-items: center; justify-content: space-between; }
  .vt-badge { font-size: var(--fs-xs); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent); }
  .vt-cost { font-size: var(--fs-xs); color: var(--color-text-faint); font-family: var(--font-mono); }
  .vt-card-title { font-family: var(--font-display); font-size: var(--fs-body); font-weight: 700; color: var(--color-text); line-height: 1.2; margin: 0; }
  .vt-card-desc { font-size: var(--fs-xs); color: var(--color-text-muted); line-height: 1.5; max-width: none; }
  .vt-card-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: auto; padding-top: 0.25rem; }
  .vt-tag-small { font-size: var(--fs-xs); letter-spacing: 0.08em; padding: 0.12rem 0.4rem; border: 1px solid var(--color-border); border-radius: 2px; color: var(--color-text-faint); text-transform: uppercase; }

  .vt-empty { text-align: center; padding: 4rem 0; color: var(--color-text-muted); }
  .vt-empty p { margin-bottom: 1.5rem; }

  .vt-tools-section { border-top: 1px solid var(--color-border); background: var(--color-surface); }
  .vt-tools-section h2 { margin: 0.5rem 0 2rem; }
  .vt-tools-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(155px, 1fr)); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); }
  .vt-tool { background: var(--color-surface); padding: 0.9rem 1.1rem; display: flex; flex-direction: column; gap: 0.15rem; }
  .vt-tool-name { font-family: var(--font-display); font-size: var(--fs-small); font-weight: 700; color: var(--color-text); }
  .vt-tool-note { font-size: var(--fs-xs); color: var(--color-text-faint); }

  .vt-cta { border-top: 1px solid var(--color-border); }
  .vt-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
  .vt-cta-text { font-family: var(--font-display); font-size: var(--fs-body); font-weight: 600; color: var(--color-text); max-width: none; }

  @media (max-width: 768px) {
    .vt-filter-group { flex-direction: column; gap: 0.4rem; }
    .vt-filter-label { min-width: auto; }
    .vt-cta-inner { flex-direction: column; align-items: flex-start; }
    .vt-tools-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
