---
// src/pages/services/[slug].astro
import { getCollection } from 'astro:content';
import { thumbUrl } from '../../../lib/image-url';
import Page from '../../../layouts/Page.astro';
import SectionBanner from '../../../components/ui/SectionBanner.astro';
import DeliverableGrid from '../../../components/mdx/DeliverableGrid.astro';
import TimelineTable from '../../../components/mdx/TimelineTable.astro';
import NotableGrid from '../../../components/mdx/NotableGrid.astro';
import ImageGallery from '../../../components/mdx/ImageGallery.astro';
import ImageCompare from '../../../components/mdx/ImageCompare.astro';
import ProcessFlow from '../../../components/mdx/ProcessFlow.astro';
import PhaseMatrix from '../../../components/mdx/PhaseMatrix.astro';
import Tour360 from '../../../components/media/Tour360.astro';
import FilmEmbed from '../../../components/media/FilmEmbed.astro';
import YouTubeEmbed from '../../../components/media/YouTubeEmbed.astro';
import SpecTable from '../../../components/mdx/SpecTable.astro';
import CompareTable from '../../../components/mdx/CompareTable.astro';
import SingleImage from '../../../components/mdx/SingleImage.astro';
import ArticleGalleryMounter from '../../../components/media/ArticleGalleryMounter.tsx';
import ArticleImageCompareMounter from '../../../components/media/ArticleImageCompareMounter.tsx';
import Lang from '../../../components/i18n/Lang.astro';
import { localizedPaths, localeUrl, tStr, type Locale } from '../../../lib/i18n';

export async function getStaticPaths() {
  const allServices = await getCollection('services', ({ data }) => data.published);
  return localizedPaths(allServices, entry => ({ slug: entry.slug }));
}

const { lang, slug } = Astro.params as { lang: Locale; [k: string]: string | undefined };
Astro.locals.lang = lang;
const allServices = await getCollection('services', ({ data }) => data.published);
const entry = allServices.find(s => s.slug === slug);
if (!entry) return Astro.redirect(localeUrl('/services/', lang));
const { data } = entry;
const { Content } = await entry.render();

// Resolve translatable frontmatter fields
const titleStr            = tStr(data.title, lang);
const descriptionStr      = tStr(data.description, lang);
const taglineStr          = tStr(data.tagline, lang);
const pricingStr          = tStr(data.pricing, lang);
const startRequirementsStr = tStr(data.startRequirements, lang);
const sidebarLabelStr     = tStr(data.sidebarLabel, lang);
const sidebarContentStr   = tStr(data.sidebarContent, lang);

// Related projects — those that list this service in their services array
const allProjects = await getCollection('projects', p =>
  p.data.published && !!p.data.coverImage && (p.data.services ?? []).includes(entry.slug)
);
const relatedProjects = allProjects.sort((a, b) => b.data.year - a.data.year).slice(0, 8);

// Linked vision-tech techniques for chip row
const allTech = await getCollection('vision-tech');
const linkedTech = (data.techniques ?? [])
  .map(slug => allTech.find(t => t.slug === slug))
  .filter(Boolean);

const hasMeta = pricingStr || startRequirementsStr || (sidebarLabelStr && sidebarContentStr);

const COPY = {
  en: {
    metaSuffix:        '— Services',
    bannerLabel:       'Service',
    breadcrumbServices:'Services',
    pricingLabel:      'Pricing',
    startRequirements: 'What you need to start',
    techniquesUsed:    'Techniques used in this service:',
    projectsUsing:     'Projects using this service:',
    seeWork:           'See Our Work',
    startProject:      'Start a Project',
    prev:              'Previous',
    next:              'Next',
  },
  hu: {
    metaSuffix:        '— Szolgáltatások',
    bannerLabel:       'Szolgáltatás',
    breadcrumbServices:'Szolgáltatások',
    pricingLabel:      'Árképzés',
    startRequirements: 'Mire van szüksége az induláshoz',
    techniquesUsed:    'A szolgáltatáshoz használt technikák:',
    projectsUsing:     'Projektek, amelyek ezt a szolgáltatást használták:',
    seeWork:           'Munkáink',
    startProject:      'Projekt indítása',
    prev:              'Előző',
    next:              'Következő',
  },
} as const;
const c = COPY[lang];
---

<Page title={`${titleStr} ${c.metaSuffix}`} description={descriptionStr} fullBleed>
  <SectionBanner
    image={data.bannerImage ?? '/_img/banners/banner-arch-viz.jpg'}
    label={c.bannerLabel}
    title={titleStr}
    size="page"
    headingLevel="h1"
  />
  <div class="service-page">
    <div class="service-breadcrumb container">
      <a href={localeUrl('/services/', lang)}>{c.breadcrumbServices}</a>
      <span>→</span>
      <span>{titleStr}</span>
    </div>

    {taglineStr && (
      <div class="service-tagline container">
        <p class="service-tagline-text">{taglineStr}</p>
      </div>
    )}

    {hasMeta && (
      <div class="container">
      <div class="service-meta">
        {pricingStr && (
          <div class="service-meta-item">
            <span class="service-meta-label">{c.pricingLabel}</span>
            <span class="service-meta-value">{pricingStr}</span>
          </div>
        )}
        {startRequirementsStr && (
          <div class="service-meta-item">
            <span class="service-meta-label">{c.startRequirements}</span>
            <span class="service-meta-value">{startRequirementsStr}</span>
          </div>
        )}
        {sidebarLabelStr && sidebarContentStr && (
          <div class="service-meta-item">
            <span class="service-meta-label">{sidebarLabelStr}</span>
            <span class="service-meta-value">{sidebarContentStr}</span>
          </div>
        )}
      </div>
      </div>
    )}

    <div class="service-main container">
      <Content components={{
        SectionBanner,
        DeliverableGrid,
        TimelineTable,
        NotableGrid,
        ImageGallery,
        ImageCompare,
        ProcessFlow,
        PhaseMatrix,
        Tour360,
        FilmEmbed,
        YoutubeEmbed: YouTubeEmbed,
        YouTubeEmbed,
        SpecTable,
        CompareTable,
        SingleImage,
        Lang,
      }} />
      <ArticleGalleryMounter client:load />
      <ArticleImageCompareMounter client:load />
    </div>

    {linkedTech.length > 0 && (
      <div class="svc-techniques container">
        <span class="svc-techniques-label">{c.techniquesUsed}</span>
        <div class="svc-techniques-chips">
          {linkedTech.map(t => (
            <a href={localeUrl(`/vision-tech/${t!.slug}/`, lang)} class="svc-technique-chip">{tStr(t!.data.title, lang)}</a>
          ))}
        </div>
      </div>
    )}

    {relatedProjects.length > 0 && (
      <section class="svc-related-section">
        <div class="container">
          <p class="svc-related-heading">{c.projectsUsing}</p>
          <div class="svc-carousel-wrap">
            <button class="svc-carousel-btn svc-carousel-prev" id="svc-prev" aria-label={c.prev}>&#8592;</button>
            <div class="svc-carousel" id="svc-carousel">
              {relatedProjects.map(p => (
                <a href={localeUrl(`/portfolio/${p.slug}/`, lang)} class="svc-rel-card">
                  <img
                    src={thumbUrl(p.data.coverImage)}
                    alt={tStr(p.data.title, lang)}
                    loading="lazy"
                    onerror={`this.onerror=null;this.src='${p.data.coverImage}'`}
                  />
                  <div class="svc-rel-body">
                    <span class="svc-rel-year">{p.data.year}</span>
                    <span class="svc-rel-title">{tStr(p.data.displayTitle, lang) || tStr(p.data.title, lang)}</span>
                  </div>
                </a>
              ))}
            </div>
            <button class="svc-carousel-btn svc-carousel-next" id="svc-next" aria-label={c.next}>&#8594;</button>
          </div>
        </div>
      </section>
    )}

    <div class="service-cta container">
      <a href={localeUrl('/portfolio/', lang)} class="btn btn-secondary">{c.seeWork}</a>
      <a href={localeUrl('/contact/', lang)} class="btn btn-primary">{c.startProject}</a>
    </div>
  </div>
</Page>

<script>
  const carousel = document.getElementById('svc-carousel') as HTMLElement | null;
  const prevBtn  = document.getElementById('svc-prev');
  const nextBtn  = document.getElementById('svc-next');
  if (carousel) {
    const cardW = () => carousel.querySelector<HTMLElement>('.svc-rel-card')?.offsetWidth ?? 300;
    prevBtn?.addEventListener('click', () => carousel.scrollBy({ left: -cardW(), behavior: 'smooth' }));
    nextBtn?.addEventListener('click', () => carousel.scrollBy({ left:  cardW(), behavior: 'smooth' }));

    // Drag-to-scroll
    let isDragging = false;
    let startX = 0;
    let scrollStart = 0;
    let moved = false;

    carousel.addEventListener('mousedown', e => {
      isDragging = true;
      moved = false;
      startX = e.pageX;
      scrollStart = carousel.scrollLeft;
      carousel.style.cursor = 'grabbing';
      carousel.style.userSelect = 'none';
    });

    window.addEventListener('mousemove', e => {
      if (!isDragging) return;
      const dx = e.pageX - startX;
      if (Math.abs(dx) > 4) moved = true;
      carousel.scrollLeft = scrollStart - dx;
    });

    window.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      carousel.style.cursor = '';
      carousel.style.userSelect = '';
    });

    // Prevent click-through on cards after a drag
    carousel.addEventListener('click', e => {
      if (moved) e.preventDefault();
    }, true);
  }
</script>

<style>
  .service-page { padding-block: var(--space-16); overflow-x: hidden; }

  .service-breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: var(--fs-xs); color: var(--color-text-faint); margin-bottom: 2rem;
  }
  .service-breadcrumb a { color: var(--color-text-muted); text-decoration: none; transition: color 200ms; }
  .service-breadcrumb a:hover { color: var(--color-accent); }

  .service-tagline { margin-bottom: 2rem; }
  .service-tagline-text {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: 300;
    font-style: italic;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.3;
  }

  /* Meta strip */
  .service-meta {
    display: flex;
    flex-wrap: wrap;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }
  .service-meta-item {
    flex: 1;
    min-width: 200px;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.5rem 1rem 0;
  }
  .service-meta-item + .service-meta-item {
    padding-left: 1.5rem;
    border-left: 1px solid var(--color-border);
  }
  .service-meta-label {
    font-size: var(--fs-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-faint);
  }
  .service-meta-value {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* MDX content — .container class (on the HTML element) provides side padding.
     SectionBanners escape to full viewport width via the position trick. */
  .service-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: 3rem;
  }

  /* SectionBanners: full viewport width, equal breathing room above and below.
     Both margins keep spacing external — never padding inside visual containers. */
  .service-main :global(.section-banner) {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin-top: clamp(1.5rem, 3vw, 3rem);
    margin-bottom: clamp(1.5rem, 3vw, 3rem);
  }

  /* Consecutive banners: cancel the stacked margins */
  .service-main :global(.section-banner + .section-banner) {
    margin-top: 0;
  }

  /* Zero out block margins on all direct children — flex gap is the sole spacer.
     Banner margins override this because they are declared below (same specificity,
     last declaration wins). */
  .service-main > :global(*) {
    margin-block: 0;
  }

  /* Direct-child typography — scoped to top-level MDX elements only so nested
     card/component text (deliverable-grid, process-flow, etc.) is not affected */
  .service-main > :global(p) {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }
  .service-main > :global(h2) {
    font-size: var(--fs-h4);
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }
  .service-main > :global(ul) {
    list-style: none;
    padding-block: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .service-main :global(ul li) {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    padding-left: 1.25rem;
    position: relative;
  }
  .service-main :global(ul li::before) {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.75em;
  }

  .service-cta { display: flex; gap: 0.75rem; margin-top: 1rem; }

  /* Techniques chip row */
  .svc-techniques {
    margin-bottom: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .svc-techniques-label {
    font-size: var(--fs-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-faint);
  }
  .svc-techniques-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .svc-technique-chip {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 0.3rem 0.65rem;
    text-decoration: none;
    transition: color 200ms, border-color 200ms;
    white-space: nowrap;
  }
  .svc-technique-chip:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* ── Related projects carousel ────────────────────────── */
  .svc-related-section {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-8);
    margin-top: var(--space-8);
  }
  .svc-related-heading {
    font-size: var(--fs-small);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-faint);
    margin-bottom: var(--space-4);
  }
  .svc-carousel-wrap {
    display: flex;
    align-items: stretch;
    gap: 1px;
  }
  .svc-carousel {
    flex: 1;
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    gap: 1px;
    background: var(--color-border);
    cursor: grab;
  }
  .svc-carousel::-webkit-scrollbar { display: none; }

  /* Card — full-bleed image with gradient overlay */
  .svc-rel-card {
    flex: 0 0 clamp(200px, 22%, 340px);
    aspect-ratio: 4 / 3;
    position: relative;
    text-decoration: none;
    scroll-snap-align: start;
    overflow: hidden;
    display: block;
  }
  .svc-rel-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease;
  }
  .svc-rel-card:hover img { transform: scale(1.06); }
  .svc-rel-body {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.18) 55%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1rem 1.1rem;
    gap: 0.15rem;
    transition: background 300ms ease;
  }
  .svc-rel-card:hover .svc-rel-body {
    background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.28) 65%, transparent 100%);
  }
  .svc-rel-year {
    font-size: var(--fs-xs);
    color: rgba(255,255,255,0.55);
    font-family: var(--font-mono);
    line-height: 1;
  }
  .svc-rel-title {
    font-size: var(--fs-small);
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.2;
  }

  .svc-carousel-btn {
    flex-shrink: 0;
    width: 2.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: var(--fs-body);
    cursor: pointer;
    transition: color 200ms ease, background 200ms ease;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .svc-carousel-btn:hover { color: var(--color-accent); background: var(--color-surface-2); }
</style>
