---
// src/pages/[lang]/about/index.astro

import Page          from '../../../layouts/Page.astro';
import SectionBanner from '../../../components/ui/SectionBanner.astro';
import timeline      from '../../../data/about-timeline.json';
import { staticLocalePaths, type Locale, tStr, localeUrl } from '../../../lib/i18n';
import { ui } from '../../../i18n/strings';

export const getStaticPaths = staticLocalePaths;


const { lang } = Astro.params as { lang: Locale };
Astro.locals.lang = lang;
const L = ui(lang);
---

<Page
  title={L.about.metaTitle}
  description={L.about.metaDescription}
  fullBleed
  >
  <div class="about-page">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- PAGE HEADER / SECTION 1 — ABOUT THE STUDIO            -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <SectionBanner
      image="/_img/banners/banner-large-scale.jpg"
      label={L.about.bannerLabel}
      title={L.about.bannerTitle}
      headingLevel="h1"
      size="page"
    />

    <section class="about-studio section">
      <div class="container two-col">

        <div class="col-left">
          <p class="body-lead">{L.about.introLead}</p>
        </div>

        <div class="col-right">
          <div class="diff-block">
            <p class="diff-label">{L.about.diffLabel}</p>
            <p class="body-text">{L.about.diffBody}</p>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- SECTION 2 — MEET THE EXPERT                            -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <SectionBanner
      image="/_img/banners/banner-general.jpg"
      label={L.about.founderLabel}
      title={L.about.founderTitle}
    />

    <section class="founder-section section">
      <div class="container founder-inner">

        <!-- Text column -->
        <div class="founder-text">
          <p class="founder-name-label">László Kerezsi</p>
          <p class="founder-role">{L.about.founderRole}</p>

          <p class="body-text">{L.about.founderBio1}</p>
          <p class="body-text">{L.about.founderBio2}</p>
          <p class="body-text">{L.about.founderBio3}</p>

          <div class="founder-contact">
            <a href="tel:+36309454179" class="contact-link">
              <span class="contact-link-label">{L.about.founderPhoneLabel}</span>
              <span class="contact-link-value">+36 30 945 4179</span>
            </a>
            <a href="mailto:info@visiongraphics.hu" class="contact-link">
              <span class="contact-link-label">{L.about.founderEmailLabel}</span>
              <span class="contact-link-value">info@visiongraphics.hu</span>
            </a>
          </div>
        </div>

        <!-- Photo + stats column -->
        <div class="founder-aside">
          <div class="founder-photo-wrap">
            <img
              src="/laszlo.jpg"
              alt={L.about.founderPhotoAlt}
              class="founder-photo"
              width="400"
              height="520"
              loading="lazy"
            />
          </div>
          <div class="founder-stats">
            {[
              { n: '30+',  l: L.about.statYears3dsMax },
              { n: '15+',  l: L.about.statYearsVRay },
              { n: '500+', l: L.about.statProjects },
              { n: '4',    l: L.about.statContinents },
            ].map(s => (
              <div class="stat-block">
                <span class="stat-n">{s.n}</span>
                <span class="stat-l">{s.l}</span>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- SECTION 3 — HOW WE WORK                                -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <SectionBanner
      image="/_img/banners/banner-workflow.jpg"
      label={L.about.structureLabel}
      title={L.about.structureTitle}
    />

    <section class="how-section section">
      <div class="container">

        <div class="two-col how-intro">
          <div class="col-left">
            <h3 class="section-sub-heading">{L.about.smallTeamHeading}</h3>
            <p class="body-lead">{L.about.smallTeamLead}</p>
          </div>
          <div class="col-right">
            <p class="body-text">{L.about.smallTeamBody}</p>
            <p class="inhouse-label">{L.about.inhouseLabel}</p>
            <ul class="how-list">
              <li>{L.about.inhouseItem1}</li>
              <li>{L.about.inhouseItem2}</li>
              <li>{L.about.inhouseItem3}</li>
              <li>{L.about.inhouseItem4}</li>
            </ul>
            <a href={localeUrl('/contact/', lang)} class="btn btn-primary">{L.about.startConvBtn}</a>
          </div>
        </div>

        <!-- Specialist network -->
        <div class="specialists-block">
          <div class="specialists-header">
            <p class="block-label">{L.about.networkLabel}</p>
            <p class="body-text specialists-intro">{L.about.networkIntro}</p>
          </div>
          <div class="specialists-grid">
            {L.about.specialists.map(s => (
              <div class="specialist-card">
                <p class="specialist-role">{s.role}</p>
                <p class="specialist-desc">{s.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Why it works -->
        <div class="benefits-block">
          <p class="block-label">{L.about.whyLabel}</p>
          <div class="benefits-grid">
            {[
              { t: L.about.benefit1Title, b: L.about.benefit1Body },
              { t: L.about.benefit2Title, b: L.about.benefit2Body },
              { t: L.about.benefit3Title, b: L.about.benefit3Body },
              { t: L.about.benefit4Title, b: L.about.benefit4Body },
            ].map(b => (
              <div class="benefit-item">
                <h4 class="benefit-title">{b.t}</h4>
                <p class="benefit-body">{b.b}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- SECTION 4 — TIMELINE                                   -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <SectionBanner
      image="/_img/banners/banner-arch-viz.jpg"
      label={L.about.historyLabel}
      title={L.about.historyTitle}
    />

    <section class="timeline-section section">
      <div class="container">

        <p class="body-text timeline-intro">{L.about.timelineIntro}</p>

        <div class="tl-timeline" id="about-timeline">
          <div class="tl-line" id="tl-line"></div>
          {timeline.map((era, i) => (
            <div class="tl-item" data-index={i} style={`transition-delay: ${i * 80}ms`}>
              <span class="tl-years">{era.years}</span>
              <div class="tl-content">
                <h3 class="tl-title">{tStr(era.title, lang)}</h3>
                <p class="tl-text">{tStr(era.summary, lang)}</p>
                <ul class="tl-projects">
                  {era.projects.map(p => <li>{p}</li>)}
                </ul>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- CTA                                                    -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <section class="about-cta">
      <div class="container about-cta-inner">
        <div>
          <h2 class="cta-heading">{L.about.ctaHeading}</h2>
          <p class="cta-sub">{L.about.ctaSub}</p>
        </div>
        <a href={localeUrl('/contact/', lang)} class="btn btn-primary">{L.about.ctaBtn}</a>
      </div>
    </section>

  </div>
</Page>

<script>
  // Scroll-animated vertical timeline
  const section = document.querySelector<HTMLElement>('.timeline-section');
  const line    = document.getElementById('tl-line');
  const items   = document.querySelectorAll<HTMLElement>('.tl-item');

  // Reveal line when section enters viewport
  if (section && line) {
    const lineObserver = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        line.classList.add('revealed');
        lineObserver.disconnect();
      }
    }, { threshold: 0.05 });
    lineObserver.observe(section);
  }

  // Pop-in each item and advance the red portion of the line
  const total = items.length;
  let visibleCount = 0;

  const itemObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        visibleCount++;
        if (line) {
          const pct = Math.round((visibleCount / total) * 100);
          line.style.setProperty('--tl-red', `${pct}%`);
        }
        itemObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  items.forEach(item => itemObserver.observe(item));
</script>

<style>
  .about-page { width: 100%; }

  /* ── Shared typography ───────────────────────────────────── */
  .body-lead {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin: 0;
  }

  .body-text {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin: 0;
    max-width: 60ch;
  }

  .block-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 1.25rem;
  }

  .section-sub-heading {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 1.25rem;
  }

  /* ── Two-column layout (shared) ──────────────────────────── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  /* ── Section 1: About the studio ────────────────────────── */
  .about-studio {
    padding-block: clamp(3rem, 5vw, 5rem);
  }

  .diff-block {
    padding: 2rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .diff-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.75rem;
  }

  /* ── Section 2: Founder ──────────────────────────────────── */
  .founder-section {
    padding-block: clamp(3rem, 5vw, 5rem);
  }

  .founder-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  .founder-name-label {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0 0 0.4rem;
  }

  .founder-role {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 2rem;
  }

  .founder-text .body-text { margin-bottom: 1rem; max-width: 58ch; }
  .founder-text .body-text:last-of-type { margin-bottom: 2rem; }

  .founder-contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    padding: 0.4rem 0;
    cursor: pointer;
    transition: color 200ms;
  }

  .contact-link-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    min-width: 3.5rem;
  }

  .contact-link-value {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    transition: color 200ms;
  }

  .contact-link:hover .contact-link-value { color: var(--color-text); }

  /* Photo — portrait rectangle, squared corners */
  .founder-aside {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
  }

  .founder-photo-wrap {
    width: 320px;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .founder-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 600ms ease;
  }

  .founder-photo-wrap:hover .founder-photo { transform: scale(1.03); }

  /* Stat blocks */
  .founder-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    width: 100%;
  }

  .stat-block {
    background: var(--color-surface);
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    transition: background 200ms;
  }

  .stat-block:hover { background: var(--color-surface-2); }

  .stat-n {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 300;
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .stat-l {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 400;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  /* ── Section 3: How We Work ──────────────────────────────── */
  .how-section { padding-block: clamp(3rem, 5vw, 5rem); }

  .how-intro { margin-bottom: 4rem; }

  .inhouse-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin: 1.5rem 0 0.75rem;
  }

  .how-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin-bottom: 2rem;
  }

  .how-list li {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    padding-left: 1.2rem;
    position: relative;
    line-height: 1.6;
  }

  .how-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: var(--fs-xs);
    top: 0.18em;
  }

  /* Specialist grid */
  .specialists-block {
    border-top: 1px solid var(--color-border);
    padding-top: 3rem;
    margin-bottom: 3rem;
  }

  .specialists-header {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(3rem, 6vw, 7rem);
    margin-bottom: 2rem;
    align-items: start;
  }

  .specialists-intro { max-width: 56ch; }

  .specialists-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .specialist-card {
    background: var(--color-surface);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    transition: background 200ms;
  }

  .specialist-card:hover { background: var(--color-surface-2); }

  .specialist-role {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .specialist-desc {
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    line-height: 1.55;
    margin: 0;
  }

  /* Benefits */
  .benefits-block {
    border-top: 1px solid var(--color-border);
    padding-top: 3rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-top: 1.5rem;
  }

  .benefit-item { display: flex; flex-direction: column; gap: 0.5rem; }

  .benefit-title {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: 400;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin: 0;
    line-height: 1.1;
  }

  .benefit-body {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Section 4: Scroll-animated Timeline ────────────────── */
  .timeline-section { padding-block: clamp(3rem, 5vw, 5rem); }

  .timeline-intro {
    max-width: 68ch;
    margin-bottom: 2.5rem;
    color: var(--color-text-faint);
    font-size: var(--fs-small);
  }

  /* Timeline container */
  .tl-timeline {
    position: relative;
    padding-left: 9rem;
  }

  /* Vertical line */
  .tl-line {
    position: absolute;
    left: 7rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 1px;
    background: linear-gradient(
      to bottom,
      var(--color-accent) 0%,
      var(--color-accent) var(--tl-red, 0%),
      var(--color-border) var(--tl-red, 0%),
      var(--color-border) 100%
    );
    transform-origin: top;
    transform: scaleY(0);
    transition: transform 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .tl-line.revealed { transform: scaleY(1); }

  /* Each era row */
  .tl-item {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    padding-bottom: 2.5rem;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .tl-item.visible { opacity: 1; transform: translateY(0); }

  /* Dot on the line */
  .tl-item::before {
    content: '';
    position: absolute;
    left: calc(-9rem + 7rem - 5px); /* line offset - half dot */
    top: 0.35rem;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    background: var(--color-bg);
    z-index: 1;
    transition: border-color 400ms, background 400ms, box-shadow 400ms;
    transition-delay: inherit;
  }
  .tl-item.visible::before {
    border-color: var(--color-accent);
    background: var(--color-accent);
    box-shadow: 0 0 10px color-mix(in srgb, var(--color-accent) 35%, transparent);
  }

  .tl-years {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-accent);
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
    display: block;
  }

  .tl-title {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .tl-text {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    line-height: 1.75;
    max-width: 65ch;
    margin-bottom: 1rem;
  }

  .tl-projects {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.5rem;
    margin: 0;
  }

  .tl-projects li {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    letter-spacing: 0.04em;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 1px;
    transition: color 200ms ease, border-color 200ms ease;
  }

  .tl-projects li:hover {
    color: var(--color-text-muted);
    border-color: rgba(255, 255, 255, 0.22);
  }

  /* ── CTA ─────────────────────────────────────────────────── */
  .about-cta {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding-block: 5rem;
  }

  .about-cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-heading {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .cta-sub {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .two-col            { grid-template-columns: 1fr; gap: 2rem; }
    .founder-inner      { grid-template-columns: 1fr; gap: 2rem; }
    .founder-aside      { flex-direction: row; align-items: flex-start; gap: 2rem; }
    .founder-photo-wrap { width: 240px; }
    .founder-stats      { grid-template-columns: repeat(4, 1fr); width: auto; flex: 1; }
    .specialists-header { grid-template-columns: 1fr; gap: 1rem; }
    .benefits-grid      { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 860px) {
    .specialists-grid   { grid-template-columns: repeat(2, 1fr); }
    .tl-timeline        { padding-left: 5rem; }
    .tl-line            { left: 3.5rem; }
    .tl-item::before    { left: calc(-5rem + 3.5rem - 5px); }
  }

  @media (max-width: 600px) {
    .founder-aside      { flex-direction: column; }
    .founder-photo-wrap { width: 100%; max-width: 280px; }
    .founder-stats      { grid-template-columns: repeat(2, 1fr); width: 100%; }
    .specialists-grid   { grid-template-columns: 1fr; }
    .benefits-grid      { grid-template-columns: 1fr; gap: 1.5rem; }
    .tl-timeline        { padding-left: 0; }
    .tl-line            { display: none; }
    .tl-item::before    { display: none; }
    .about-cta-inner    { flex-direction: column; align-items: flex-start; }
    .about-cta          { padding-block: 3.5rem; }
  }
</style>
