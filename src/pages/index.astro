---
// src/pages/index.astro

import Base from '../layouts/Base.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Icon from '../components/ui/Icon.astro';
import HomeCarousel from '../components/HomeCarousel';
import { getCollection, getEntry } from 'astro:content';

// Featured projects for homepage carousel
const allProjects = await getCollection('projects', ({ data }) =>
  data.published && data.featured && !!data.coverImage
);
const featuredProjects = allProjects.sort((a, b) => b.data.year - a.data.year);

const carouselSlides = await Promise.all(
  featuredProjects.map(async p => {
    const city    = p.data.city    ? (await getEntry('cities',    p.data.city.id))?.data.title    : undefined;
    const country = p.data.country ? (await getEntry('countries', p.data.country.id))?.data.title : undefined;
    return {
      slug:       p.slug,
      title:      p.data.title,
      year:       p.data.year,
      coverImage: p.data.coverImage,
      location:   [city, country].filter(Boolean).join(', ') || undefined,
    };
  })
);

// Services teaser — first 4 by order
const allServices = await getCollection('services', ({ data }) => data.published);
const teaserServices = allServices
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
---

<Base
  title="Vision Graphics"
  description="Expert 3D architectural visualization. 30 years, 500+ projects. Budapest-based, working globally. Stills, animation, VR, AI-enhanced workflows."
>
  <Header />

  <main id="content">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- HERO                                                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-content">
          <p class="section-label hero-label">30 Years · 500+ Projects · Budapest</p>
          <h1 class="hero-h1">
            Architecture<br />
            Deserves Better<br />
            <em>Visuals</em>
          </h1>
          <p class="hero-sub">
            We turn complex architectural plans into visuals that get projects approved,
            properties sold, and stakeholders aligned.
            Budapest-based. Working globally since 1996.
          </p>
          <div class="hero-ctas">
            <a href="/portfolio/" class="btn btn-primary">See Our Work</a>
            <a href="/contact/"   class="btn btn-secondary">Talk to Us</a>
          </div>
        </div>
      </div>

      <div class="hero-bg" aria-hidden="true">
        <div class="hero-bg-overlay"></div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- FEATURED WORK — carousel immediately below the fold        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    {carouselSlides.length > 0 && (
      <section class="featured-section">
        <div class="featured-carousel-header container">
          <div>
            <p class="section-label">Selected Work</p>
            <h2 class="display-md">30 Years of Projects</h2>
          </div>
          <a href="/portfolio/" class="btn btn-secondary">Full Portfolio</a>
        </div>
        <HomeCarousel slides={carouselSlides} client:load />
      </section>
    )}

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- CLIENT LOGOS                                                -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <section class="logos-strip section-sm">
      <div class="container">
        <p class="section-label logos-label">Trusted by</p>
        <div class="logos-row">
          {[
            'Mol Campus', 'Hungexpo', 'Budapest Airport',
            'Antalya Airport', 'Korda Studios', 'Opera / Eiffel Art Studios',
            'K&H Bank', 'Agora Budapest',
          ].map(name => (
            <span class="logo-name-text">{name}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- STATS                                                       -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <section class="stats-bar section-sm">
      <div class="container">
        <div class="stats-grid">
          {[
            { number: '30+',  label: 'Years of experience' },
            { number: '500+', label: 'Projects delivered' },
            { number: '4',    label: 'Continents' },
            { number: '1996', label: 'Founded' },
          ].map(s => (
            <div class="stat">
              <span class="stat-number">{s.number}</span>
              <span class="stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <hr class="container-rule" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- THE STUDIO                                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <section class="section solution-section">
      <div class="container solution-inner">
        <div class="solution-text">
          <p class="section-label">The Studio</p>
          <h2 class="display-md">Vision Graphics</h2>

          <div class="laszlo-portrait">
            <img
              src="/laszlo.jpg"
              alt="The studio mascot keeping watch. László is somewhere in the background — that's intentional."
              class="laszlo-img"
              loading="lazy"
            />
          </div>

          <p class="solution-body">
            László Kerezsi has been doing this for 30 years. He works directly on your
            project — no account managers, no handoffs to juniors. When your project needs
            more firepower, he brings in a tested network of specialists. You get one
            point of contact and the output of a full studio.
          </p>
          <blockquote class="solution-callout">
            "We catch problems in your plans before they become expensive construction
            mistakes. That's 30 years of pattern recognition working for you."
          </blockquote>
          <a href="/about/" class="btn btn-ghost">About the studio</a>
        </div>

        <div class="differentiators">
          {[
            {
              n: '01',
              title: 'Direct Access',
              body: 'You work with László, not a project coordinator. He\'s been doing this since 3ds Max was version 1.',
            },
            {
              n: '02',
              title: 'Scalable Without the Overhead',
              body: 'Small project? Just us. Airport terminal? We bring in the right specialists. You pay for what the project needs.',
            },
            {
              n: '03',
              title: 'AI Where It Helps',
              body: 'AI integrated into the workflow — not as a gimmick, but to deliver faster drafts, more variations, and better QC on large file sets.',
            },
          ].map(d => (
            <div class="diff-card">
              <span class="diff-n">{d.n}</span>
              <h3 class="diff-title">{d.title}</h3>
              <p class="diff-body">{d.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- SERVICES TEASER                                             -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <section class="section services-teaser-section">
      <div class="container">
        <div class="services-teaser-header">
          <div>
            <p class="section-label">What We Do</p>
            <h2 class="display-md">Services</h2>
          </div>
          <a href="/services/" class="btn btn-secondary">All Services</a>
        </div>
        <div class="services-teaser-grid">
          {teaserServices.map((svc, i) => (
            <a href={`/services/${svc.slug}/`} class="svc-card">
              <span class="svc-n">0{i + 1}</span>
              <h3 class="svc-title">{svc.data.title}</h3>
              <p class="svc-tagline">{svc.data.tagline}</p>
              <span class="svc-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- HOW IT WORKS                                                -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <section class="section process-section">
      <div class="container">
        <p class="section-label">How It Works</p>
        <h2 class="display-md">Three Steps to Finished Visuals</h2>
        <div class="process-steps">
          {[
            {
              step: '1',
              title: 'Quick Start',
              time:  '2–3 days',
              items: [
                'Send your plans — we take it from there',
                'Clear timing and costs before we begin',
                'No lengthy briefing forms',
              ],
            },
            {
              step: '2',
              title: 'Working Together',
              time:  '1–2 weeks',
              items: [
                'First drafts within days',
                'Regular check-ins, no surprises',
                'Fix things as we go',
              ],
            },
            {
              step: '3',
              title: 'Ready to Present',
              time:  'Final week',
              items: [
                'Visuals prepared for your format: pitch, planning, or marketing',
                'Files delivered in formats your team can use',
                'VR upgrade available at any stage',
              ],
            },
          ].map(s => (
            <div class="process-step">
              <div class="process-step-header">
                <span class="process-n">{s.step}</span>
                <div>
                  <h3 class="process-title">{s.title}</h3>
                  <span class="process-time">{s.time}</span>
                </div>
              </div>
              <ul class="process-list">
                {s.items.map(item => <li>{item}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- CTA BANNER                                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <section class="cta-banner">
      <div class="container cta-banner-inner">
        <div>
          <h2 class="cta-h2">Let's Talk About Your Project</h2>
          <p class="cta-sub">30-minute consultation. No charge. No obligation.</p>
        </div>
        <a href="/contact/" class="btn btn-primary">Get in Touch</a>
      </div>
    </section>

  </main>

  <Footer />
</Base>

<style>
  /* ── Hero ─────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    padding-block: var(--space-20) var(--space-12);
  }

  .hero-content { max-width: 700px; }

  .hero-label {
    margin-bottom: var(--space-6);
    opacity: 0;
    animation: fadeUp 0.8s ease 0.2s forwards;
  }

  .hero-h1 {
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: var(--space-8);
    opacity: 0;
    animation: fadeUp 0.8s ease 0.35s forwards;
  }

  .hero-h1 em {
    font-style: italic;
    color: var(--color-accent);
  }

  .hero-sub {
    font-size: var(--fs-body);
    font-weight: 300;
    color: var(--color-text-muted);
    max-width: 48ch;
    line-height: 1.7;
    margin-bottom: var(--space-10);
    opacity: 0;
    animation: fadeUp 0.8s ease 0.5s forwards;
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.65s forwards;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      url('/hero-bg.jpg') center/cover no-repeat,
      linear-gradient(135deg, var(--color-surface-2) 0%, var(--color-surface) 50%, var(--color-surface-2) 100%);
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(0, 0, 0, 0.92) 0%,
      rgba(0, 0, 0, 0.70) 50%,
      rgba(0, 0, 0, 0.40) 100%
    );
  }

  /* ── Featured / Carousel ──────────────────────────────────── */
  .featured-carousel-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-block: var(--space-8) var(--space-6);
  }

  /* ── Logos ────────────────────────────────────────────────── */
  .logos-label { margin-bottom: var(--space-5); }

  .logos-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-8);
    align-items: center;
  }

  .logo-name-text {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    color: var(--color-text-faint);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: color 200ms ease;
  }

  .logo-name-text:hover { color: var(--color-text-muted); }

  /* ── Stats ────────────────────────────────────────────────── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .stat {
    background: var(--color-surface);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 300;
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    font-weight: 300;
  }

  .container-rule {
    border-color: var(--color-border);
    margin-inline: auto;
    max-width: 1320px;
    padding-inline: clamp(1.5rem, 5vw, 4rem);
  }

  /* ── Studio / Solution ────────────────────────────────────── */
  .solution-section { background: var(--color-surface); border-block: 1px solid var(--color-border); }

  .solution-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-20);
    align-items: start;
  }

  /* László — editorial rectangle, no circle */
  .laszlo-portrait {
    margin: var(--space-6) 0 var(--space-5);
  }

  .laszlo-img {
    display: block;
    width: 100%;
    max-width: 360px;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
  }

  .solution-body {
    margin: 0 0 var(--space-6);
    font-size: var(--fs-small);
    max-width: 52ch;
  }

  .solution-callout {
    border-left: 2px solid var(--color-accent);
    padding-left: var(--space-5);
    margin: var(--space-6) 0 var(--space-8);
    font-family: var(--font-display);
    font-size: var(--fs-body);
    font-weight: 300;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .differentiators {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
  }

  .diff-card {
    padding: var(--space-7) var(--space-8);
    border-bottom: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: var(--space-5);
    row-gap: var(--space-1);
  }

  .diff-card:last-child { border-bottom: none; }

  .diff-n {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-accent);
    grid-row: 1;
    grid-column: 1;
    padding-top: 0.1rem;
  }

  .diff-title {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--color-text);
    grid-row: 1;
    grid-column: 2;
  }

  .diff-body {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    line-height: 1.6;
    grid-row: 2;
    grid-column: 2;
    margin: 0;
    max-width: none;
  }

  /* ── Services Teaser ──────────────────────────────────────── */
  .services-teaser-section { border-top: 1px solid var(--color-border); }

  .services-teaser-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-10);
  }

  .services-teaser-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .svc-card {
    background: var(--color-surface);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    text-decoration: none;
    position: relative;
    transition: background 200ms ease;
    border-top: 2px solid transparent;
  }

  .svc-card:hover {
    background: var(--color-surface-2);
    border-top-color: var(--color-accent);
  }

  .svc-n {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-accent);
  }

  .svc-title {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .svc-tagline {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    line-height: 1.6;
    flex: 1;
    margin: 0;
  }

  .svc-arrow {
    font-size: var(--fs-small);
    color: var(--color-text-faint);
    transition: color 200ms ease, transform 200ms ease;
    display: inline-block;
    align-self: flex-start;
  }

  .svc-card:hover .svc-arrow {
    color: var(--color-accent);
    transform: translateX(4px);
  }

  /* ── Process ──────────────────────────────────────────────── */
  .process-steps {
    margin-top: var(--space-10);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .process-step {
    background: var(--color-surface);
    padding: var(--space-10) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .process-step-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .process-n {
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    font-weight: 300;
    color: var(--color-border);
    line-height: 0.9;
    letter-spacing: -0.04em;
    flex-shrink: 0;
  }

  .process-title {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .process-time {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-accent);
  }

  .process-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: 0;
  }

  .process-list li {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    padding-left: var(--space-4);
    position: relative;
    line-height: 1.5;
  }

  .process-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-border);
    font-size: var(--fs-xs);
  }

  /* ── CTA Banner ───────────────────────────────────────────── */
  .cta-banner {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-16);
    margin-top: var(--space-24);
  }

  .cta-banner-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .cta-h2 {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: 300;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .cta-sub {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ── Animations ───────────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .solution-inner         { grid-template-columns: 1fr; gap: var(--space-12); }
    .services-teaser-grid   { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .stats-grid             { grid-template-columns: repeat(2, 1fr); }
    .services-teaser-grid   { grid-template-columns: 1fr; }
    .process-steps          { grid-template-columns: 1fr; }
    .cta-banner-inner       { flex-direction: column; text-align: center; }
    .services-teaser-header { flex-direction: column; align-items: flex-start; gap: var(--space-4); }
    .featured-carousel-header { flex-direction: column; align-items: flex-start; gap: var(--space-3); }
    .laszlo-img             { max-width: 100%; }
  }
</style>
