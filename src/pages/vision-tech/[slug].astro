---
// src/pages/vision-tech/[slug].astro
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import Page from '../../layouts/Page.astro';
import SectionBanner from '../../components/ui/SectionBanner.astro';
import { thumbUrl } from '../../lib/image-url';
import Tour360 from '../../components/media/Tour360.astro';
import FilmEmbed from '../../components/media/FilmEmbed.astro';
import YouTubeEmbed from '../../components/media/YouTubeEmbed.astro';
import ImageLightbox from '../../components/media/ImageLightbox.tsx';
import MdxImageCompare from '../../components/mdx/ImageCompare.astro';
import MdxImageGallery from '../../components/mdx/ImageGallery.astro';
import MdxSectionBanner from '../../components/mdx/SectionBanner.astro';
import SingleImage from '../../components/mdx/SingleImage.astro';
import NotableGrid from '../../components/mdx/NotableGrid.astro';
import DeliverableGrid from '../../components/mdx/DeliverableGrid.astro';
import TimelineTable from '../../components/mdx/TimelineTable.astro';
import PhaseMatrix from '../../components/mdx/PhaseMatrix.astro';
import ArticleImageCompareMounter from '../../components/media/ArticleImageCompareMounter.tsx';
import ArticleGalleryMounter from '../../components/media/ArticleGalleryMounter.tsx';
import ProcessFlow from '../../components/mdx/ProcessFlow.astro';
import SpecTable from '../../components/mdx/SpecTable.astro';
import CompareTable from '../../components/mdx/CompareTable.astro';

export async function getStaticPaths() {
  const all = await getCollection('vision-tech', e => e.data.published !== false);
  return all.map(entry => ({ params: { slug: entry.slug } }));
}

const { slug } = Astro.params;
const all = await getCollection('vision-tech');
const entry = all.find(e => e.slug === slug);
if (!entry || entry.data.published === false) return Astro.redirect('/vision-tech/');
const { data } = entry;
const { Content } = await entry.render();

// Related portfolio projects
const allProjects = await getCollection('projects', p => p.data.published && !!p.data.coverImage);

// 1. Specific match: relatedCategories (subcategory) + relatedFeatures
const specificMatches = allProjects.filter(p => {
  const catMatch = data.relatedCategories.length === 0 ||
    data.relatedCategories.some(c => p.data.categories.some(pc => pc.id === c));
  const featMatch = data.relatedFeatures.length === 0 ||
    data.relatedFeatures.some(f => p.data.features.includes(f));
  return catMatch && featMatch;
}).sort((a, b) => b.data.year - a.data.year);

// 2. If fewer than 6 specific matches, fill with featured/recent projects
let related: typeof allProjects;
if (specificMatches.length >= 6) {
  related = specificMatches.slice(0, 8);
} else {
  const specificSlugs = new Set(specificMatches.map(p => p.slug));
  const fallback = allProjects
    .filter(p => !specificSlugs.has(p.slug))
    .sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0) || b.data.year - a.data.year);
  related = [...specificMatches, ...fallback].slice(0, 8);
}

// Resolve client names for related projects
const relatedClientNames = await Promise.all(
  related.map(async p => {
    if (!p.data.client) return undefined;
    const entry = await getEntry('clients', p.data.client.id);
    return entry?.data.title;
  })
);
---

<Page
  title={`${data.title} | Vision Graphics Technologies`}
  description={data.description}
  fullBleed
>

  <!-- ─── Hero ─────────────────────────────────────────────── -->
  <SectionBanner
    image={data.image}
    label={data.technique ?? 'Technique'}
    title={data.title}
    size="page"
    headingLevel="h1"
  />
  <div class="vt-breadcrumb container">
    <a href="/vision-tech/" class="vt-back">&larr; All Techniques</a>
  </div>

  <!-- ─── Description + inline fields ─────────────────────── -->
  <section class="section vt-desc-section">
    <div class="container">
      <p class="vt-tech-label">The technology:</p>
      <p class="vt-desc-body">{data.description}</p>

      <div class="vt-fields-row">
        <span class="vt-field">
          <span class="vt-field-label">Purpose:</span>
          <span class="vt-field-val">{data.purpose.join(' | ')}</span>
        </span>
        {data.technique && (
          <span class="vt-field">
            <span class="vt-field-label">Technical Approach:</span>
            <span class="vt-field-val">{data.technique}</span>
          </span>
        )}
        <span class="vt-field">
          <span class="vt-field-label">Reality:</span>
          <span class="vt-field-val">{data.reality}</span>
        </span>
      </div>

      <div class="vt-fields-row">
        <span class="vt-field">
          <span class="vt-field-label">Complexity:</span>
          <span class="vt-field-val">{data.complexity}</span>
        </span>
        <span class="vt-field">
          <span class="vt-field-label">Cost:</span>
          <span class="vt-field-val">{data.cost}</span>
        </span>
        <span class="vt-field">
          <span class="vt-field-label">3D Model:</span>
          <span class="vt-field-val">{data.model3d}</span>
        </span>
      </div>
    </div>
  </section>

  <section class="vt-block-section">
    <div class="container">
      <div class="vt-body-content">
        <Content components={{ Tour360, FilmEmbed, YouTubeEmbed, YoutubeEmbed: YouTubeEmbed, ImageCompare: MdxImageCompare, ImageGallery: MdxImageGallery, SectionBanner: MdxSectionBanner, SingleImage, ProcessFlow, SpecTable, CompareTable, NotableGrid, DeliverableGrid, TimelineTable, PhaseMatrix }} />
        <ArticleImageCompareMounter client:load />
        <ArticleGalleryMounter client:load />
      </div>
    </div>
  </section>

  <!-- CTA after all blocks -->
  <section class="vt-block-section">
    <div class="container">
      <a href="/contact/" class="btn btn-primary">Discuss Your Project</a>
    </div>
  </section>

  <!-- ─── Gallery ─────────────────────────────────────────── -->
  {data.gallery && data.gallery.length > 0 && (
    <section class="vt-gallery-section">
      <div class="container">
        <p class="section-label">Examples</p>
        <ImageLightbox images={data.gallery} title="Examples" client:load />
      </div>
    </section>
  )}

  <!-- ─── Related projects carousel ───────────────────────── -->
  {related.length > 0 && (
    <section class="vt-related-section">
      <div class="container">
        <p class="vt-related-heading">Related projects:</p>
        <div class="vt-carousel-wrap">
          <button class="vt-carousel-btn vt-carousel-prev" id="vt-prev" aria-label="Previous projects">&#8592;</button>
          <div class="vt-carousel" id="vt-carousel">
            {related.map(p => (
              <a href={`/portfolio/${p.slug}/`} class="vt-related-card">
                <div class="vt-card-img">
                  <img
                    src={thumbUrl(p.data.coverImage)}
                    alt={p.data.title}
                    loading="lazy"
                    onerror={`this.onerror=null;this.src='${p.data.coverImage}'`}
                  />
                </div>
                <div class="vt-card-body">
                  <span class="vt-card-title">{p.data.title}</span>
                </div>
              </a>
            ))}
          </div>
          <button class="vt-carousel-btn vt-carousel-next" id="vt-next" aria-label="Next projects">&#8594;</button>
        </div>
        <div class="vt-dots" id="vt-dots">
          {related.map((_, i) => (
            <button class={`vt-dot${i === 0 ? ' vt-dot--active' : ''}`} aria-label={`Go to project ${i + 1}`}></button>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ─── Nav to other techniques ──────────────────────────── -->
  <section class="section-sm vt-nav-section">
    <div class="container vt-nav-inner">
      <a href="/vision-tech/" class="btn btn-ghost">&larr; All Techniques</a>
      <a href="/contact/" class="btn btn-primary">Talk to Us</a>
    </div>
  </section>

</Page>

<script>
  const carousel = document.getElementById('vt-carousel') as HTMLElement | null;
  const dotsWrap = document.getElementById('vt-dots');
  const prevBtn  = document.getElementById('vt-prev');
  const nextBtn  = document.getElementById('vt-next');

  if (carousel) {
    const cards = carousel.querySelectorAll<HTMLElement>('.vt-related-card');
    const dots  = dotsWrap ? Array.from(dotsWrap.querySelectorAll<HTMLElement>('.vt-dot')) : [];
    const cardW = () => cards[0]?.offsetWidth ?? 300;

    const updateDots = () => {
      const idx = Math.round(carousel.scrollLeft / cardW());
      dots.forEach((d, i) => d.classList.toggle('vt-dot--active', i === idx));
    };

    prevBtn?.addEventListener('click', () => carousel.scrollBy({ left: -cardW(), behavior: 'smooth' }));
    nextBtn?.addEventListener('click', () => carousel.scrollBy({ left:  cardW(), behavior: 'smooth' }));

    carousel.addEventListener('scroll', updateDots, { passive: true });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => carousel.scrollTo({ left: cardW() * i, behavior: 'smooth' }));
    });
  }
</script>

<style>
  /* ─── Breadcrumb ────────────────────────────────────────── */
  .vt-breadcrumb {
    padding-block: var(--space-4);
  }

  .vt-back {
    display: inline-block;
    font-size: var(--fs-xs); letter-spacing: 0.08em;
    color: var(--color-text-muted); text-decoration: none;
    transition: color 200ms ease;
  }
  .vt-back:hover { color: var(--color-text); }

  /* ─── Description section ───────────────────────────────── */
  .vt-desc-section { padding-bottom: var(--space-8); }

  .vt-tech-label {
    font-size: var(--fs-body);
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .vt-desc-body {
    font-size: var(--fs-body);
    line-height: 1.75;
    color: var(--color-text-muted);
    max-width: 72ch;
    margin-bottom: var(--space-6);
  }

  /* ─── Inline data fields ────────────────────────────────── */
  .vt-fields-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2) var(--space-8);
    margin-top: var(--space-4);
  }

  .vt-field {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
  }

  .vt-field-label {
    font-size: var(--fs-small);
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .vt-field-val {
    font-size: var(--fs-small);
    font-weight: 700;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ─── Block sections ────────────────────────────────────── */
  .vt-block-section {
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  /* ─── Rich body content ─────────────────────────────────── */
  .vt-body-content { max-width: none; }

  .vt-body-content :global(h2) {
    font-size: var(--fs-h5); font-weight: 600;
    color: var(--color-text); margin: 2rem 0 0.6rem; line-height: 1.25;
  }
  .vt-body-content :global(h3) {
    font-size: var(--fs-body); font-weight: 600;
    color: var(--color-text); margin: 1.5rem 0 0.5rem;
  }
  .vt-body-content :global(p) {
    font-size: var(--fs-body); line-height: 1.75;
    color: var(--color-text-muted); margin: 0.6rem 0;
    max-width: none;
  }
  .vt-body-content :global(ul),
  .vt-body-content :global(ol) {
    margin: 0.6rem 0 0.6rem 1.25rem;
    display: flex; flex-direction: column; gap: 0.3rem;
  }
  .vt-body-content :global(li) {
    font-size: var(--fs-body); line-height: 1.65; color: var(--color-text-muted);
  }
  .vt-body-content :global(strong) { color: var(--color-text); font-weight: 600; }
  .vt-body-content :global(a) {
    color: var(--color-accent); text-decoration: none;
    border-bottom: 1px solid transparent; transition: border-color 150ms ease;
  }
  .vt-body-content :global(a:hover) { border-bottom-color: var(--color-accent); }

  /* ─── Gallery ───────────────────────────────────────────── */
  .vt-gallery-section { border-top: 1px solid var(--color-border); padding-block: 3rem; }
  .vt-gallery-section .section-label { margin-bottom: 1.5rem; }

  /* ─── Related projects carousel ─────────────────────────── */
  .vt-related-section {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-8);
  }

  .vt-related-heading {
    font-size: var(--fs-body);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  /* Carousel wrapper — positions prev/next buttons */
  .vt-carousel-wrap {
    position: relative;
    display: flex;
    align-items: stretch;
  }

  /* Scrollable strip */
  .vt-carousel {
    flex: 1;
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    /* 1px gaps between cards via outline trick */
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  .vt-carousel::-webkit-scrollbar { display: none; }

  /* Each card: thumbnail left + title right */
  .vt-related-card {
    flex: 0 0 clamp(200px, 25%, 400px);
    height: 90px;
    display: flex;
    text-decoration: none;
    scroll-snap-align: start;
    overflow: hidden;
    transition: filter 200ms ease;
  }
  .vt-related-card:hover { filter: brightness(1.12); }

  .vt-card-img {
    width: 38%;
    flex-shrink: 0;
    overflow: hidden;
  }
  .vt-card-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 350ms ease;
  }
  .vt-related-card:hover .vt-card-img img { transform: scale(1.07); }

  .vt-card-body {
    flex: 1;
    background: var(--color-surface);
    display: flex;
    align-items: center;
    padding: 0.5rem 0.85rem;
  }

  .vt-card-title {
    font-size: var(--fs-small);
    font-weight: 700;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.25;
  }

  /* Prev / Next buttons */
  .vt-carousel-btn {
    flex-shrink: 0;
    width: 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-inline: none;
    color: var(--color-text-muted);
    font-size: var(--fs-body);
    cursor: pointer;
    transition: color 200ms ease, background 200ms ease;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .vt-carousel-prev { border-right: none; }
  .vt-carousel-next { border-left: none; }
  .vt-carousel-btn:hover { color: var(--color-accent); background: var(--color-surface-2); }

  /* Dots */
  .vt-dots {
    display: flex;
    justify-content: center;
    gap: 0.4rem;
    margin-top: var(--space-4);
  }
  .vt-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--color-border);
    border: none; cursor: pointer; padding: 0;
    transition: background 200ms ease;
  }
  .vt-dot--active { background: var(--color-accent); }

  /* ─── Bottom nav ────────────────────────────────────────── */
  .vt-nav-section { border-top: 1px solid var(--color-border); }
  .vt-nav-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; }

  /* ─── Responsive ────────────────────────────────────────── */
  @media (max-width: 768px) {
    .vt-fields-row { gap: var(--space-2) var(--space-6); }
    .vt-related-card { flex: 0 0 clamp(180px, 50%, 280px); }
    .vt-nav-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
