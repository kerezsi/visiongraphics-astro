---
// src/pages/articles/[slug].astro

import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';
import ArticleImageCompareMounter from '../../components/media/ArticleImageCompareMounter.tsx';
import ArticleGalleryMounter from '../../components/media/ArticleGalleryMounter.tsx';
import SectionBanner from '../../components/mdx/SectionBanner.astro';
import ImageGallery from '../../components/mdx/ImageGallery.astro';
import ImageCompare from '../../components/mdx/ImageCompare.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => data.published);
  return articles.map(article => ({ params: { slug: article.slug } }));
}

const { slug } = Astro.params;
const allArticles = await getCollection('articles', ({ data }) => data.published);
const article = allArticles.find(a => a.slug === slug);
if (!article) return Astro.redirect('/articles/');
const { data } = article;
const { Content } = await article.render();

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('en-GB', {
    day: 'numeric', month: 'long', year: 'numeric',
  }).format(date);
}

// Adjacent articles for navigation
const sorted = [...allArticles].sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const currentIndex = sorted.findIndex(a => a.slug === article.slug);
const prevArticle = sorted[currentIndex + 1] ?? null;
const nextArticle = sorted[currentIndex - 1] ?? null;
---

<Page
  title={data.title}
  description={data.excerpt}
  image={data.coverImage}
  fullBleed
>
  <div class="article-page">
  <div class="container article-inner">

    <!-- Breadcrumb -->
    <div class="article-breadcrumb">
      <a href="/articles/">Articles</a>
      <span>→</span>
      <span>{data.title}</span>
    </div>

    <!-- Header -->
    <header class="article-header">
      <div class="article-meta">
        <time class="article-date" datetime={data.date.toISOString()}>
          {formatDate(data.date)}
        </time>
        {data.tags.length > 0 && (
          <div class="article-tags">
            {data.tags.map(tag => (
              <span class="article-tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
      <h1 class="display-lg article-h1">{data.title}</h1>
      <p class="article-excerpt">{data.excerpt}</p>
    </header>

    {data.coverImage && (
      <div class="article-cover">
        <img src={data.coverImage} alt={data.title} loading="eager" />
      </div>
    )}

    <!-- Content -->
    <div class="article-layout">
      <div class="article-content prose">
        <Content components={{ SectionBanner, ImageGallery, ImageCompare }} />
        <ArticleImageCompareMounter client:load />
        <ArticleGalleryMounter client:load />
      </div>

      <aside class="article-sidebar">
        <div class="sidebar-block">
          <h3 class="sidebar-label">About the author</h3>
          <p class="sidebar-author-name">László Kerezsi</p>
          <p class="sidebar-author-bio">
            Founder, Vision Graphics Kft. 30 years in architectural visualization,
            3ds Max since version 1, AI integration since it became useful.
          </p>
        </div>

        <div class="sidebar-block">
          <h3 class="sidebar-label">Contact</h3>
          <a href="/contact/" class="btn btn-primary sidebar-btn">Start a Project</a>
        </div>
      </aside>
    </div>

    <!-- Navigation -->
    <nav class="article-nav" aria-label="Article navigation">
      {prevArticle && (
        <a href={`/articles/${prevArticle.slug}/`} class="article-nav-link article-nav-link--prev">
          <span class="nav-dir">← Older</span>
          <span class="nav-title">{prevArticle.data.title}</span>
        </a>
      )}
      <a href="/articles/" class="article-nav-link article-nav-link--all">All Articles</a>
      {nextArticle && (
        <a href={`/articles/${nextArticle.slug}/`} class="article-nav-link article-nav-link--next">
          <span class="nav-dir">Newer →</span>
          <span class="nav-title">{nextArticle.data.title}</span>
        </a>
      )}
    </nav>

  </div>
  </div>
</Page>

<style>
  .article-page { width: 100%; }
  .article-inner { padding-block: clamp(3rem, 5vw, 5rem); }

  .article-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    margin-bottom: 2rem;
  }

  .article-breadcrumb a { color: var(--color-text-muted); text-decoration: none; transition: color 200ms; }
  .article-breadcrumb a:hover { color: var(--color-accent); }

  /* Header */
  .article-header { margin-bottom: 2rem; }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .article-date {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
  }

  .article-tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }

  .article-tag {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    border: 1px solid var(--color-border);
    padding: 0.15rem 0.45rem;
    border-radius: 1px;
  }

  .article-h1 { margin: 0 0 1rem; }

  .article-excerpt {
    font-size: var(--fs-body);
    color: var(--color-text-muted);
    max-width: 62ch;
    line-height: 1.65;
    margin: 0;
  }

  /* Cover */
  .article-cover {
    margin-bottom: 3rem;
    aspect-ratio: 16/7;
    overflow: hidden;
    background: var(--color-surface-2);
    border-radius: var(--radius-sm);
  }

  .article-cover img { width: 100%; height: 100%; object-fit: cover; }

  /* Layout */
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 4rem;
    align-items: start;
  }

  /* Section banner blocks inside article prose */
  .article-content.prose :global(.article-section-banner) {
    position: relative;
    height: clamp(80px, 14vw, 180px);
    background-size: cover;
    background-position: center;
    overflow: hidden;
    border-radius: var(--radius-sm);
    margin: 2rem 0;
    display: flex;
    align-items: flex-end;
  }

  .article-content.prose :global(.article-section-banner__overlay) {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 100%);
  }
  :global([data-theme="light"]) .article-content.prose :global(.article-section-banner__overlay) {
    background: linear-gradient(to top, rgba(247,245,242,0.88) 0%, rgba(247,245,242,0.25) 100%);
  }

  .article-content.prose :global(.article-section-banner__content) {
    position: relative;
    padding: 0.75rem 1rem;
    z-index: 1;
  }

  .article-content.prose :global(.article-section-banner__label) {
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.25rem;
  }

  .article-content.prose :global(.article-section-banner__title) {
    font-size: var(--fs-h5);
    font-weight: 300;
    color: var(--color-text);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  /* Prose content */
  .article-content.prose {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 65ch;
  }

  .article-content.prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: 300;
    color: var(--color-text);
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.01em;
  }

  .article-content.prose :global(h3) {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    font-weight: 500;
    color: var(--color-text);
    margin: 2rem 0 0.75rem;
  }

  .article-content.prose :global(p) {
    margin-bottom: 1.25rem;
    max-width: none;
  }

  .article-content.prose :global(ul),
  .article-content.prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .article-content.prose :global(li) {
    margin-bottom: 0.4rem;
    color: var(--color-text-muted);
    font-size: var(--fs-small);
  }

  .article-content.prose :global(code) {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    background: var(--color-surface-2);
    padding: 0.1rem 0.35rem;
    border-radius: 2px;
    color: var(--color-accent);
  }

  .article-content.prose :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--fs-body);
    color: var(--color-text-muted);
  }

  /* Sidebar */
  .article-sidebar {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    top: 5rem;
  }

  .sidebar-block { display: flex; flex-direction: column; gap: 0.6rem; }

  .sidebar-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .sidebar-author-name {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
    max-width: none;
  }

  .sidebar-author-bio {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
    max-width: none;
  }

  .sidebar-btn { width: 100%; justify-content: center; }

  /* Navigation */
  .article-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    gap: 1rem;
  }

  .article-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    transition: color 200ms;
    max-width: 35%;
  }

  .article-nav-link--all {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    flex-direction: row;
    align-items: center;
    max-width: none;
  }

  .article-nav-link--all:hover { color: var(--color-text); }
  .article-nav-link--next { text-align: right; align-items: flex-end; }

  .nav-dir {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .nav-title {
    font-family: var(--font-display);
    font-size: var(--fs-body);
    color: var(--color-text-muted);
    line-height: 1.3;
    transition: color 200ms;
  }

  .article-nav-link:hover .nav-title { color: var(--color-accent); }

  /* Responsive */
  @media (max-width: 900px) {
    .article-layout { grid-template-columns: 1fr; }
    .article-sidebar { position: static; }
  }
</style>
