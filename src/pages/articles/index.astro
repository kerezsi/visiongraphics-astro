---
// src/pages/articles/index.astro

import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => data.published);
const articles = allArticles.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('en-GB', {
    day: 'numeric', month: 'long', year: 'numeric',
  }).format(date);
}
---

<Page
  title="Articles"
  description="Insights on architectural visualization, AI in production workflows, 3ds Max, V-Ray, and the business of building imagery. Vision Graphics Kft."
>
  <div class="articles-page">

    <div class="articles-header">
      <p class="section-label">Writing</p>
      <h1 class="display-lg articles-h1">Articles</h1>
      <p class="articles-intro">
        Notes from 30 years in architectural visualization — on tools, workflows,
        AI integration, and the business of making imagery that works.
      </p>
    </div>

    {articles.length > 0 ? (
      <div class="articles-list">
        {articles.map((article, i) => (
          <a href={`/articles/${article.slug}/`} class:list={['article-item', { 'article-item--featured': i === 0 }]}>
            {article.data.coverImage && (
              <div class="article-image">
                <img
                  src={article.data.coverImage}
                  alt={article.data.title}
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              </div>
            )}
            <div class="article-body">
              <div class="article-meta">
                <time class="article-date" datetime={article.data.date.toISOString()}>
                  {formatDate(article.data.date)}
                </time>
                {article.data.tags.length > 0 && (
                  <div class="article-tags">
                    {article.data.tags.slice(0, 3).map(tag => (
                      <span class="article-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              <h2 class="article-title">{article.data.title}</h2>
              <p class="article-excerpt">{article.data.excerpt}</p>
              <span class="article-read-more">Read article →</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="articles-empty">
        <p>Articles coming soon.</p>
        <p class="articles-empty-sub">
          In the meantime, see our <a href="/faq/">FAQ</a> for answers to common questions,
          or <a href="/contact/">get in touch</a> directly.
        </p>
      </div>
    )}

  </div>
</Page>

<style>
  .articles-page { max-width: 820px; }

  .articles-header { margin-bottom: 3rem; }

  .articles-h1 { margin: 0.75rem 0 1.25rem; }

  .articles-intro {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    max-width: 55ch;
    line-height: 1.7;
    margin: 0;
  }

  /* List */
  .articles-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .article-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding-block: 2rem;
    border-top: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition: background 200ms;
  }

  .article-item:last-child { border-bottom: 1px solid var(--color-border); }

  .article-item--featured {
    grid-template-columns: 1fr 1fr;
  }

  .article-item:hover .article-title { color: var(--color-accent); }

  .article-image {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--color-surface-2);
    border-radius: var(--radius-sm);
  }

  .article-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }

  .article-item:hover .article-image img { transform: scale(1.03); }

  .article-body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    justify-content: center;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .article-date {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-text-faint);
  }

  .article-tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }

  .article-tag {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    border: 1px solid var(--color-border);
    padding: 0.15rem 0.45rem;
    border-radius: 1px;
  }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 300;
    color: var(--color-text);
    line-height: 1.15;
    letter-spacing: -0.01em;
    transition: color 200ms;
    margin: 0;
  }

  .article-excerpt {
    font-size: 0.87rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
    max-width: 60ch;
  }

  .article-read-more {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.03em;
    margin-top: 0.25rem;
  }

  /* Empty state */
  .articles-empty {
    padding: 4rem 0;
    border-top: 1px solid var(--color-border);
  }

  .articles-empty p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
    max-width: none;
  }

  .articles-empty-sub { font-size: 0.82rem !important; }

  .articles-empty a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 640px) {
    .article-item--featured { grid-template-columns: 1fr; }
  }
</style>
