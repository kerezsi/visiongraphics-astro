---
// src/pages/portfolio/[slug].astro

import Page from '../../layouts/Page.astro';
import FilmEmbed from '../../components/media/FilmEmbed.astro';
import Tour360 from '../../components/media/Tour360.astro';
import YouTubeEmbed from '../../components/media/YouTubeEmbed.astro';
import ImageLightbox from '../../components/media/ImageLightbox';
import ImageGallery from '../../components/mdx/ImageGallery.astro';
import ImageCompare from '../../components/mdx/ImageCompare.astro';
import MdxSectionBanner from '../../components/mdx/SectionBanner.astro';
import ProjectDescription from '../../components/mdx/ProjectDescription.astro';
import ProjectStory from '../../components/mdx/ProjectStory.astro';
import ProjectTasks from '../../components/mdx/ProjectTasks.astro';
import ArticleGalleryMounter from '../../components/media/ArticleGalleryMounter.tsx';
import ArticleImageCompareMounter from '../../components/media/ArticleImageCompareMounter.tsx';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => data.published);
  return projects.map(project => ({ params: { slug: project.slug } }));
}

const { slug } = Astro.params;
const allProjects = await getCollection('projects', ({ data }) => data.published);
const project = allProjects.find(p => p.slug === slug);
if (!project) return Astro.redirect('/portfolio/');
const { data } = project;
const { Content } = await project.render();

// Resolve category references to { id, title } objects
const resolvedCategories = await Promise.all(
  data.categories.map(async ref => {
    const entry = await getEntry('categories', ref.id);
    return { id: ref.id, title: entry?.data.title ?? ref.id };
  })
);

// Resolve optional client/designer/location references to display strings
const clientTitle   = data.client   ? (await getEntry('clients',   data.client.id))?.data.title   : undefined;
const designerTitle = data.designer ? (await getEntry('designers', data.designer.id))?.data.title : undefined;
const cityTitle     = data.city     ? (await getEntry('cities',    data.city.id))?.data.title     : undefined;
const countryTitle  = data.country  ? (await getEntry('countries', data.country.id))?.data.title  : undefined;
const locationStr   = [cityTitle, countryTitle].filter(Boolean).join(', ') || undefined;

// Adjacent projects for prev/next navigation
const sorted = allProjects.sort((a, b) => b.data.year - a.data.year);
const currentIndex = sorted.findIndex(p => p.slug === project.slug);
const prevProject = sorted[currentIndex + 1] ?? null;
const nextProject = sorted[currentIndex - 1] ?? null;

// Format a technique slug for display: "360-tour" → "360 TOUR"
function formatTech(slug: string): string {
  return slug.replace(/-/g, '\u00A0').toUpperCase();
}
---

<Page
  title={data.title}
  description={data.description ?? `${data.title} — architectural visualization by Vision Graphics Kft.`}
  image={data.coverImage}
  fullBleed
>
  <!-- Hero image -->
  <div class="project-hero">
    <img
      src={data.coverImage}
      alt={data.title}
      class="project-hero-img"
      loading="eager"
    />
    <div class="project-hero-overlay">
      <div class="container">
        <div class="project-hero-meta">
          <a href="/portfolio/" class="back-link">← Portfolio</a>
          <div class="project-cats">
            {resolvedCategories.map(cat => (
              <a href={`/portfolio/category/${cat.id}/`} class="project-cat-tag">
                {cat.title}
              </a>
            ))}
          </div>
        </div>
        <h1 class="project-title">{data.title}</h1>
        <div class="project-subtitle-row">
          <span class="project-year">{data.year}</span>
          {clientTitle  && <span class="project-client">{clientTitle}</span>}
          {locationStr  && <span class="project-location">{locationStr}</span>}
        </div>
      </div>
    </div>
  </div>

  <!-- Single-column content area -->
  <div class="project-content-area container">

    <!-- "The Project:" section -->
    <div class="project-intro">
      <h2 class="project-red-heading">The Project:</h2>
      {data.description && (
        <p class="project-description">{data.description}</p>
      )}
      <div class="project-data-line">
        {resolvedCategories.length > 0 && (
          <span class="data-item">
            <span class="data-label">Field:</span>
            <span class="data-value">{resolvedCategories.map(c => c.title).join(' | ')}</span>
          </span>
        )}
        <span class="data-item">
          <span class="data-label">Date:</span>
          <span class="data-value">{data.year}</span>
        </span>
        {locationStr && (
          <span class="data-item">
            <span class="data-label">Location:</span>
            <span class="data-value">{locationStr}</span>
          </span>
        )}
        {clientTitle && (
          <span class="data-item">
            <span class="data-label">Client:</span>
            <span class="data-value">{clientTitle}</span>
          </span>
        )}
        {designerTitle && (
          <span class="data-item">
            <span class="data-label">Architect | Designer:</span>
            <span class="data-value">{designerTitle}</span>
          </span>
        )}
      </div>
    </div>

    <!-- "The Task:" section header + techniques -->
    <div class="project-task-header">
      <h2 class="project-red-heading">The Task:</h2>
      {data.techniques && data.techniques.length > 0 && (
        <div class="techniques-bar">
          {data.techniques.map((t: string, i: number) => (
            <>
              {i > 0 && <span class="tech-sep"> | </span>}
              <a href={`/vision-tech/${t}/`} class="tech-item">{formatTech(t)}</a>
            </>
          ))}
        </div>
      )}
    </div>

    <!-- MDX body: ProjectTasks text → media → ProjectStory -->
    <div class="project-content">
      <Content components={{ ImageGallery, ImageCompare, Tour360, FilmEmbed, YouTubeEmbed, YoutubeEmbed: YouTubeEmbed, SectionBanner: MdxSectionBanner, ProjectDescription, ProjectStory, ProjectTasks }} />
      <ArticleGalleryMounter client:load />
      <ArticleImageCompareMounter client:load />
    </div>

    <!-- CTA block -->
    <div class="project-cta">
      <p>Similar project in mind?</p>
      <a href="/contact/" class="btn btn-primary">Talk to Us</a>
    </div>

    <!-- Project navigation -->
    <nav class="project-nav" aria-label="Project navigation">
      {prevProject && (
        <a href={`/portfolio/${prevProject.slug}/`} class="project-nav-link project-nav-link--prev">
          <span class="nav-dir">← Previous</span>
          <span class="nav-title">{prevProject.data.title}</span>
        </a>
      )}
      <a href="/portfolio/" class="project-nav-link project-nav-link--all">All Projects</a>
      {nextProject && (
        <a href={`/portfolio/${nextProject.slug}/`} class="project-nav-link project-nav-link--next">
          <span class="nav-dir">Next →</span>
          <span class="nav-title">{nextProject.data.title}</span>
        </a>
      )}
    </nav>

  </div>
</Page>

<style>
  /* =====================
     Hero
     ===================== */
  .project-hero {
    position: relative;
    height: 70vh;
    min-height: 400px;
    overflow: hidden;
  }

  .project-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.45);
  }

  .project-hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: linear-gradient(to top, rgba(10,10,18,0.92) 0%, rgba(10,10,18,0.2) 50%, transparent 80%);
    padding-bottom: 3rem;
  }

  .project-hero-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .back-link {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 200ms ease;
    letter-spacing: 0.05em;
  }
  .back-link:hover { color: var(--color-text); }

  .project-cats { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .project-cat-tag {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    border: 1px solid rgba(218, 19, 19, 0.4);
    padding: 0.2rem 0.5rem;
    border-radius: 1px;
    transition: all 200ms ease;
  }
  .project-cat-tag:hover {
    background: rgba(218, 19, 19, 0.12);
    border-color: var(--color-accent);
  }

  .project-title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 0.75rem;
  }

  .project-subtitle-row {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
  }

  /* =====================
     Content area
     ===================== */
  .project-content-area {
    padding-block-end: var(--space-16);
  }

  /* =====================
     Red section headings
     ===================== */
  .project-red-heading {
    font-family: var(--font-display);
    font-size: var(--fs-h4);
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  /* =====================
     "The Project:" section
     ===================== */
  .project-intro {
    padding-top: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .project-description {
    font-size: var(--fs-body);
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: 1.25rem;
    max-width: 68ch;
  }

  .project-data-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 2rem;
  }

  .data-item {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    display: flex;
    gap: 0.4em;
    align-items: baseline;
  }

  .data-label {
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-size: var(--fs-xs);
    white-space: nowrap;
  }

  .data-value {
    color: var(--color-text);
  }

  /* =====================
     "The Task:" section header
     ===================== */
  .project-task-header {
    margin-bottom: 1.5rem;
  }

  .techniques-bar {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .tech-item {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 150ms;
  }
  .tech-item:hover { color: var(--color-accent); }

  .tech-sep {
    color: var(--color-text-faint);
  }

  /* =====================
     MDX body content
     ===================== */
  .project-content {
    margin-bottom: 2rem;
  }

  /* SectionBanner inside MDX body: full viewport width */
  .project-content :global(.article-section-banner) {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin-inline: 0;
  }

  /* =====================
     CTA block
     ===================== */
  .project-cta {
    margin-block: 3rem;
    padding: 2rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    text-align: center;
  }

  .project-cta p {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    max-width: none;
  }

  /* =====================
     Project navigation
     ===================== */
  .project-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    gap: 1rem;
  }

  .project-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    transition: color 200ms;
    max-width: 35%;
  }

  .nav-dir {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    letter-spacing: 0.1em;
  }

  .nav-title {
    font-family: var(--font-display);
    font-size: var(--fs-body);
    color: var(--color-text-muted);
    transition: color 200ms;
  }

  .project-nav-link:hover .nav-title { color: var(--color-accent); }

  .project-nav-link--all {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    flex-direction: row;
    align-items: center;
    max-width: none;
  }
  .project-nav-link--all:hover { color: var(--color-text); }

  .project-nav-link--next {
    text-align: right;
    align-items: flex-end;
  }
</style>
