---
// src/pages/pricing/index.astro

import Page from '../../layouts/Page.astro';

const packages = [
  {
    name: 'Essential',
    price: 'from €5,000',
    desc: 'Single building or product. Standard delivery. Perfect for planning applications, property launches, and single-phase presentations.',
    includes: [
      'Up to 5 still images',
      'Two rounds of client feedback',
      'High-resolution TIFF + web JPG',
      'Standard 2–3 week timeline',
    ],
    cta: 'Get a Quote',
    href: '/contact/',
    highlight: false,
  },
  {
    name: 'Professional',
    price: 'from €15,000',
    desc: 'Full visualization package for multi-phase projects or marketing campaigns. Animation included. Faster delivery.',
    includes: [
      'Up to 15 still images',
      'Short animation (up to 90 sec)',
      '360° tour option',
      'Accelerated 1–2 week timeline',
      'Three rounds of client feedback',
    ],
    cta: 'Get a Quote',
    href: '/contact/',
    highlight: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    desc: 'Airport-scale, urban masterplan, or multi-phase integrated marketing. Scoped individually. László as single point of contact throughout.',
    includes: [
      'Unlimited scope by agreement',
      '4K animation',
      'VR walkthrough',
      'Dedicated timeline',
      'Specialist network as required',
    ],
    cta: 'Talk to Us',
    href: '/contact/',
    highlight: false,
  },
];
---

<Page
  title="Pricing"
  description="Transparent pricing for architectural visualization. Essential from €5,000, Professional from €15,000, Enterprise custom. Vision Graphics Kft., Budapest."
>

  <PageHero
    image="/_img/banners/banner-general.jpg"
    label="Transparent Pricing"
    title="No Surprises."
  />
  <div class="pricing-page">

    <!-- Header -->
    <div class="pricing-header">
      <p class="section-label">Pricing</p>
      <h1 class="display-lg pricing-h1">Transparent Pricing.<br /><em>No Surprises.</em></h1>
      <p class="pricing-intro">
        We quote based on actual scope, not package tiers.
        The tiers below are starting points for conversation.
      </p>
    </div>

    <!-- Package cards -->
    <div class="packages">
      {packages.map(pkg => (
        <div class:list={['package', { 'package--featured': pkg.highlight }]}>
          {pkg.highlight && (
            <div class="package-badge">Most common</div>
          )}
          <div class="package-top">
            <h2 class="package-name">{pkg.name}</h2>
            <span class="package-price">{pkg.price}</span>
          </div>
          <p class="package-desc">{pkg.desc}</p>
          <ul class="package-includes">
            {pkg.includes.map(item => <li>{item}</li>)}
          </ul>
          <a href={pkg.href} class:list={['btn', pkg.highlight ? 'btn-primary' : 'btn-secondary', 'package-cta']}>
            {pkg.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Line-item reference pricing -->
    <div class="line-items">
      <h2 class="line-items-title">Reference Pricing</h2>
      <p class="line-items-intro">
        Every project is quoted individually. The figures below give you a concrete sense
        of what individual deliverables cost — use them to build a rough estimate before we talk.
      </p>

      <div class="price-categories">

        <div class="price-cat">
          <h3 class="price-cat-title">3D Modeling</h3>
          <div class="price-rows">
            <div class="price-row">
              <span class="price-code">A1</span>
              <span class="price-item">Base 3D model — exterior from plans, geometric precision</span>
              <span class="price-val">€2,300–5,000+</span>
            </div>
          </div>
        </div>

        <div class="price-cat">
          <h3 class="price-cat-title">Exterior Visualization</h3>
          <div class="price-rows">
            <div class="price-row">
              <span class="price-code">B1</span>
              <span class="price-item">Daytime renders — set of 5 photorealistic exterior views</span>
              <span class="price-val">€980</span>
            </div>
            <div class="price-row">
              <span class="price-code">B2</span>
              <span class="price-item">Night version — evening/night lighting variations</span>
              <span class="price-val">€700</span>
            </div>
            <div class="price-row">
              <span class="price-code">B3</span>
              <span class="price-item">Extra exterior views</span>
              <span class="price-val">€195/image</span>
            </div>
            <div class="price-row">
              <span class="price-code">B4</span>
              <span class="price-item">360° tour — 5 viewpoints, 3D environment, web/VR compatible</span>
              <span class="price-val">€1,525</span>
            </div>
            <div class="price-row">
              <span class="price-code">B5</span>
              <span class="price-item">Extra panoramic viewpoints</span>
              <span class="price-val">€145/viewpoint</span>
            </div>
            <div class="price-row">
              <span class="price-code">B6</span>
              <span class="price-item">Photo integration into photographed panoramas</span>
              <span class="price-val">€115/viewpoint</span>
            </div>
          </div>
        </div>

        <div class="price-cat">
          <h3 class="price-cat-title">Interior Visualization</h3>
          <div class="price-rows">
            <div class="price-row">
              <span class="price-code">C1</span>
              <span class="price-item">Studio unit — 3–4 stills + 3–4 viewpoint panorama tour</span>
              <span class="price-val">€1,725/unit</span>
            </div>
            <div class="price-row">
              <span class="price-code">C2</span>
              <span class="price-item">1-bed unit — 5–7 stills + 5–7 viewpoint panorama tour</span>
              <span class="price-val">€2,025/unit</span>
            </div>
            <div class="price-row">
              <span class="price-code">C3</span>
              <span class="price-item">2-bed unit — 7–9 stills + 6–8 viewpoint panorama tour</span>
              <span class="price-val">€2,400/unit</span>
            </div>
            <div class="price-row">
              <span class="price-code">C4</span>
              <span class="price-item">3-bed unit — 8–11 stills + 7–9 viewpoint panorama tour</span>
              <span class="price-val">€2,775/unit</span>
            </div>
            <div class="price-row">
              <span class="price-code">C5</span>
              <span class="price-item">Common areas — lobby and corridor with panorama tour</span>
              <span class="price-val">€500–2,000+</span>
            </div>
          </div>
        </div>

        <div class="price-cat">
          <h3 class="price-cat-title">Floor Plans</h3>
          <div class="price-rows">
            <div class="price-row">
              <span class="price-code">D1</span>
              <span class="price-item">Unique floor plan</span>
              <span class="price-val">€82/plan</span>
            </div>
            <div class="price-row">
              <span class="price-code">D2</span>
              <span class="price-item">Variant plan</span>
              <span class="price-val">€44/plan</span>
            </div>
            <div class="price-row">
              <span class="price-code">D3</span>
              <span class="price-item">Copy plan</span>
              <span class="price-val">€4/plan</span>
            </div>
            <div class="price-row">
              <span class="price-code">D4</span>
              <span class="price-item">Sales sheet</span>
              <span class="price-val">€115</span>
            </div>
            <div class="price-row">
              <span class="price-code">D5</span>
              <span class="price-item">Sheet assembly</span>
              <span class="price-val">€40/unit</span>
            </div>
          </div>
        </div>

        <div class="price-cat">
          <h3 class="price-cat-title">Animation</h3>
          <div class="price-rows">
            <div class="price-row">
              <span class="price-code">E1</span>
              <span class="price-item">Base film — 1.5-minute HD animation with people and vehicles</span>
              <span class="price-val">€8,000</span>
            </div>
            <div class="price-row">
              <span class="price-code">E2</span>
              <span class="price-item">Extra animation footage</span>
              <span class="price-val">€90/second</span>
            </div>
          </div>
        </div>

        <div class="price-cat">
          <h3 class="price-cat-title">Interactive</h3>
          <div class="price-rows">
            <div class="price-row">
              <span class="price-code">F1</span>
              <span class="price-item">VR app integration — full integration with automated views</span>
              <span class="price-val">€8,000</span>
            </div>
          </div>
        </div>

      </div>

      <p class="line-items-note">
        All prices ex. VAT. Payment: 30–40% deposit, milestone payments, balance on delivery.
        Rush timelines available — additional fees apply. NDAs signed on request.
      </p>
    </div>

    <!-- What drives cost -->
    <div class="cost-factors">
      <div class="cost-col">
        <h2 class="cost-col-title">What drives cost up</h2>
        <ul class="cost-list cost-list--up">
          <li>Animation vs. stills — significantly more</li>
          <li>Number of unique camera angles</li>
          <li>Interior detail level (furniture, materials)</li>
          <li>Tight deadlines</li>
          <li>Multiple revision rounds beyond the included set</li>
        </ul>
      </div>
      <div class="cost-col">
        <h2 class="cost-col-title">What keeps cost down</h2>
        <ul class="cost-list cost-list--down">
          <li>Clear brief upfront</li>
          <li>Good source materials (CAD, not sketches)</li>
          <li>Flexible timeline</li>
          <li>AI-assisted workflows where appropriate</li>
        </ul>
      </div>
    </div>

    <!-- CTA banner -->
    <div class="pricing-cta">
      <div class="pricing-cta-text">
        <h2 class="pricing-cta-h2">Not sure which fits?</h2>
        <p>30-minute consultation, no charge. We scope the project together.</p>
      </div>
      <a href="/contact/" class="btn btn-primary">Get in Touch</a>
    </div>

  </div>
</Page>

<style>
  .pricing-page { max-width: 1000px; }

  /* Header */
  .pricing-header { margin-bottom: 3rem; }

  .pricing-h1 {
    margin: 0.75rem 0 1.25rem;
  }

  .pricing-h1 em {
    font-style: italic;
    color: var(--color-accent);
  }

  .pricing-intro {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    max-width: 52ch;
    line-height: 1.7;
    margin: 0;
  }

  /* Packages */
  .packages {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    margin-bottom: 4rem;
  }

  .package {
    background: var(--color-surface);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    transition: background 200ms ease;
  }

  .package--featured {
    background: var(--color-surface-2);
  }

  .package-badge {
    position: absolute;
    top: -1px;
    left: 2rem;
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-bg);
    background: var(--color-accent);
    padding: 0.2rem 0.6rem;
  }

  .package-top {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-top: 1rem;
  }

  .package-name {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .package-price {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .package-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
    max-width: none;
  }

  .package-includes {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
    margin: 0;
  }

  .package-includes li {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    padding-left: 1.1rem;
    position: relative;
    line-height: 1.4;
  }

  .package-includes li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.65rem;
  }

  .package-cta { margin-top: auto; width: 100%; justify-content: center; }

  /* Line items */
  .line-items {
    margin-bottom: 4rem;
  }

  .line-items-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .line-items-intro {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    max-width: 62ch;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .price-categories {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
  }

  .price-cat {
    border-bottom: 1px solid var(--color-border);
  }

  .price-cat:last-child { border-bottom: none; }

  .price-cat-title {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    padding: 0.75rem 1.25rem;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .price-rows { display: flex; flex-direction: column; }

  .price-row {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: 1rem;
    align-items: baseline;
    padding: 0.65rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    transition: background 150ms;
  }

  .price-row:last-child { border-bottom: none; }
  .price-row:hover { background: var(--color-surface); }

  .price-code {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-accent);
    white-space: nowrap;
  }

  .price-item {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .price-val {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text);
    white-space: nowrap;
    text-align: right;
  }

  .line-items-note {
    font-size: 0.75rem;
    color: var(--color-text-faint);
    margin-top: 1rem;
    line-height: 1.6;
  }

  /* Cost factors */
  .cost-factors {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .cost-col { background: var(--color-surface); padding: 2rem; }

  .cost-col-title {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin-bottom: 1rem;
  }

  .cost-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cost-list li {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.4;
  }

  .cost-list--up li::before {
    content: '↑';
    position: absolute;
    left: 0;
    color: var(--color-accent-2);
    font-size: 0.7rem;
  }

  .cost-list--down li::before {
    content: '↓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.7rem;
  }

  /* CTA */
  .pricing-cta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    padding: 2.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    flex-wrap: wrap;
  }

  .pricing-cta-h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--color-text);
    margin-bottom: 0.4rem;
  }

  .pricing-cta-text p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
    max-width: none;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .packages { grid-template-columns: 1fr; }
    .cost-factors { grid-template-columns: 1fr; }
    .pricing-cta { flex-direction: column; }
  }
</style>
