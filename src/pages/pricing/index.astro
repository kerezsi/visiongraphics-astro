---
// src/pages/pricing/index.astro

import Page from '../../layouts/Page.astro';
import SectionBanner from '../../components/ui/SectionBanner.astro';
import packages from '../../data/pricing-packages.json';
import reference from '../../data/pricing-reference.json';
---

<Page
  title="Pricing"
  description="Transparent pricing for architectural visualization. Essential from €5,000, Professional from €15,000, Enterprise custom. Vision Graphics Kft., Budapest."
  fullBleed
>
  <div class="pricing-page">

    <SectionBanner
      image="/_img/banners/banner-general.jpg"
      label="Investment"
      title="Pricing"
      size="page"
      headingLevel="h1"
    />

    <section class="pricing-section section">
    <div class="container">

    <!-- Header -->
    <div class="pricing-header">
      <p class="section-label">Pricing</p>
      <h2 class="display-lg pricing-h2">Transparent Pricing.<br /><em>No Surprises.</em></h2>
      <p class="pricing-intro">
        We quote based on actual scope, not package tiers.
        The tiers below are starting points for conversation.
      </p>
    </div>

    <!-- Package cards -->
    <div class="packages">
      {packages.map(pkg => (
        <div class:list={['package', { 'package--featured': pkg.highlight }]}>
          {pkg.highlight && (
            <div class="package-badge">Most common</div>
          )}
          <div class="package-top">
            <h2 class="package-name">{pkg.name}</h2>
            <span class="package-price">{pkg.price}</span>
          </div>
          <p class="package-desc">{pkg.desc}</p>
          <ul class="package-includes">
            {pkg.includes.map(item => <li>{item}</li>)}
          </ul>
          <a href={pkg.href} class:list={['btn', pkg.highlight ? 'btn-primary' : 'btn-secondary', 'package-cta']}>
            {pkg.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Line-item reference pricing -->
    <div class="line-items">
      <h2 class="line-items-title">Reference Pricing</h2>
      <p class="line-items-intro">{reference.intro}</p>

      <div class="price-categories">
        {reference.categories.map(cat => (
          <div class="price-cat">
            <h3 class="price-cat-title">{cat.title}</h3>
            <div class="price-rows">
              {cat.rows.map(row => (
                <div class="price-row">
                  <span class="price-code">{row.code}</span>
                  <span class="price-item">{row.item}</span>
                  <span class="price-val">{row.value}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <p class="line-items-note">{reference.note}</p>
    </div>

    <!-- What drives cost -->
    <div class="cost-factors">
      <div class="cost-col">
        <h2 class="cost-col-title">What drives cost up</h2>
        <ul class="cost-list cost-list--up">
          <li>Animation vs. stills — significantly more</li>
          <li>Number of unique camera angles</li>
          <li>Interior detail level (furniture, materials)</li>
          <li>Tight deadlines</li>
          <li>Multiple revision rounds beyond the included set</li>
        </ul>
      </div>
      <div class="cost-col">
        <h2 class="cost-col-title">What keeps cost down</h2>
        <ul class="cost-list cost-list--down">
          <li>Clear brief upfront</li>
          <li>Good source materials (CAD, not sketches)</li>
          <li>Flexible timeline</li>
          <li>AI-assisted workflows where appropriate</li>
        </ul>
      </div>
    </div>

    <!-- CTA banner -->
    <div class="pricing-cta">
      <div class="pricing-cta-text">
        <h2 class="pricing-cta-h2">Not sure which fits?</h2>
        <p>30-minute consultation, no charge. We scope the project together.</p>
      </div>
      <a href="/contact/" class="btn btn-primary">Get in Touch</a>
    </div>

    </div>
    </section>
  </div>
</Page>

<style>
  .pricing-page { width: 100%; }
  .pricing-section { padding-block: clamp(3rem, 5vw, 5rem); }

  /* Header */
  .pricing-header { margin-bottom: 3rem; }

  .pricing-intro {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    max-width: 52ch;
    line-height: 1.7;
    margin: 0;
  }

  /* Packages */
  .packages {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    margin-bottom: 4rem;
  }

  .package {
    background: var(--color-surface);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    transition: background 200ms ease;
  }

  .package--featured {
    background: var(--color-surface-2);
  }

  .package-badge {
    position: absolute;
    top: -1px;
    left: 2rem;
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-bg);
    background: var(--color-accent);
    padding: 0.2rem 0.6rem;
  }

  .package-top {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-top: 1rem;
  }

  .package-name {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .package-price {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .package-desc {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
    max-width: none;
  }

  .package-includes {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
    margin: 0;
  }

  .package-includes li {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    padding-left: 1.1rem;
    position: relative;
    line-height: 1.4;
  }

  .package-includes li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: var(--fs-xs);
  }

  .package-cta { margin-top: auto; width: 100%; justify-content: center; }

  /* Line items */
  .line-items {
    margin-bottom: 4rem;
  }

  .line-items-title {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: 300;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .line-items-intro {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    max-width: 62ch;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .price-categories {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
  }

  .price-cat {
    border-bottom: 1px solid var(--color-border);
  }

  .price-cat:last-child { border-bottom: none; }

  .price-cat-title {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    padding: 0.75rem 1.25rem;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .price-rows { display: flex; flex-direction: column; }

  .price-row {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: 1rem;
    align-items: baseline;
    padding: 0.65rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    transition: background 150ms;
  }

  .price-row:last-child { border-bottom: none; }
  .price-row:hover { background: var(--color-surface); }

  .price-code {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-accent);
    white-space: nowrap;
  }

  .price-item {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .price-val {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text);
    white-space: nowrap;
    text-align: right;
  }

  .line-items-note {
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    margin-top: 1rem;
    line-height: 1.6;
  }

  /* Cost factors */
  .cost-factors {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .cost-col { background: var(--color-surface); padding: 2rem; }

  .cost-col-title {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin-bottom: 1rem;
  }

  .cost-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cost-list li {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.4;
  }

  .cost-list--up li::before {
    content: '↑';
    position: absolute;
    left: 0;
    color: var(--color-accent-2);
    font-size: var(--fs-xs);
  }

  .cost-list--down li::before {
    content: '↓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: var(--fs-xs);
  }

  /* CTA */
  .pricing-cta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    padding: 2.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    flex-wrap: wrap;
  }

  .pricing-cta-h2 {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: 300;
    color: var(--color-text);
    margin-bottom: 0.4rem;
  }

  .pricing-cta-text p {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    margin: 0;
    max-width: none;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .packages { grid-template-columns: 1fr; }
    .cost-factors { grid-template-columns: 1fr; }
    .pricing-cta { flex-direction: column; }
  }
</style>
