---
import { tStr, DEFAULT_LOCALE, type Localized, type Locale } from '../../lib/i18n';

interface Item {
  title: Localized<string>;
  desc: Localized<string>;
  href?: string;
}
interface Props {
  columns?: 2 | 3;
  items: Item[];
}
const { columns = 3, items } = Astro.props;
const lang: Locale = (Astro.locals as { lang?: Locale })?.lang ?? DEFAULT_LOCALE;
---
<div class:list={['deliverable-grid', columns === 3 ? 'grid-3' : 'grid-2']}>
  {items.map(item => {
    const title = tStr(item.title, lang);
    const desc  = tStr(item.desc,  lang);
    return (
      <div class="deliverable-card">
        {item.href
          ? <a href={item.href} class="deliverable-title deliverable-title-link">{title}</a>
          : <h4 class="deliverable-title">{title}</h4>
        }
        <p class="deliverable-desc">{desc}</p>
      </div>
    );
  })}
</div>

<style>
  .deliverable-grid { display: grid; gap: var(--space-6); }
  .deliverable-grid.grid-2 { grid-template-columns: repeat(2, 1fr); }
  .deliverable-grid.grid-3 { grid-template-columns: repeat(3, 1fr); }
  @media (max-width: 640px) {
    .deliverable-grid.grid-2,
    .deliverable-grid.grid-3 { grid-template-columns: 1fr; }
  }
  .deliverable-card {
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-6);
  }
  .deliverable-title {
    font-size: var(--fs-body);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
    display: block;
  }
  a.deliverable-title-link {
    text-decoration: none;
    transition: color 200ms;
  }
  a.deliverable-title-link:hover { color: var(--color-accent); }
  .deliverable-desc { font-size: var(--fs-small); color: var(--color-text-muted); margin: 0; line-height: 1.6; }
</style>
