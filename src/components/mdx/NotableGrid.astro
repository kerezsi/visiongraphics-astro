---
import { tStr, DEFAULT_LOCALE, type Localized, type Locale } from '../../lib/i18n';

interface Item {
  name: Localized<string>;
  year: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
const lang: Locale = (Astro.locals as { lang?: Locale })?.lang ?? DEFAULT_LOCALE;
---
<div class="notable-grid">
  {items.map(item => (
    <div class="notable-item">
      <span class="notable-name">{tStr(item.name, lang)}</span>
      <span class="notable-year">{item.year}</span>
    </div>
  ))}
</div>

<style>
  .notable-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-1) var(--space-6); }
  .notable-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--space-1) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .notable-name { font-size: var(--fs-small); color: var(--color-text-muted); }
  .notable-year { font-size: var(--fs-xs); color: var(--color-text-faint); font-family: var(--font-mono, monospace); }
</style>
