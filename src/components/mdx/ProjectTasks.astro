---
// src/components/mdx/ProjectTasks.astro
// Renders the tasks text content for "The Task:" section.
// The section heading and techniques list are rendered by the page template.
// Content is passed as MDX children (slot).
---
<div class="mdx-project-tasks">
  <slot />
</div>

<style>
  .mdx-project-tasks :global(p) {
    font-size: var(--fs-small);
    line-height: 1.85;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    max-width: 70ch;
  }
</style>
