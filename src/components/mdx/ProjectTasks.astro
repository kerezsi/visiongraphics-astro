---
// src/components/mdx/ProjectTasks.astro
// Renders the "What We Did" section.
// Content is passed as MDX children (slot), not as a text prop.
---
<section class="mdx-project-tasks">
  <h2 class="project-section-title">What We Did</h2>
  <div class="story-text">
    <slot />
  </div>
</section>

<style>
  .mdx-project-tasks {
    margin-bottom: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .project-section-title {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin-bottom: 1rem;
  }
  .story-text :global(p) {
    font-size: var(--fs-small);
    line-height: 1.85;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    max-width: 70ch;
  }
</style>
