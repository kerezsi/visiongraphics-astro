---
// src/components/mdx/ProjectStory.astro
// Renders the story/background section with an editable heading.
// Content is passed as MDX children (slot).
const { heading = 'The Story:' } = Astro.props;
---
<section class="mdx-project-story">
  <h2 class="project-red-heading">{heading}</h2>
  <div class="story-text">
    <slot />
  </div>
</section>

<style>
  .mdx-project-story {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }
  .project-red-heading {
    font-family: var(--font-display);
    font-size: var(--fs-h4);
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: var(--space-5);
    letter-spacing: -0.01em;
  }
  .story-text :global(p) {
    font-size: var(--fs-small);
    line-height: 1.85;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    max-width: 70ch;
  }
</style>
