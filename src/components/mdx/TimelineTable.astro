---
import { tStr, DEFAULT_LOCALE, type Localized, type Locale } from '../../lib/i18n';

interface Row {
  scope: Localized<string>;
  deliverables: Localized<string>;
}
interface Props {
  rows: Row[];
}
const { rows } = Astro.props;
const lang: Locale = (Astro.locals as { lang?: Locale })?.lang ?? DEFAULT_LOCALE;
---
<div class="timeline-table">
  {rows.map(row => (
    <div class="timeline-row">
      <span class="timeline-scope">{tStr(row.scope, lang)}</span>
      <span class="timeline-deliverables">{tStr(row.deliverables, lang)}</span>
    </div>
  ))}
</div>

<style>
  .timeline-table { display: flex; flex-direction: column; gap: var(--space-2); }
  .timeline-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--space-4);
    font-size: var(--fs-small);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .timeline-scope { color: var(--color-text-muted); font-weight: 600; }
  .timeline-deliverables { color: var(--color-text-muted); }
</style>
