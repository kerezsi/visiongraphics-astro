---
// src/components/ui/PageHero.astro
//
// Two variants — matched to dev.visiongraphics.eu measured heights:
//
//   variant="page"    → ~560px  — top-level section pages (services, portfolio, about…)
//   variant="section" → ~420px  — service sub-pages and detail pages
//
// Props:
//   image    — path to banner image, e.g. "/_img/banners/banner-services.jpg"
//   label    — small red line 1, e.g. "Visuals & Solutions"
//   title    — large bold white line 2, e.g. "Show It, Scale It, Build It."
//   variant  — "page" (default) | "section"

interface Props {
  image:    string;
  label:    string;
  title:    string;
  variant?: 'page' | 'section';
  imageAlt?: string;
}

const { image, label, title, variant = 'page', imageAlt = '' } = Astro.props;
---

<div class={`page-hero page-hero--${variant}`}>
  <div class="page-hero__bg">
    <img src={image} alt={imageAlt} loading="eager" decoding="async" />
  </div>
  <div class="page-hero__content container">
    <p class="page-hero__label">{label}</p>
    <h1 class="page-hero__title">{title}</h1>
  </div>
</div>

<style>
  /* ── Shared base ─────────────────────────────────────────── */
  .page-hero {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Variant heights (matching dev.visiongraphics.eu) ──── */
  .page-hero--page    { height: clamp(320px, 42vw, 560px); }
  .page-hero--section { height: clamp(260px, 33vw, 420px); }

  /* ── Background image ───────────────────────────────────── */
  .page-hero__bg {
    position: absolute;
    inset: 0;
  }

  .page-hero__bg img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
    display: block;
  }

  /* Dark gradient: solid on left, transparent on right */
  .page-hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      var(--color-bg) 0%,
      var(--color-bg) 28%,
      rgba(26, 26, 26, 0.80) 52%,
      rgba(26, 26, 26, 0.28) 72%,
      transparent 100%
    );
  }

  /* ── Text content ───────────────────────────────────────── */
  .page-hero__content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    padding-block: 2.5rem;
    max-width: 60%;
  }

  .page-hero__label {
    font-family: var(--font-body);
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.02em;
    margin: 0;
    line-height: 1.2;
  }

  .page-hero__title {
    font-family: var(--font-body);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin: 0;
  }

  /* ── Variant font sizes ─────────────────────────────────── */
  .page-hero--page .page-hero__label   { font-size: 0.9rem; }
  .page-hero--page .page-hero__title   { font-size: 2.2rem; }

  .page-hero--section .page-hero__label { font-size: 0.8rem; }
  .page-hero--section .page-hero__title { font-size: 1.8rem; }

  /* ── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .page-hero--page    { height: clamp(260px, 55vw, 340px); }
    .page-hero--section { height: clamp(200px, 45vw, 280px); }

    .page-hero__content {
      max-width: 90%;
      padding-inline: 0;
    }

    .page-hero__bg::after {
      background: linear-gradient(
        to right,
        var(--color-bg) 0%,
        var(--color-bg) 45%,
        rgba(26, 26, 26, 0.88) 70%,
        rgba(26, 26, 26, 0.65) 100%
      );
    }
  }
</style>
