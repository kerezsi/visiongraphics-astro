---
// src/components/ui/PageHero.astro
// Uniform page banner used on all interior pages.
// Matches dev.visiongraphics.eu visual style:
//   - Full-width dark banner, ~300px tall
//   - Image on the right, fading to dark on the left
//   - label = small red text (line 1)
//   - title = large bold white text (line 2)

interface Props {
  image: string;       // path to banner image, e.g. "/_img/banners/banner-services.jpg"
  label: string;       // small red line, e.g. "Visuals & Solutions"
  title: string;       // large white heading, e.g. "Show It, Scale It, Build It."
  imageAlt?: string;
}

const { image, label, title, imageAlt = '' } = Astro.props;
---

<div class="page-hero">
  <div class="page-hero-bg">
    <img src={image} alt={imageAlt} loading="eager" decoding="async" />
  </div>
  <div class="page-hero-content container">
    <p class="page-hero-label">{label}</p>
    <h1 class="page-hero-title">{title}</h1>
  </div>
</div>

<style>
  .page-hero {
    position: relative;
    width: 100%;
    height: clamp(200px, 28vw, 340px);
    overflow: hidden;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  /* Background image — right-aligned, fades to dark on the left */
  .page-hero-bg {
    position: absolute;
    inset: 0;
  }

  .page-hero-bg img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
    display: block;
  }

  /* Gradient: solid dark on left, transparent on right */
  .page-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      var(--color-bg) 0%,
      var(--color-bg) 30%,
      rgba(26, 26, 26, 0.82) 55%,
      rgba(26, 26, 26, 0.35) 75%,
      transparent 100%
    );
  }

  /* Text — sits above the gradient */
  .page-hero-content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.4rem;
    padding-block: 2rem;
    max-width: 55%;
  }

  .page-hero-label {
    font-family: var(--font-body);
    font-size: clamp(0.8rem, 1.5vw, 1rem);
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.02em;
    margin: 0;
    line-height: 1.2;
  }

  .page-hero-title {
    font-family: var(--font-body);
    font-size: clamp(1.8rem, 4.5vw, 3.5rem);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0;
  }

  @media (max-width: 640px) {
    .page-hero-content {
      max-width: 100%;
    }
    .page-hero-bg::after {
      background: linear-gradient(
        to right,
        var(--color-bg) 0%,
        var(--color-bg) 50%,
        rgba(26, 26, 26, 0.9) 75%,
        rgba(26, 26, 26, 0.7) 100%
      );
    }
  }
</style>
