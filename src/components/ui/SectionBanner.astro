---
// src/components/ui/SectionBanner.astro
// Mid-page section header banner — smaller variant of PageHero
// Used to introduce major sections within a page (e.g. About sections)

interface Props {
  image:         string;
  label:         string;
  title:         string;
  imageAlt?:     string;
  align?:        'left' | 'center';
  headingLevel?: 'h1' | 'h2';
  size?:         'page' | 'section';   // page = taller hero-like, section = compact mid-page
}

const {
  image,
  label,
  title,
  imageAlt     = '',
  align        = 'left',
  headingLevel = 'h2',
  size         = 'section',
} = Astro.props;

const HeadingTag = headingLevel;
---

<div class={`section-banner section-banner--${align} section-banner--${size}`}>
  <div class="section-banner__bg">
    <img src={image} alt={imageAlt} loading="lazy" decoding="async" />
  </div>
  <div class="section-banner__overlay" aria-hidden="true"></div>
  <div class="section-banner__content container">
    <p class="section-banner__label">{label}</p>
    <HeadingTag class="section-banner__title">{title}</HeadingTag>
  </div>
</div>

<style>
  .section-banner {
    position: relative;
    height: clamp(90px, calc(16.5vw - 45px), 180px);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    width: 100%;
  }

  /* Page-header size — ½ of original dev height */
  .section-banner--page {
    height: clamp(135px, 16.5vw, 225px);
  }

  /* Background image */
  .section-banner__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .section-banner__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  /* Dark gradient — darker than PageHero since these are smaller */
  .section-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      105deg,
      rgba(10, 10, 10, 0.92) 0%,
      rgba(10, 10, 10, 0.72) 55%,
      rgba(10, 10, 10, 0.45) 100%
    );
  }

  .section-banner--center .section-banner__overlay {
    background: linear-gradient(
      180deg,
      rgba(10, 10, 10, 0.3) 0%,
      rgba(10, 10, 10, 0.85) 100%
    );
  }

  /* Content */
  .section-banner__content {
    position: relative;
    z-index: 2;
    padding-block: var(--space-6);
    width: 100%;
  }

  .section-banner__label {
    @apply font-body text-tiny font-semibold uppercase tracking-wide-18 text-accent leading-none;
    margin: 0 0 var(--space-2);
  }

  .section-banner__title {
    @apply font-display text-h4 font-light text-content leading-none;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .section-banner--center .section-banner__content { text-align: center; }
  .section-banner--center .section-banner__label { @apply flex justify-center; }
</style>
