---
// src/components/ui/SectionBanner.astro
// Mid-page section header banner — smaller variant of PageHero
// Used to introduce major sections within a page (e.g. About sections)
// AND inside MDX bodies (registered as the `SectionBanner` component in
// service/vision-tech templates), so it must accept Localized<string> for
// label/title/imageAlt to support per-locale MDX prop syntax:
//   <SectionBanner label={{ en: "Interior", hu: "Belső" }} ... />

import { tStr, DEFAULT_LOCALE, type Localized, type Locale } from '../../lib/i18n';

interface Props {
  image:         string;
  label:         Localized<string>;
  title:         Localized<string>;
  imageAlt?:     Localized<string>;
  align?:        'left' | 'center';
  headingLevel?: 'h1' | 'h2';
  size?:         'page' | 'section';   // page = taller hero-like, section = compact mid-page
}

const {
  image,
  label,
  title,
  imageAlt,
  align        = 'left',
  headingLevel = 'h2',
  size         = 'section',
} = Astro.props;

const lang: Locale = (Astro.locals as { lang?: Locale })?.lang ?? DEFAULT_LOCALE;
const labelStr    = tStr(label,    lang);
const titleStr    = tStr(title,    lang);
const imageAltStr = tStr(imageAlt, lang);

const HeadingTag = headingLevel;
---

<div class={`section-banner section-banner--${align} section-banner--${size}`}>
  <div class="section-banner__bg">
    <img src={image} alt={imageAltStr} loading="lazy" decoding="async" />
  </div>
  <div class="section-banner__overlay" aria-hidden="true"></div>
  <div class="section-banner__content container">
    <p class="section-banner__label">{labelStr}</p>
    <HeadingTag class="section-banner__title">{titleStr}</HeadingTag>
  </div>
</div>

<style>
  .section-banner {
    position: relative;
    height: clamp(90px, calc(16.5vw - 45px), 180px);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    width: 100%;
  }

  /* Page-header size — ½ of original dev height */
  .section-banner--page {
    height: clamp(135px, 16.5vw, 225px);
  }

  /* Background image */
  .section-banner__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .section-banner__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  /* Gradient overlay — dark by default, overridden for light mode */
  .section-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      105deg,
      rgba(10, 10, 10, 0.92) 0%,
      rgba(10, 10, 10, 0.72) 55%,
      rgba(10, 10, 10, 0.45) 100%
    );
  }

  .section-banner--center .section-banner__overlay {
    background: linear-gradient(
      180deg,
      rgba(10, 10, 10, 0.3) 0%,
      rgba(10, 10, 10, 0.85) 100%
    );
  }

  /* Light mode — fade to off-white */
  :global([data-theme="light"]) .section-banner__overlay {
    background: linear-gradient(
      105deg,
      rgba(247, 245, 242, 0.92) 0%,
      rgba(247, 245, 242, 0.72) 55%,
      rgba(247, 245, 242, 0.30) 100%
    );
  }

  :global([data-theme="light"]) .section-banner--center .section-banner__overlay {
    background: linear-gradient(
      180deg,
      rgba(247, 245, 242, 0.20) 0%,
      rgba(247, 245, 242, 0.88) 100%
    );
  }

  /* Content */
  .section-banner__content {
    position: relative;
    z-index: 2;
    padding-block: var(--space-6);
    width: 100%;
  }

  .section-banner__label {
    @apply font-body text-tiny font-semibold uppercase tracking-wide-18 text-accent leading-none;
    margin: 0 0 var(--space-2);
  }

  .section-banner__title {
    @apply font-display text-h4 font-light text-content leading-none;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .section-banner--center .section-banner__content { text-align: center; }
  .section-banner--center .section-banner__label { @apply flex justify-center; }
</style>
