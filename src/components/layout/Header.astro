---
// src/components/layout/Header.astro

import navConfigRaw from '../../data/nav-config.json';
import ThemeToggle from '../ui/ThemeToggle.astro';
import LangSwitcher from './LangSwitcher.astro';
import { DEFAULT_LOCALE, localeUrl, localeFromPath, type Locale } from '../../lib/i18n';
import { ui } from '../../i18n/strings';

const path = Astro.url.pathname;
const lang: Locale = (Astro.locals as { lang?: Locale })?.lang ?? localeFromPath(path);
const L = ui(lang);

// nav-config.json stores English labels and bare-root hrefs (e.g. "/portfolio/").
// We translate the labels via a href→key map, and prefix hrefs with the active
// locale. The JSON file itself stays unchanged so the editor's Pages tab keeps
// working without modification.
const NAV_LABEL_KEY: Record<string, keyof typeof L.nav> = {
  '/portfolio/':    'portfolio',
  '/services/':     'services',
  '/vision-tech/':  'technologies',
  '/about/':        'about',
  '/contact/':      'contact',
  '/faq/':          'faq',
  '/pricing/':      'pricing',
  '/articles/':     'blog',
};

const navItems = (navConfigRaw as Array<{ label: string; href: string; enabled: boolean }>)
  .filter((item) => item.enabled)
  .map((item) => {
    const key = NAV_LABEL_KEY[item.href];
    return {
      label: key ? L.nav[key] : item.label,
      href:  localeUrl(item.href, lang),
    };
  });

function isActive(href: string): boolean {
  if (href === `/${lang}/`) return path === `/${lang}/` || path === `/${lang}`;
  return path.startsWith(href);
}
---

<header class="site-header" id="site-header">
  <div class="container header-inner">

    <!-- Logo -->
    <a href={localeUrl('/', lang)} class="logo" aria-label="Vision Graphics — Home">
      <img src="/logo.png"   alt="Vision Graphics Kft." class="logo-img logo-dark"  width="160" height="39" />
      <img src="/logo_b.png" alt=""                      class="logo-img logo-light" width="160" height="39" aria-hidden="true" />
    </a>

    <!-- Desktop Nav -->
    <nav class="desktop-nav" aria-label="Main navigation">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={['nav-link', { active: isActive(item.href) }]}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Language switcher + theme toggle (desktop only — both also in mobile nav dropdown) -->
    <span class="desktop-header-controls">
      <LangSwitcher />
      <ThemeToggle />
    </span>

    <!-- Mobile menu button -->
    <button
      class="mobile-menu-btn"
      id="mobile-menu-btn"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Toggle navigation"
    >
      <span class="hamburger"></span>
    </button>

  </div>

  <!-- Mobile Nav -->
  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation" hidden>
    {navItems.map(item => (
      <a
        href={item.href}
        class:list={['mobile-nav-link', { active: isActive(item.href) }]}
      >
        {item.label}
      </a>
    ))}
    <div class="mobile-nav-lang">
      <LangSwitcher />
    </div>
    <div
      class="mobile-nav-theme"
      id="mobile-nav-theme"
      role="button"
      tabindex="0"
      aria-label="Toggle light/dark mode"
    >
      <ThemeToggle />
      <span class="mobile-nav-theme-label">{lang === 'hu' ? 'Világos / sötét mód' : 'Toggle light/dark'}</span>
    </div>
  </nav>
</header>


<script>
  const btn = document.getElementById('mobile-menu-btn');
  const nav = document.getElementById('mobile-nav');
  const header = document.getElementById('site-header');

  function closeMobileNav() {
    if (!btn || !nav) return;
    btn.setAttribute('aria-expanded', 'false');
    nav.setAttribute('hidden', '');
    btn.classList.remove('open');
  }

  // Mobile toggle
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    nav?.toggleAttribute('hidden');
    btn.classList.toggle('open');
  });

  // Close on nav-link selection (but NOT on the theme-toggle row)
  nav?.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', closeMobileNav);
  });

  // Make the whole theme row clickable — forwards to the inner toggle button.
  // (Wrapper is a div + role=button because nesting a real <button> in another
  // <button> is invalid HTML — the browser collapses the outer one.)
  const themeRow = document.getElementById('mobile-nav-theme');
  function triggerThemeToggle(e: Event) {
    const inner = themeRow?.querySelector<HTMLButtonElement>('.theme-toggle-btn');
    if (!inner) return;
    if (e.target instanceof Node && inner.contains(e.target)) return; // inner button handles its own click
    inner.click();
  }
  themeRow?.addEventListener('click', triggerThemeToggle);
  themeRow?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      triggerThemeToggle(e);
    }
  });

  // Scroll shadow
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-header-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color 300ms ease;
  }

  .site-header.scrolled {
    @apply border-b border-line;
  }

  .header-inner {
    @apply flex items-center justify-between;
    height: var(--size-header);
  }

  /* Logo */
  .logo {
    @apply flex items-center no-underline flex-shrink-0;
  }

  .logo-img {
    @apply block w-auto;
    height: var(--size-logo);
  }
  .logo-light { display: none; }
  :global([data-theme="light"]) .logo-dark  { display: none; }
  :global([data-theme="light"]) .logo-light { display: block; }

  /* Desktop Nav */
  .desktop-nav {
    @apply flex items-center;
  }

  .nav-link {
    @apply font-body text-tiny font-medium text-muted no-underline uppercase tracking-wide-8 transition-colors duration-200;
    padding: var(--space-2) var(--space-3);
  }

  .nav-link:hover {
    @apply text-content;
  }

  .nav-link.active {
    @apply text-accent;
  }

  /* Mobile button */
  .mobile-menu-btn {
    @apply hidden bg-transparent border border-line cursor-pointer text-muted transition-colors duration-200;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
  }

  .mobile-menu-btn:hover {
    @apply border-muted;
  }

  .hamburger,
  .hamburger::before,
  .hamburger::after {
    display: block;
    width: 18px;
    height: 1.5px;
    background: currentColor;
    transition: all 200ms ease;
  }

  .hamburger {
    position: relative;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
  }

  .hamburger::before { top: -5px; }
  .hamburger::after  { top:  5px; }

  .mobile-menu-btn.open .hamburger { background: transparent; }
  .mobile-menu-btn.open .hamburger::before { top: 0; transform: rotate(45deg); }
  .mobile-menu-btn.open .hamburger::after  { top: 0; transform: rotate(-45deg); }

  /* Mobile nav panel */
  .mobile-nav[hidden] { display: none; }

  .mobile-nav {
    @apply border-t border-line bg-page flex flex-col;
    padding: var(--space-4);
    gap: var(--space-1);
  }

  .mobile-nav-link {
    @apply font-body text-small font-light text-muted;
    padding: var(--space-3);
    border-radius: var(--radius-sm);
    transition: color 150ms ease, background 150ms ease;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    @apply text-accent;
    background: rgba(218, 19, 19, 0.08);
  }

  .mobile-nav-theme {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    margin-top: var(--space-2);
    border: none;
    border-top: 1px solid var(--color-border);
    border-radius: 0;
    background: transparent;
    width: 100%;
    text-align: left;
    cursor: pointer;
    color: inherit;
    font: inherit;
    transition: background 150ms ease;
  }

  .mobile-nav-theme:hover {
    background: rgba(218, 19, 19, 0.06);
  }

  .mobile-nav-theme-label {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 300;
    color: var(--color-text-faint);
  }

  /* Desktop header controls (lang switcher + theme toggle) */
  .desktop-header-controls {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* Mobile language switcher row */
  .mobile-nav-lang {
    display: flex;
    align-items: center;
    padding: var(--space-3);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-2);
  }

  /* Responsive */
  @media (min-width: 901px) {
    .mobile-nav { display: none !important; }
  }

  @media (max-width: 900px) {
    .desktop-nav             { display: none; }
    .desktop-header-controls { display: none; }
    .mobile-menu-btn { display: flex; align-items: center; }
  }
</style>
