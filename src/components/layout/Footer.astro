---
// src/components/layout/Footer.astro
// Corrected: no newsletter widget, consistent contact info

import navConfig from '../../data/nav-config.json';
import { localeUrl, localeFromPath, type Locale } from '../../lib/i18n';
import { ui } from '../../i18n/strings';

const year = new Date().getFullYear();

const path = Astro.url.pathname;
const lang: Locale = (Astro.locals as { lang?: Locale })?.lang ?? localeFromPath(path);
const L = ui(lang);

// Service column labels are short, hardcoded HU translations (the underlying
// service slugs are language-agnostic). When MDX service titles are translated,
// we could fetch them from the collection instead, but for footer chrome the
// short labels are clearer.
const SERVICE_LABELS: Record<string, { en: string; hu: string }> = {
  '/services/architectural-visualization/': { en: 'Architectural Visualization', hu: 'Építészeti látványterv' },
  '/services/large-scale-projects/':        { en: 'Large-Scale Projects',        hu: 'Nagyléptékű projektek' },
  '/services/advanced-ai-services/':        { en: 'AI-Enhanced Services',        hu: 'AI-támogatott szolgáltatások' },
  '/services/workflow-optimization/':       { en: 'Workflow Optimization',       hu: 'Munkafolyamat-optimalizálás' },
  '/services/3ds-max-tools/':               { en: '3ds Max Tools',               hu: '3ds Max eszközök' },
  '/services/custom-rendering/':            { en: 'Custom Rendering',            hu: 'Egyedi renderelés' },
};

const services = Object.entries(SERVICE_LABELS).map(([href, labels]) => ({
  label: labels[lang],
  href:  localeUrl(href, lang),
}));

// Studio column mirrors the top-nav. Translate via the same href→key map as
// Header (kept inline here to avoid an extra import; keep in sync).
const NAV_LABEL_KEY: Record<string, keyof typeof L.nav> = {
  '/portfolio/':    'portfolio',
  '/vision-tech/':  'technologies',
  '/about/':        'about',
  '/contact/':      'contact',
  '/faq/':          'faq',
  '/pricing/':      'pricing',
  '/articles/':     'blog',
};

const links = (navConfig as Array<{ label: string; href: string; enabled: boolean }>)
  .filter(item => item.enabled && item.href !== '/services/')
  .map(item => {
    const key = NAV_LABEL_KEY[item.href];
    return {
      label: key ? L.nav[key] : item.label,
      href:  localeUrl(item.href, lang),
    };
  });
---

<footer class="site-footer">
  <div class="container">

    <div class="footer-grid">

      <!-- Brand column -->
      <div class="footer-brand">
        <a href={localeUrl('/', lang)} class="footer-logo" aria-label="Vision Graphics — Home">
          <img src="/logo.png"   alt="Vision Graphics Kft." class="footer-logo-img footer-logo-dark"  width="140" height="34" />
          <img src="/logo_b.png" alt=""                      class="footer-logo-img footer-logo-light" width="140" height="34" aria-hidden="true" />
        </a>
        <p class="footer-bio">
          {lang === 'hu'
            ? 'Építészeti látványtervezés és több.\nBudapest, globálisan dolgozunk 1996 óta.'
            : 'Architectural visualization & more.\nBudapest, working globally since 1996.'}
        </p>
        <address class="footer-address">
          Hollósy Simon utca 15.<br />
          {lang === 'hu' ? '1126 Budapest, Magyarország' : '1126 Budapest, Hungary'}
        </address>
        <div class="footer-contact">
          <a href="tel:+36309454179">+36 30 945 4179</a>
          <a href="mailto:info@visiongraphics.hu">info@visiongraphics.hu</a>
        </div>
      </div>

      <!-- Services column -->
      <div class="footer-col">
        <h4 class="footer-col-title">{L.nav.services}</h4>
        <nav aria-label="Services links">
          {services.map(s => (
            <a href={s.href} class="footer-link">{s.label}</a>
          ))}
        </nav>
      </div>

      <!-- Quick links column -->
      <div class="footer-col">
        <h4 class="footer-col-title">{lang === 'hu' ? 'Stúdió' : 'Studio'}</h4>
        <nav aria-label="Studio links">
          {links.map(l => (
            <a href={l.href} class="footer-link">{l.label}</a>
          ))}
        </nav>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <span>© Vision Graphics Kft. {year}</span>
      <span class="footer-bottom-right">
        Budapest · Est. 1996
      </span>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    @apply border-t border-line;
    padding-block: var(--space-16) var(--space-8);
    margin-top: var(--space-24);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-12);
    padding-bottom: var(--space-12);
    @apply border-b border-line;
  }

  /* Logo */
  .footer-logo {
    @apply inline-block no-underline;
    margin-bottom: var(--space-4);
    opacity: 0.85;
    transition: opacity 200ms ease;
  }

  .footer-logo:hover { opacity: 1; }

  .footer-logo-img {
    @apply block w-auto;
    height: var(--size-logo-sm);
  }
  .footer-logo-light { display: none; }
  :global([data-theme="light"]) .footer-logo-dark  { display: none; }
  :global([data-theme="light"]) .footer-logo-light { display: block; }

  .footer-bio {
    @apply text-small text-muted;
    margin-bottom: var(--space-5);
    max-width: 28ch;
    line-height: 1.6;
  }

  .footer-address {
    @apply text-tiny text-muted not-italic;
    line-height: 1.7;
    margin-bottom: var(--space-3);
  }

  .footer-contact {
    @apply flex flex-col;
    gap: var(--space-1);
  }

  .footer-contact a {
    @apply text-tiny text-muted no-underline transition-colors duration-200;
  }

  .footer-contact a:hover {
    @apply text-accent;
  }

  /* Columns */
  .footer-col-title {
    @apply font-body text-tiny font-medium uppercase tracking-wide-15 text-faint;
    margin-bottom: var(--space-4);
  }

  .footer-col nav {
    @apply flex flex-col;
    gap: var(--space-2);
  }

  .footer-link {
    @apply text-tiny text-muted no-underline transition-colors duration-200;
    line-height: 1.4;
  }

  .footer-link:hover {
    @apply text-content;
  }

  /* Bottom bar */
  .footer-bottom {
    @apply flex justify-between items-center font-body text-tiny text-faint;
    padding-top: var(--space-6);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer-bottom {
      @apply flex-col text-center;
      gap: 0.5rem;
    }
  }
</style>
