---
// src/components/layout/Footer.astro
// Corrected: no newsletter widget, consistent contact info

const year = new Date().getFullYear();

const services = [
  { label: 'Architectural Visualization', href: '/services/architectural-visualization/' },
  { label: 'Large-Scale Projects',        href: '/services/large-scale-projects/' },
  { label: 'AI-Enhanced Services',        href: '/services/advanced-ai-services/' },
  { label: 'Workflow Optimization',       href: '/services/workflow-optimization/' },
  { label: '3ds Max Tools',               href: '/services/3ds-max-tools/' },
  { label: 'Custom Rendering',            href: '/services/custom-rendering/' },
];

const links = [
  { label: 'Portfolio',    href: '/portfolio/' },
  { label: 'Technologies', href: '/vision-tech/' },
  { label: 'FAQ',          href: '/faq/' },
  { label: 'Pricing',      href: '/pricing/' },
  { label: 'Blog',         href: '/articles/' },
  { label: 'About',        href: '/about/' },
  { label: 'Contact',      href: '/contact/' },
];
---

<footer class="site-footer">
  <div class="container">

    <div class="footer-grid">

      <!-- Brand column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Vision Graphics — Home">
          <img src="/logo.png" alt="Vision Graphics Kft." class="footer-logo-img" width="140" height="34" />
        </a>
        <p class="footer-bio">
          Architectural visualization, Budapest.
          Working globally since 1996.
        </p>
        <address class="footer-address">
          Hollósy Simon utca 15.<br />
          1126 Budapest, Hungary
        </address>
        <div class="footer-contact">
          <a href="tel:+36309454179">+36 30 945 4179</a>
          <a href="mailto:info@visiongraphics.eu">info@visiongraphics.eu</a>
        </div>
      </div>

      <!-- Services column -->
      <div class="footer-col">
        <h4 class="footer-col-title">Services</h4>
        <nav aria-label="Services links">
          {services.map(s => (
            <a href={s.href} class="footer-link">{s.label}</a>
          ))}
        </nav>
      </div>

      <!-- Quick links column -->
      <div class="footer-col">
        <h4 class="footer-col-title">Studio</h4>
        <nav aria-label="Studio links">
          {links.map(l => (
            <a href={l.href} class="footer-link">{l.label}</a>
          ))}
        </nav>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <span>© Vision Graphics Kft. {year}</span>
      <span class="footer-bottom-right">
        Budapest · Est. 1996
      </span>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    @apply border-t border-line;
    padding-block: var(--space-16) var(--space-8);
    margin-top: var(--space-24);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-12);
    padding-bottom: var(--space-12);
    @apply border-b border-line;
  }

  /* Logo */
  .footer-logo {
    @apply inline-block no-underline;
    margin-bottom: var(--space-4);
    opacity: 0.85;
    transition: opacity 200ms ease;
  }

  .footer-logo:hover { opacity: 1; }

  .footer-logo-img {
    @apply block w-auto;
    height: var(--size-logo-sm);
  }

  .footer-bio {
    @apply text-small text-muted;
    margin-bottom: var(--space-5);
    max-width: 28ch;
    line-height: 1.6;
  }

  .footer-address {
    @apply text-tiny text-muted not-italic;
    line-height: 1.7;
    margin-bottom: var(--space-3);
  }

  .footer-contact {
    @apply flex flex-col;
    gap: var(--space-1);
  }

  .footer-contact a {
    @apply text-tiny text-muted no-underline transition-colors duration-200;
  }

  .footer-contact a:hover {
    @apply text-accent;
  }

  /* Columns */
  .footer-col-title {
    @apply font-body text-tiny font-medium uppercase tracking-wide-15 text-faint;
    margin-bottom: var(--space-4);
  }

  .footer-col nav {
    @apply flex flex-col;
    gap: var(--space-2);
  }

  .footer-link {
    @apply text-tiny text-muted no-underline transition-colors duration-200;
    line-height: 1.4;
  }

  .footer-link:hover {
    @apply text-content;
  }

  /* Bottom bar */
  .footer-bottom {
    @apply flex justify-between items-center font-body text-tiny text-faint;
    padding-top: var(--space-6);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer-bottom {
      @apply flex-col text-center;
      gap: 0.5rem;
    }
  }
</style>
