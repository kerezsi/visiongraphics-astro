---
// src/components/media/FilmEmbed.astro
// Vimeo facade pattern — thumbnail shown, iframe only loads on click
// Fetches thumbnail at BUILD TIME (no runtime API calls)

import { tStr, DEFAULT_LOCALE, type Localized, type Locale } from '../../lib/i18n';

interface Props {
  vimeoId: string;
  title:   Localized<string>;
}

const { vimeoId, title } = Astro.props;
const lang: Locale = (Astro.locals as { lang?: Locale })?.lang ?? DEFAULT_LOCALE;
const titleStr = tStr(title, lang);

// Fetch Vimeo thumbnail at build time
let thumbnailUrl = '';
try {
  const res = await fetch(`https://vimeo.com/api/v2/video/${vimeoId}.json`);
  if (res.ok) {
    const data = await res.json();
    thumbnailUrl = data[0]?.thumbnail_large ?? data[0]?.thumbnail_medium ?? '';
  }
} catch {
  // Fallback — no thumbnail
}
---

<div
  class="film-embed"
  data-vimeo-id={vimeoId}
  role="button"
  tabindex="0"
  aria-label={lang === 'hu' ? `Film lejátszása: ${titleStr}` : `Play film: ${titleStr}`}
>
  {thumbnailUrl
    ? <img src={thumbnailUrl} alt={lang === 'hu' ? `${titleStr} — film miniatűr` : `${titleStr} — film thumbnail`} class="film-thumb" loading="lazy" />
    : <div class="film-thumb film-thumb--placeholder"></div>
  }

  <div class="film-overlay">
    <button class="film-play-btn" aria-label={lang === 'hu' ? 'Lejátszás' : 'Play'}>
      <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="30" cy="30" r="29" stroke="currentColor" stroke-width="1.5" opacity="0.6"/>
        <path d="M24 20L44 30L24 40V20Z" fill="currentColor"/>
      </svg>
    </button>
    <span class="film-title">{titleStr}</span>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.film-embed').forEach(embed => {
    const activate = () => {
      const id = embed.dataset.vimeoId;
      if (!id) return;
      const iframe = document.createElement('iframe');
      iframe.src = `https://player.vimeo.com/video/${id}?autoplay=1&color=c8a96e&title=0&byline=0&portrait=0`;
      iframe.allow = 'autoplay; fullscreen; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.className = 'film-iframe';
      embed.innerHTML = '';
      embed.appendChild(iframe);
      embed.classList.add('film-embed--active');
      embed.removeEventListener('click', activate);
      embed.removeEventListener('keydown', keyHandler);
    };

    const keyHandler = (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); }
    };

    embed.addEventListener('click', activate);
    embed.addEventListener('keydown', keyHandler);
  });
</script>

<style>
  .film-embed {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--color-surface-2);
    cursor: pointer;
    overflow: hidden;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  .film-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease, filter 400ms ease;
    filter: brightness(0.75);
  }

  .film-thumb--placeholder {
    background: linear-gradient(135deg, var(--color-surface-2), var(--color-surface));
  }

  .film-embed:hover .film-thumb {
    transform: scale(1.02);
    filter: brightness(0.6);
  }

  .film-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }

  .film-play-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    width: var(--space-16);
    height: var(--space-16);
    transition: transform 250ms ease, color 250ms ease;
    padding: 0;
  }

  .film-play-btn svg { width: 100%; height: 100%; }

  .film-embed:hover .film-play-btn {
    transform: scale(1.1);
    color: var(--color-accent);
  }

  .film-title {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 400;
    color: rgba(240, 237, 232, 0.8); /* near-white at 80% — no token for opacity variants */
    letter-spacing: 0.05em;
    text-align: center;
    padding-inline: var(--space-4);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
  }

  .film-iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .film-embed--active {
    cursor: default;
  }
</style>
