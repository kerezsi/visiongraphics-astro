---
// src/components/media/YouTubeEmbed.astro
// YouTube facade pattern — thumbnail at build time, iframe only on click

interface Props {
  url:    string;
  title?: string;
}

const { url, title = 'Video' } = Astro.props;

// Extract YouTube video ID from multiple URL patterns
function extractYouTubeId(rawUrl: string): string | null {
  try {
    // youtu.be/ID
    const shortMatch = rawUrl.match(/youtu\.be\/([A-Za-z0-9_-]{11})/);
    if (shortMatch) return shortMatch[1];

    // youtube.com/watch?v=ID
    const watchMatch = rawUrl.match(/[?&]v=([A-Za-z0-9_-]{11})/);
    if (watchMatch) return watchMatch[1];

    // youtube.com/embed/ID
    const embedMatch = rawUrl.match(/embed\/([A-Za-z0-9_-]{11})/);
    if (embedMatch) return embedMatch[1];

    return null;
  } catch {
    return null;
  }
}

const videoId = extractYouTubeId(url);
const thumbnailUrl = videoId
  ? `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`
  : null;
---

{videoId && (
  <div
    class="yt-embed"
    data-yt-id={videoId}
    role="button"
    tabindex="0"
    aria-label={`Play video: ${title}`}
  >
    {thumbnailUrl
      ? <img
          src={thumbnailUrl}
          alt={`${title} — video thumbnail`}
          class="yt-thumb"
          loading="lazy"
          onerror={`this.onerror=function(){this.onerror=null;this.src='https://img.youtube.com/vi/${videoId}/sddefault.jpg'};this.src='https://img.youtube.com/vi/${videoId}/hqdefault.jpg'`}
        />
      : <div class="yt-thumb yt-thumb--placeholder"></div>
    }

    <div class="yt-overlay">
      <button class="yt-play-btn" aria-label="Play">
        <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="30" cy="30" r="29" stroke="currentColor" stroke-width="1.5" opacity="0.6"/>
          <path d="M24 20L44 30L24 40V20Z" fill="currentColor"/>
        </svg>
      </button>
      <span class="yt-title">{title}</span>
    </div>
  </div>
)}

<script>
  document.querySelectorAll<HTMLElement>('.yt-embed').forEach(embed => {
    const activate = () => {
      const id = embed.dataset.ytId;
      if (!id) return;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0&modestbranding=1`;
      iframe.allow = 'autoplay; fullscreen; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.title = 'YouTube Video';
      iframe.style.cssText = 'width:100%;height:100%;border:none;display:block;';
      embed.innerHTML = '';
      embed.appendChild(iframe);
      embed.classList.add('yt-embed--active');
      embed.removeEventListener('click', activate);
      embed.removeEventListener('keydown', keyHandler);
    };

    const keyHandler = (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); }
    };

    embed.addEventListener('click', activate);
    embed.addEventListener('keydown', keyHandler);
  });
</script>

<style>
  .yt-embed {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--color-surface-2);
    cursor: pointer;
    overflow: hidden;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  .yt-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease, filter 400ms ease;
    filter: brightness(0.75);
  }

  .yt-thumb--placeholder {
    background: linear-gradient(135deg, var(--color-surface-2), var(--color-surface));
  }

  .yt-embed:hover .yt-thumb {
    transform: scale(1.02);
    filter: brightness(0.6);
  }

  .yt-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .yt-play-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    width: 4rem;
    height: 4rem;
    transition: transform 250ms ease, color 250ms ease;
    padding: 0;
  }

  .yt-play-btn svg { width: 100%; height: 100%; }

  .yt-embed:hover .yt-play-btn {
    transform: scale(1.1);
    color: var(--color-accent);
  }

  .yt-title {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 400;
    color: rgba(240, 237, 232, 0.8);
    letter-spacing: 0.05em;
    text-align: center;
    padding-inline: 1rem;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }

  .yt-embed--active {
    border-color: var(--color-border);
  }
</style>
